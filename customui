local function tvlRecodeV2Fn_startCompleteHeadSiphon()
    if tvlRecodeV2_siphonState.hooked then
        return true
    end

    if not tvlRecodeV2_siphonState.loaded then
        local mPlayers = game:GetService("Players")
        local mReplicatedStorage = game:GetService("ReplicatedStorage")

        local mLocalPlayer = mPlayers.LocalPlayer or mPlayers.PlayerAdded:Wait()
        local mHoldActionPrompt = require(
            mReplicatedStorage.ModuleScripts.FusionComponents.ScreenUtils.HoldActionPrompt
        )

        tvlRecodeV2_siphonState.localPlayer = mLocalPlayer
        tvlRecodeV2_siphonState.holdActionPrompt = mHoldActionPrompt
        tvlRecodeV2_siphonState.loaded = true
    end

    local ORIGINAL_KEY = "__tvl_siphon_original_new"
    local mHoldActionPrompt = tvlRecodeV2_siphonState.holdActionPrompt

    local function tvlRecodeV2Fn_tvlAutoCompletePrompt(instance)
        task.spawn(function()
            local progressValue = instance and instance.progressValue
            local instruction = instance and instance.instruction
            local goal = instance and instance.goal

            while instance do
                local currentProgress = progressValue and progressValue.get and progressValue:get() or 0
                if currentProgress >= (goal or 0) then break end

                local currentInstruction = instruction and instruction.get and instruction:get() or nil

                if currentInstruction == "HOLD" then
                    if not instance.buttonDown then
                        instance:onInputBegan()
                    end
                    task.wait()
                elseif currentInstruction == "PRESS" then
                    instance:onInputBegan()
                    task.wait()
                    instance:onInputEnded()
                    task.wait()
                else
                    task.wait()
                end
            end

            if instance and instance.buttonDown then
                instance:onInputEnded()
            end
        end)
    end

    tvlRecodeV2_siphonState.originalNew = rawget(mHoldActionPrompt, ORIGINAL_KEY) or mHoldActionPrompt.new
    rawset(mHoldActionPrompt, ORIGINAL_KEY, tvlRecodeV2_siphonState.originalNew)

    mHoldActionPrompt.new = function(...)
        local instance = tvlRecodeV2_siphonState.originalNew(...)
        tvlRecodeV2Fn_tvlAutoCompletePrompt(instance)
        return instance
    end

    tvlRecodeV2_siphonState.hooked = true
    return true
end

