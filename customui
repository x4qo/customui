local function tvlRecodeV2Fn_registerColorFlag(flag, initialColor, applyFn)
    local current = initialColor
    tvlRecodeV2_ColorConfigRegistry[flag] = {
        get = function()
            return { r = current.R, g = current.G, b = current.B }
        end,
        set = function(data)
            if type(data) ~= "table" then return end
            local color = Color3.new(tonumber(data.r) or 0, tonumber(data.g) or 0, tonumber(data.b) or 0)
            current = color
            applyFn(color)
        end,
    }
    return function(color)
        current = color
        applyFn(color)
    end
end

local tvlRecodeV2_lastBuildYield = os.clock()
local function tvlRecodeV2Fn_buildYield()
    if os.clock() - tvlRecodeV2_lastBuildYield >= 0.004 then
        task.wait()
        tvlRecodeV2_lastBuildYield = os.clock()
    end
end

local function tvlRecodeV2Fn_makeSection(column, sname)
    tvlRecodeV2Fn_buildYield()
    local section = tvlRecodeV2Fn_hugSection(column:section({ name = sname }))
    local secObj = { _section = section, _lastToggle = nil }

    function secObj:AddToggle(flag, o)
        if tvlRecodeV2_SafeMode and tvlRecodeV2_SafeToggleDeny[flag] then
            -- Not a safe-mode necessity; skip building it entirely.
            return { items = {} }
        end
        tvlRecodeV2Fn_buildYield()
        o = o or {}
        local toggle = section:toggle({
            name = o.Title or tostring(flag),
            flag = flag,
            type = "toggle",
            default = o.Default or false,
            callback = function(value)
                if o.Callback then o.Callback(value) end
            end,
        })
        self._lastToggle = toggle
        tvlRecodeV2_toggleByFlag[flag] = toggle
        return toggle
    end

    function secObj:AddSlider(flag, o)
        tvlRecodeV2Fn_buildYield()
        o = o or {}
        local rounding = tonumber(o.Rounding) or 0
        local interval = (rounding > 0) and (1 / (10 ^ rounding)) or 1
        local sld = section:slider({
            name = o.Title or tostring(flag),
            flag = flag,
            min = o.Min,
            max = o.Max,
            default = o.Default,
            decimal = interval,
            seperator = false,
            callback = function(value)
                if o.Callback then o.Callback(value) end
            end,
        })
        -- library:slider forces a trailing separator (its `or true` default ignores our
        -- seperator=false); strip it when the caller explicitly asks for no separator.
        if o.Seperator == false then
            local elements = section.items and section.items["elements"]
            if elements then
                local kids = elements:GetChildren()
                local last = kids[#kids]
                if last and last:IsA("Frame") and last.Size == UDim2.new(1, 1, 0, 1) then
                    last:Destroy()
                end
            end
        end
        return sld
    end

    function secObj:AddDropdown(flag, o)
        tvlRecodeV2Fn_buildYield()
        o = o or {}
        local dd = section:dropdown({
            name = o.Title or tostring(flag),
            flag = flag,
            items = o.Values or {},
            multi = o.Multi or false,
            default = o.Default,
            scrolling = o.Scrolling or false,
            max_height = o.MaxHeight,
            callback = function(value)
                if o.Callback then o.Callback(value) end
            end,
        })
        if o.Seperator == false then
            local elements = section.items and section.items["elements"]
            if elements then
                local kids = elements:GetChildren()
                local last = kids[#kids]
                if last and last:IsA("Frame") and last.Size == UDim2.new(1, 1, 0, 1) then
                    last:Destroy()
                end
            end
        end
        return dd
    end

    function secObj:AddButton(o)
        o = o or {}
        return section:button({
            name = o.Title or "Button",
            callback = function()
                if o.Callback then o.Callback() end
            end,
        })
    end

    function secObj:AddParagraph(o)
        o = o or {}
        if o.Title then section:label({ name = o.Title, seperator = false }) end
        if o.Content then section:label({ name = o.Content, seperator = false }) end
