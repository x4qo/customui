    msLabel.Size = UDim2.new(0, 0, 1, 0)
    msLabel.TextXAlignment = Enum.TextXAlignment.Left
    msLabel.BackgroundTransparency = 1
    msLabel.BorderSizePixel = 0
    msLabel.ZIndex = 62
    msLabel.Parent = bar

    do
        local lastFps, lastPing = -1, -1
        task.spawn(function()
            while gui.Parent do
                task.wait(1.5)
                if tvlRecodeV2_PresenceGui and tvlRecodeV2_PresenceGui.Enabled then
                    local fps = math.floor(1 / math.max(tvlRecodeV2_RunService.RenderStepped:Wait(), 1 / 240) + 0.5)
                    local ping = tvlRecodeV2Fn_getRealPingMs()
                    if ping then
                        ping = math.floor(ping + 0.5)
                    else
                        ping = 0
                        pcall(function() ping = math.floor(presenceLP:GetNetworkPing() * 1000 + 0.5) end)
                    end
                    if fps ~= lastFps then
                        lastFps = fps
                        fpsLabel.Text = string.format('%d <font color="rgb(110, 110, 116)">FPS</font>', fps)
                    end
                    if ping ~= lastPing then
                        lastPing = ping
                        msLabel.Text = string.format('%d <font color="rgb(110, 110, 116)">ms</font>', ping)
                    end
                end
            end
        end)
    end

    do
        local startPos, startInput
        local moveConn
        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                startInput = input.Position
                startPos   = bar.Position
                if moveConn then moveConn:Disconnect() end
                moveConn = tvlRecodeV2_UIS.InputChanged:Connect(function(input2)
                    if input2.UserInputType == Enum.UserInputType.MouseMovement then
                        local delta = input2.Position - startInput
                        bar.Position = UDim2.new(
                            startPos.X.Scale, startPos.X.Offset + delta.X,
                            startPos.Y.Scale, startPos.Y.Offset + delta.Y
                        )
                    end
                end)
            end
        end)
        local function stopDrag(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                if moveConn then moveConn:Disconnect(); moveConn = nil end
            end
        end
        bar.InputEnded:Connect(stopDrag)
        tvlRecodeV2_UIS.InputEnded:Connect(stopDrag)
    end
end

