local function tvlRecodeV2Fn_makeCustomSiphonController()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local PROMPT_NAME = "HoldActionPrompt"
    local VICTIM_START_BEHIND = "12955999854"
    local COUNTER_ANIM_ID = "rbxassetid://17898290067"

    local state = {
        enabled = false,
        escapeDelay = 2.6,
        lp = nil,
        pg = nil,
        siphonEscape = nil,
        counterAnim = nil,
        isVictim = false,
        connections = {},
    }

    local controller = {}

    local function getAnimator()
        local char = state.lp and state.lp.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        return humanoid and humanoid:FindFirstChildOfClass("Animator")
    end

    local function playCounterAnim()
        local animator = getAnimator()
        if not animator then return end
        local ok, track = pcall(function()
            return animator:LoadAnimation(state.counterAnim)
        end)
        if ok and track then
            pcall(function() track:Play() end)
        end
    end

    local function hookAnimator(animator)
        if not animator then return end
        state.connections[#state.connections + 1] = animator.AnimationPlayed:Connect(function(track)
            local id = track.Animation and track.Animation.AnimationId
            if id and id:match("%d+") == VICTIM_START_BEHIND then
                state.isVictim = true
            end
        end)
    end

    local function onPrompt()
        task.delay(state.escapeDelay, function()
            if not state.enabled then return end
            local victim = state.isVictim
            state.isVictim = false
            pcall(function() state.siphonEscape:FireServer() end)
            if victim then
                playCounterAnim()
            end
        end)
    end

    local function check(obj)
        if obj.Name == PROMPT_NAME then
            onPrompt()
        end
    end

    local function onCharacter(char)
        state.isVictim = false
        local humanoid = char:WaitForChild("Humanoid", 5)
        hookAnimator(humanoid and humanoid:WaitForChild("Animator", 5))
    end

    function controller:setDelay(value)
        local n = tonumber(value)
        if n then
            state.escapeDelay = math.max(0, n)
        end
        return state.escapeDelay
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end
        if enable then
            local ok = pcall(function()
                state.lp = Players.LocalPlayer or Players.PlayerAdded:Wait()
                state.pg = state.lp:WaitForChild("PlayerGui")
                state.siphonEscape = ReplicatedStorage
                    :WaitForChild("Remotes")
                    :WaitForChild("AbilityService")
                    :WaitForChild("ToServer")
                    :WaitForChild("SiphonEscape")
                state.counterAnim = Instance.new("Animation")
                state.counterAnim.AnimationId = COUNTER_ANIM_ID
            end)
            if not ok or not state.siphonEscape then
                return false, "Could not resolve SiphonEscape remote"
            end
            state.enabled = true
            state.isVictim = false

            state.connections[#state.connections + 1] = state.pg.DescendantAdded:Connect(check)
            for _, d in ipairs(state.pg:GetDescendants()) do check(d) end

            state.connections[#state.connections + 1] = state.lp.CharacterAdded:Connect(onCharacter)
            if state.lp.Character then
                task.spawn(onCharacter, state.lp.Character)
            end
            return true
        end

        state.enabled = false
        for _, conn in ipairs(state.connections) do
            pcall(function() conn:Disconnect() end)
        end
        table.clear(state.connections)
        state.isVictim = false
        return true
    end

    return controller
end

