-- Eject: switch every feature off (restoring hooks / unbinding render steps / dropping
-- connections) and then destroy the menu and every on-screen GUI so nothing remains.
local function tvlRecodeV2Fn_ejectScript()
    -- silence the flood of "X Disabled" toasts while we tear everything down
    tvlRecodeV2_featureNotificationsReady = false

    for _, toggle in pairs(tvlRecodeV2_toggleByFlag) do
        pcall(function()
            if type(toggle) == "table" and type(toggle.set) == "function" then
                toggle.enabled = false
                toggle.set(false)
            end
        end)
    end

    -- give the disable callbacks a beat to finish, then remove all UI
    task.delay(0.1, function()
        for _, gui in ipairs(tvlRecodeV2_teardownGuis) do
            pcall(function() if gui then gui:Destroy() end end)
        end
        pcall(function()
            if tvlRecodeV2_PresenceGui then tvlRecodeV2_PresenceGui:Destroy() end
        end)
        pcall(function()
            if tvlRecodeV2_Library and tvlRecodeV2_Library.keybind_screen then
                tvlRecodeV2_Library.keybind_screen:Destroy()
            end
        end)
        pcall(function()
            if tvlRecodeV2_Library and type(tvlRecodeV2_Library.unload_menu) == "function" then
                tvlRecodeV2_Library:unload_menu()
            end
        end)
        pcall(function() if getgenv then getgenv().library = nil end end)
    end)
end

