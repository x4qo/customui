    local speedStroke = Instance.new("UIStroke")
    speedStroke.Color = Color3.fromRGB(60, 60, 68)
    speedStroke.Thickness = 2
    speedStroke.Parent = speedCircle
    local speedText = Instance.new("TextLabel")
    speedText.Name = "\0"
    speedText.AnchorPoint = Vector2.new(0.5, 1)
    speedText.Position = UDim2.new(0.5, 0, 1, -5)
    speedText.Size = UDim2.new(1, 0, 0, 12)
    speedText.BackgroundTransparency = 1
    speedText.Text = "SPEED"
    speedText.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedText.TextStrokeTransparency = 0.5
    speedText.TextSize = 10
    speedText.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    speedText.ZIndex = 2
    speedText.Parent = speedCircle

    local function setSpeedActive(on)
        on = on and true or false
        if tvlRecodeV2_spoofRunSpeedState.uiEnabled then
            local c = tvlRecodeV2_spoofRunSpeedState.controller
            if c and type(c.setActive) == "function" then
                pcall(function() c:setActive(on) end)
            end
        end
        speedStroke.Color = on and tvlRecodeV2_currentAccent or Color3.fromRGB(60, 60, 68)
        speedCircle.ImageTransparency = on and 0 or 0.1
    end

    task.spawn(function()
        while mobileGui.Parent do
            local show = (tvlRecodeV2_spoofRunSpeedState.uiEnabled == true)
            if speedCircle.Visible ~= show then
                speedCircle.Visible = show
            end
            if show then
                -- Keep the button visual in sync with the real boost state so it still
                -- reflects toggles made via the keybind.
                local on = tvlRecodeV2_spoofRunSpeedState.boosted and true or false
                local wantColor = on and tvlRecodeV2_currentAccent or Color3.fromRGB(60, 60, 68)
                if speedStroke.Color ~= wantColor then speedStroke.Color = wantColor end
                local wantT = on and 0 or 0.1
                if speedCircle.ImageTransparency ~= wantT then speedCircle.ImageTransparency = wantT end
            end
            task.wait(0.2)
        end
    end)

    local speedPressStart, speedStartCenter, speedDragging, speedPressInput, speedPressTime

    speedCircle.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.Touch
            and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return
        end
        speedPressInput = input
        speedPressStart = input.Position
        speedPressTime = os.clock()
        speedStartCenter = speedCircle.AbsolutePosition + speedCircle.AbsoluteSize / 2
        speedDragging = false
    end)

    tvlRecodeV2_UIS.InputChanged:Connect(function(input)
        if not speedPressStart or input ~= speedPressInput then return end
        if input.UserInputType ~= Enum.UserInputType.Touch
            and input.UserInputType ~= Enum.UserInputType.MouseMovement then
            return
        end
        if os.clock() - speedPressTime < HOLD_TO_DRAG_TIME then return end
        local dx = input.Position.X - speedPressStart.X
        local dy = input.Position.Y - speedPressStart.Y
        if not speedDragging and (math.abs(dx) > DRAG_THRESHOLD or math.abs(dy) > DRAG_THRESHOLD) then
            speedDragging = true
        end
        if speedDragging then
            speedCircle.Position = UDim2.fromOffset(speedStartCenter.X + dx, speedStartCenter.Y + dy)
        end
    end)

    local function endSpeedPress(input)
        if input.UserInputType ~= Enum.UserInputType.Touch
            and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return
        end
        if not speedPressStart or input ~= speedPressInput then return end
        speedPressStart = nil
        speedPressInput = nil
        if not speedDragging then
            setSpeedActive(not tvlRecodeV2_spoofRunSpeedState.boosted)
        end
        speedDragging = false
    end
    speedCircle.InputEnded:Connect(endSpeedPress)
    tvlRecodeV2_UIS.InputEnded:Connect(endSpeedPress)

    -- On-screen Aim Lock button. Shows while Aim Lock is enabled; a tap toggles the lock
    -- onto the closest target to the middle of the screen (mobile has no cursor). A 5-second
    -- hold then drag moves it, matching the spam/speed circles.
    local lockCircle = Instance.new("ImageButton")
    lockCircle.Name = "\0"
    lockCircle.AnchorPoint = Vector2.new(0.5, 0.5)
    lockCircle.Position = UDim2.new(0.85, 0, 0.78, 0)
    lockCircle.Size = UDim2.fromOffset(70, 70)
    lockCircle.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    lockCircle.BackgroundTransparency = 0.25
    lockCircle.AutoButtonColor = false
    lockCircle.Image = GUI_ICON_IMAGE
    lockCircle.ImageTransparency = 0.1
    lockCircle.ScaleType = Enum.ScaleType.Fit
    lockCircle.Visible = false
    lockCircle.Parent = mobileGui
    local lockCorner = Instance.new("UICorner")
    lockCorner.CornerRadius = UDim.new(1, 0)
    lockCorner.Parent = lockCircle
    local lockStroke = Instance.new("UIStroke")
    lockStroke.Color = Color3.fromRGB(60, 60, 68)
    lockStroke.Thickness = 2
    lockStroke.Parent = lockCircle
    local lockText = Instance.new("TextLabel")
    lockText.Name = "\0"
    lockText.AnchorPoint = Vector2.new(0.5, 1)
    lockText.Position = UDim2.new(0.5, 0, 1, -5)
    lockText.Size = UDim2.new(1, 0, 0, 12)
    lockText.BackgroundTransparency = 1
    lockText.Text = "LOCK"
    lockText.TextColor3 = Color3.fromRGB(255, 255, 255)
    lockText.TextStrokeTransparency = 0.5
    lockText.TextSize = 10
    lockText.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    lockText.ZIndex = 2
    lockText.Parent = lockCircle

    local function setLockActive(on)
        on = on and true or false
        -- route through setActive so the RenderStep loop is bound/unbound with the lock
        if type(tvlRecodeV2_aimLockState.setActive) == "function" then
            tvlRecodeV2_aimLockState.setActive(on)
        else
            tvlRecodeV2_aimLockState.active = on
        end
        lockStroke.Color = on and tvlRecodeV2_currentAccent or Color3.fromRGB(60, 60, 68)
        lockCircle.ImageTransparency = on and 0 or 0.1
    end

    task.spawn(function()
        while mobileGui.Parent do
            local show = (tvlRecodeV2_aimLockState.enabled == true)
            if lockCircle.Visible ~= show then
                lockCircle.Visible = show
                if not show then
                    setLockActive(false)
                end
            end
            if show then
                -- keep the button visual in sync with the real lock state so it reflects
                -- toggles made via the keybind too.
                local on = tvlRecodeV2_aimLockState.active and true or false
                local wantColor = on and tvlRecodeV2_currentAccent or Color3.fromRGB(60, 60, 68)
                if lockStroke.Color ~= wantColor then lockStroke.Color = wantColor end
                local wantT = on and 0 or 0.1
                if lockCircle.ImageTransparency ~= wantT then lockCircle.ImageTransparency = wantT end
            end
            task.wait(0.2)
        end
    end)

    local lockPressStart, lockStartCenter, lockDragging, lockPressInput, lockPressTime

    lockCircle.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.Touch
            and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return
        end
        lockPressInput = input
        lockPressStart = input.Position
        lockPressTime = os.clock()
        lockStartCenter = lockCircle.AbsolutePosition + lockCircle.AbsoluteSize / 2
        lockDragging = false
    end)

    tvlRecodeV2_UIS.InputChanged:Connect(function(input)
        if not lockPressStart or input ~= lockPressInput then return end
        if input.UserInputType ~= Enum.UserInputType.Touch
            and input.UserInputType ~= Enum.UserInputType.MouseMovement then
            return
        end
        if os.clock() - lockPressTime < HOLD_TO_DRAG_TIME then return end
        local dx = input.Position.X - lockPressStart.X
        local dy = input.Position.Y - lockPressStart.Y
        if not lockDragging and (math.abs(dx) > DRAG_THRESHOLD or math.abs(dy) > DRAG_THRESHOLD) then
            lockDragging = true
        end
        if lockDragging then
            lockCircle.Position = UDim2.fromOffset(lockStartCenter.X + dx, lockStartCenter.Y + dy)
        end
    end)

    local function endLockPress(input)
        if input.UserInputType ~= Enum.UserInputType.Touch
            and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return
        end
        if not lockPressStart or input ~= lockPressInput then return end
        lockPressStart = nil
        lockPressInput = nil
        if not lockDragging then
            setLockActive(not tvlRecodeV2_aimLockState.active)
        end
        lockDragging = false
    end
    lockCircle.InputEnded:Connect(endLockPress)
    tvlRecodeV2_UIS.InputEnded:Connect(endLockPress)

    local mobileHostTab = tvlRecodeV2_Tabs.Spammer
        or tvlRecodeV2_Tabs.Main
        or tvlRecodeV2_Tabs.Private
        or tvlRecodeV2_Tabs.Vel
    if mobileHostTab then
        local mobileSection = mobileHostTab:AddSection("Mobile")
        mobileSection:AddSlider("MobileSpamButtonSize", {
            Title = "Spam Button Size",
            Icon = "solar/widget-bold",
            Min = 40,
            Max = 160,
            Default = 70,
            Rounding = 0,
            Callback = function(value)
                local px = math.clamp(math.floor(tonumber(value) or 70), 40, 160)
                spamCircle.Size = UDim2.fromOffset(px, px)
            end
        })
        mobileSection:AddSlider("MobileSpeedButtonSize", {
            Title = "Speed Button Size",
            Icon = "solar/widget-bold",
            Min = 40,
            Max = 160,
            Default = 70,
            Rounding = 0,
            Callback = function(value)
                local px = math.clamp(math.floor(tonumber(value) or 70), 40, 160)
                speedCircle.Size = UDim2.fromOffset(px, px)
            end
        })
        mobileSection:AddSlider("MobileAimLockButtonSize", {
            Title = "Aim Lock Button Size",
            Icon = "solar/widget-bold",
            Min = 40,
            Max = 160,
            Default = 70,
            Rounding = 0,
            Callback = function(value)
                local px = math.clamp(math.floor(tonumber(value) or 70), 40, 160)
                lockCircle.Size = UDim2.fromOffset(px, px)
            end
        })
        mobileSection:AddDivider()
    end
end

tvlRecodeV2_featureNotificationsReady = true

pcall(function()
    if type(tvlRecodeV2Fn_readAutoLoadSettings) ~= "function" then return end
    local autoLoadSettings = tvlRecodeV2Fn_readAutoLoadSettings()
    if autoLoadSettings and autoLoadSettings.enabled and type(autoLoadSettings.name) == "string" and autoLoadSettings.name ~= "" then
        local name = autoLoadSettings.name
        if type(readfile) == "function" then
            local ok, data = pcall(readfile, tvlRecodeV2_ConfigDir .. "/" .. name .. ".cfg")
            if ok and type(data) == "string" then
                local ok2 = pcall(function() tvlRecodeV2_Library:load_config(data) end)
                if ok2 then
                    tvlRecodeV2Fn_loadExtraConfigData(name)
                    tvlRecodeV2Fn_notifyFeature("Configs", "Auto-loaded: " .. name, "Info")
                end
            end
        end
    end
end)

