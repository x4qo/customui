local tvlRecodeV2_spoofRunSpeedState = {
    controller = nil,
    keybind = Enum.KeyCode.T,
    boosted = false,
    uiEnabled = false,
}

local function tvlRecodeV2Fn_createSpoofRunSpeedController()
    local state = {
        enabled = false,
        connections = {},
        movementData = nil,
        enhancedMovementClient = nil,
        vampireOriginal = nil,
        hereticOriginal = nil,
        originalStats = nil,
        specieType = nil,
    }

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            pcall(function() state.connections[i]:Disconnect() end)
            state.connections[i] = nil
        end
    end

    local function applyBoost(on)
        if not state.movementData or not state.enhancedMovementClient or not state.specieType or not state.originalStats then return end
        tvlRecodeV2_spoofRunSpeedState.boosted = on
        if on then
            state.movementData[state.specieType.Vampire] = {
                jumpPower = state.originalStats.jumpPower,
                walkSpeed = state.originalStats.walkSpeed,
                runAnimationSpeed = state.originalStats.runAnimationSpeed,
                fieldOfView = state.originalStats.fieldOfView,
                canDoubleJump = state.originalStats.canDoubleJump,
                canVampireRun = state.originalStats.canVampireRun,
            }
            state.movementData[state.specieType.Heretic] = {
                jumpPower = state.originalStats.jumpPower,
                walkSpeed = state.originalStats.walkSpeed,
                runAnimationSpeed = state.originalStats.runAnimationSpeed,
                fieldOfView = state.originalStats.fieldOfView,
                canDoubleJump = state.originalStats.canDoubleJump,
                canVampireRun = state.originalStats.canVampireRun,
            }
        else
            state.movementData[state.specieType.Vampire] = state.vampireOriginal
            state.movementData[state.specieType.Heretic] = state.hereticOriginal
        end
        pcall(function() state.enhancedMovementClient.setState(true, true) end)
    end

    local function connect()
        if state.enabled then return true end

        local Players = game:GetService("Players")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local localPlayer = Players.LocalPlayer
        local playerScripts = localPlayer and localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local emcModule = moduleScripts and moduleScripts:WaitForChild("EnhancedMovementClient", 5)
        if not emcModule then return false, "EnhancedMovementClient unavailable" end

        local okEmc, emc = pcall(require, emcModule)
        if not okEmc or not emc then return false, "EnhancedMovementClient require failed" end

        local rsModules = ReplicatedStorage:FindFirstChild("ModuleScripts")
        local dataFolder = rsModules and rsModules:FindFirstChild("Data")
        local mdModule = dataFolder and dataFolder:FindFirstChild("MovementData")
        if not mdModule then return false, "MovementData unavailable" end

        local okMd, md = pcall(require, mdModule)
        if not okMd or not md then return false, "MovementData require failed" end

        local stEnums = rsModules and rsModules:FindFirstChild("Enums")
        local stModule = stEnums and stEnums:FindFirstChild("SpecieType")
        if not stModule then return false, "SpecieType unavailable" end

        local okSt, st = pcall(require, stModule)
        if not okSt or not st then return false, "SpecieType require failed" end

        state.enhancedMovementClient = emc
        state.movementData = md
        state.specieType = st

        local orig = md[st.Original]
        state.originalStats = {
            jumpPower = orig.jumpPower,
            walkSpeed = orig.walkSpeed,
            runAnimationSpeed = orig.runAnimationSpeed,
            fieldOfView = orig.fieldOfView,
            canDoubleJump = orig.canDoubleJump,
            canVampireRun = orig.canVampireRun,
        }

        local vamp = md[st.Vampire]
        state.vampireOriginal = {
            jumpPower = vamp.jumpPower,
            walkSpeed = vamp.walkSpeed,
            runAnimationSpeed = vamp.runAnimationSpeed,
            fieldOfView = vamp.fieldOfView,
            canDoubleJump = vamp.canDoubleJump,
            canVampireRun = vamp.canVampireRun,
        }

        local her = md[st.Heretic]
        state.hereticOriginal = {
            jumpPower = her.jumpPower,
            walkSpeed = her.walkSpeed,
            runAnimationSpeed = her.runAnimationSpeed,
            fieldOfView = her.fieldOfView,
            canDoubleJump = her.canDoubleJump,
            canVampireRun = her.canVampireRun,
        }

        state.enabled = true

        addConnection(game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode == tvlRecodeV2_spoofRunSpeedState.keybind then
                applyBoost(not tvlRecodeV2_spoofRunSpeedState.boosted)
            end
        end))

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                disconnectAll()
                return false, err
            end
            return true
        end

        if tvlRecodeV2_spoofRunSpeedState.boosted then
            applyBoost(false)
        end
        state.enabled = false
        state.movementData = nil
        state.enhancedMovementClient = nil
        state.vampireOriginal = nil
        state.hereticOriginal = nil
        state.originalStats = nil
        state.specieType = nil
        disconnectAll()
        return true
    end

    -- Public active-state control (used by the keybind and the mobile button).
    -- applyBoost guards itself when the feature isn't connected, so this is a safe no-op then.
    function controller:setActive(value)
        applyBoost(value == true)
    end

    function controller:toggle()
        applyBoost(not tvlRecodeV2_spoofRunSpeedState.boosted)
    end

    return controller
end

local function tvlRecodeV2Fn_getSpoofRunSpeedController()
    if not tvlRecodeV2_spoofRunSpeedState.controller then
        tvlRecodeV2_spoofRunSpeedState.controller = tvlRecodeV2Fn_createSpoofRunSpeedController()
    end
    return tvlRecodeV2_spoofRunSpeedState.controller
end

