local function tvlRecodeV2Fn_createAntiStunController()
    local state = {
        enabled = false,
        hooksInstalled = false,
        connections = {},
        playerState = nil,
        controls = nil,
        realApplyStun = nil,
        realDisable = nil,
    }

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            pcall(function() state.connections[i]:Disconnect() end)
            state.connections[i] = nil
        end
    end

    local function connect()
        if state.enabled then return true end

        local Players = game:GetService("Players")
        local localPlayer = Players.LocalPlayer
        local playerScripts = localPlayer and localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local psModule = moduleScripts and moduleScripts:WaitForChild("PlayerState", 5)
        if not psModule then return false, "PlayerState unavailable" end

        local okPs, playerState = pcall(require, psModule)
        if not okPs or not playerState then return false, "PlayerState require failed" end

        local pmModule = playerScripts and playerScripts:WaitForChild("PlayerModule", 5)
        if not pmModule then return false, "PlayerModule unavailable" end

        local okPm, playerModule = pcall(require, pmModule)
        if not okPm or not playerModule then return false, "PlayerModule require failed" end

        local okCtrls, controls = pcall(function() return playerModule:GetControls() end)
        if not okCtrls or not controls then return false, "GetControls failed" end

        -- Install the stun hooks only once. They stay installed and simply pass
        -- through when the feature is inactive, which avoids the risks of
        -- restoring/re-wrapping the module functions on every toggle.
        if not state.hooksInstalled then
            state.playerState = playerState
            state.controls = controls
            state.realApplyStun = playerState.applyStun
            state.realDisable = controls.Disable

            playerState.applyStun = function(selfObj, p29, p30)
                if tvlRecodeV2_antiStunState.active then
                    return state.realApplyStun(selfObj, false, false)
                end
                return state.realApplyStun(selfObj, p29, p30)
            end

            controls.Disable = function(...)
                if tvlRecodeV2_antiStunState.active then return end
                return state.realDisable(...)
            end

            state.hooksInstalled = true
        end

        state.enabled = true

        addConnection(game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode == tvlRecodeV2_antiStunState.keybind then
                tvlRecodeV2_antiStunState.active = not tvlRecodeV2_antiStunState.active
                tvlRecodeV2Fn_notifyFeature("Anti Stun", tvlRecodeV2_antiStunState.active and "On" or "Off", "Info")
            end
        end))

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                disconnectAll()
                return false, err
            end
            return true
        end

        tvlRecodeV2_antiStunState.active = false
        state.enabled = false
        disconnectAll()
        return true
    end

    return controller
end

function tvlRecodeV2Fn_getAntiStunController()
    if not tvlRecodeV2_antiStunState.controller then
        tvlRecodeV2_antiStunState.controller = tvlRecodeV2Fn_createAntiStunController()
    end
    return tvlRecodeV2_antiStunState.controller
end

