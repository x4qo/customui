local function tvlRecodeV2Fn_makeSiphonColorController()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local state = {
        enabled = false,
        color = Color3.fromRGB(39, 76, 177),
        connections = {},
        originals = {},
        localPlayer = nil,
        character = nil,
        particles = nil,
    }

    local controller = {}

    local function recordOriginal(inst, value)
        if state.originals[inst] == nil then
            state.originals[inst] = value
        end
    end

    local function applyToParticle(inst)
        if inst:IsA("ParticleEmitter") or inst:IsA("Beam") then
            recordOriginal(inst, inst.Color)
            inst.Color = ColorSequence.new(state.color)
        elseif inst:IsA("PointLight") then
            recordOriginal(inst, inst.Color)
            inst.Color = state.color
        end
    end

    local function applyToDescendants(root)
        if not root then return end
        for _, descendant in ipairs(root:GetDescendants()) do
            applyToParticle(descendant)
        end
    end

    local function applyAll()
        if not state.enabled or not state.particles then return end

        local function attachmentOf(name)
            local folder = state.particles:FindFirstChild(name)
            return folder and folder:FindFirstChild("Attachment")
        end

        applyToDescendants(attachmentOf("MagicSiphon"))
        applyToDescendants(attachmentOf("BarrierSiphon"))
        applyToDescendants(attachmentOf("HeadSiphon"))
        applyToDescendants(attachmentOf("HeadSiphonBarrier"))

        local siphonableObject = state.particles:FindFirstChild("SiphonableObject")
        if siphonableObject then
            for _, child in ipairs(siphonableObject:GetChildren()) do
                applyToDescendants(child)
            end
        end

        local character = state.character or (state.localPlayer and state.localPlayer.Character)
        local rightHand = character and character:FindFirstChild("RightHand")
        local siphonParticle = rightHand and rightHand:FindFirstChild("SiphonParticle")
        if siphonParticle then
            applyToDescendants(siphonParticle)
        end
    end

    local function restoreAll()
        for inst, value in pairs(state.originals) do
            pcall(function()
                if inst and inst.Parent ~= nil then
                    inst.Color = value
                end
            end)
        end
        table.clear(state.originals)
    end

    function controller:setColor(color3)
        if typeof(color3) ~= "Color3" then return false end
        state.color = color3
        applyAll()
        return true
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end
        if enable then
            local ok = pcall(function()
                state.localPlayer = Players.LocalPlayer or Players.PlayerAdded:Wait()
                state.character = state.localPlayer.Character
                state.particles = ReplicatedStorage:WaitForChild("Assets"):WaitForChild("Particles")
            end)
            if not ok or not state.particles then
                return false, "Could not resolve siphon particles"
            end
            state.enabled = true
            applyAll()

            state.connections[#state.connections + 1] = state.localPlayer.CharacterAdded:Connect(function(newCharacter)
                state.character = newCharacter
                task.wait(0.1)
                applyAll()
            end)
            state.connections[#state.connections + 1] = state.particles.Changed:Connect(function()
                applyAll()
            end)
            return true
        end

        state.enabled = false
        for _, conn in ipairs(state.connections) do
            pcall(function() conn:Disconnect() end)
        end
        table.clear(state.connections)
        restoreAll()
        return true
    end

    return controller
end

