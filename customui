local function tvlRecodeV2Fn_normalizeHwid(value)
    return tostring(value or "")
        :gsub("[\226\128\139-\226\128\141\239\187\191]", "")
        :gsub("%s+", "")
        :lower()
end

local function tvlRecodeV2Fn_getRequestFunction()
    return request
end

local function tvlRecodeV2Fn_requestText(url)
    local requestFunc = tvlRecodeV2Fn_getRequestFunction()
    if type(requestFunc) ~= "function" then
        return ""
    end

    local ok, response = pcall(function()
        return requestFunc({
            Url = tostring(url),
            Method = "GET",
            Headers = { ["User-Agent"] = "MyHub" },
        })
    end)

    if not ok then
        return ""
    end

    local body = type(response) == "table" and response.Body or response
    local statusCode = type(response) == "table" and tonumber(response.StatusCode or response.status_code or response.Status) or 200
    if statusCode and (statusCode < 200 or statusCode >= 300) then
        return ""
    end
    if type(body) ~= "string" then
        return ""
    end

    return body
end

local function tvlRecodeV2Fn_stringifyHwid(value, seen)
    local valueType = type(value)
    if valueType == "string" or valueType == "number" then
        local text = tostring(value)
        if text == "" or text:match("^table:%s*0x") then
            return nil
        end
        return text
    end

    if valueType == "table" then
        seen = seen or {}
        if seen[value] then
            return nil
        end
        seen[value] = true

        for _, key in ipairs({
            "hwid", "HWID",
            "fingerprint", "Fingerprint",
            "identifier", "Identifier",
            "clientId", "ClientId",
            "id", "Id",
            "value", "Value",
        }) do
            local text = tvlRecodeV2Fn_stringifyHwid(value[key], seen)
            if text then
                return text
            end
        end

        for _, item in pairs(value) do
            local text = tvlRecodeV2Fn_stringifyHwid(item, seen)
            if text then
                return text
            end
        end

        return nil
    end

    local text = tostring(value or "")
    if text == "" or text:match("^table:%s*0x") then
        return nil
    end
    return text
end

local function tvlRecodeV2Fn_getDirectHwid()
    local injected = tvlRecodeV2Fn_stringifyHwid(__VELS_CANONICAL_HWID)
    injected = injected and tvlRecodeV2Fn_normalizeHwid(injected) or nil
    if injected and injected ~= "" then
        return injected
    end

    if gethwid then
        local ok, id = pcall(gethwid)
        id = ok and tvlRecodeV2Fn_stringifyHwid(id) or nil
        if id then
            return tvlRecodeV2Fn_normalizeHwid(id)
        end
    end

    if syn and syn.fingerprint then
        local ok, id = pcall(syn.fingerprint)
        id = ok and tvlRecodeV2Fn_stringifyHwid(id) or nil
        if id then
            return tvlRecodeV2Fn_normalizeHwid(id)
        end
    end

    if getexecutoridentifier then
        local ok, id = pcall(getexecutoridentifier)
        id = ok and tvlRecodeV2Fn_stringifyHwid(id) or nil
        if id then
            return tvlRecodeV2Fn_normalizeHwid(id)
        end
    end

    local ok, id = pcall(function()
        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    id = ok and tvlRecodeV2Fn_stringifyHwid(id) or nil
    if id then
        return tvlRecodeV2Fn_normalizeHwid(id)
    end

    return ""
end

local function tvlRecodeV2Fn_getExecutorLabel()
    if type(identifyexecutor) == "function" then
        local ok, name, version = pcall(identifyexecutor)
        if ok and name then
            if version then
                return tostring(name) .. " " .. tostring(version)
            end
            return tostring(name)
        end
    end

    if type(getexecutorname) == "function" then
        local ok, name = pcall(getexecutorname)
        if ok and name then
            return tostring(name)
        end
    end

    return "Unknown"
end

