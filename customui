local function tvlRecodeV2Fn_setPlantEspType(plantType, enabled)
    tvlRecodeV2_plantEspState.selectedTypes[plantType] = enabled

    for plant, entry in pairs(tvlRecodeV2_plantEspState.plantEsp) do
        if entry.plantType == plantType and not enabled and tvlRecodeV2_plantEspState.destroyPlantMarker then
            tvlRecodeV2_plantEspState.destroyPlantMarker(plant)
        end
    end

    if enabled and tvlRecodeV2_plantEspState.active and tvlRecodeV2_plantEspState.scanPlants then
        pcall(tvlRecodeV2_plantEspState.scanPlants)
    end
end

local function tvlRecodeV2Fn_startPlantEsp()
    if tvlRecodeV2_plantEspState.active then
        return
    end

    if not tvlRecodeV2_plantEspState.loaded then
        local mRunService = game:GetService("RunService")
        local mWorkspace = game:GetService("Workspace")
        local mPlayers = game:GetService("Players")

        tvlRecodeV2_plantEspState.runService = mRunService
        tvlRecodeV2_plantEspState.workspace = mWorkspace
        tvlRecodeV2_plantEspState.players = mPlayers
        tvlRecodeV2_plantEspState.localPlayer = mPlayers.LocalPlayer or mPlayers.PlayerAdded:Wait()
        tvlRecodeV2_plantEspState.loaded = true
    end

    tvlRecodeV2_plantEspState.active = true

    local mRunService = tvlRecodeV2_plantEspState.runService
    local mWorkspace = tvlRecodeV2_plantEspState.workspace
    local mLocalPlayer = tvlRecodeV2_plantEspState.localPlayer

    local MAX_DISTANCE = 3000
    local SCAN_INTERVAL = 10
    local DISTANCE_INTERVAL = 0.12

    local mPlantTypes = {
        "ArcanithPlant", "YarrowPlant", "PerenniaPlant", "DerridaPlant",
        "Sanguinia", "NightshadePlant", "MooncapPlant", "WolfsbanePlant",
    }

    local mPlantColors = {
        ArcanithPlant = Color3.fromRGB(138, 43, 226),
        YarrowPlant = Color3.fromRGB(0, 255, 127),
        PerenniaPlant = Color3.fromRGB(144, 238, 144),
        DerridaPlant = Color3.fromRGB(255, 215, 0),
        Sanguinia = Color3.fromRGB(30, 144, 255),
        NightshadePlant = Color3.fromRGB(186, 85, 211),
        MooncapPlant = Color3.fromRGB(176, 176, 196),
        WolfsbanePlant = Color3.fromRGB(123, 104, 238),
    }

    local function tvlRecodeV2Fn_tvlGetPlayerRoot()
        local char = mLocalPlayer and mLocalPlayer.Character
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function tvlRecodeV2Fn_tvlFindPlantsFolder()
        local interactables = mWorkspace:FindFirstChild("Interactables")
        return interactables and interactables:FindFirstChild("Plants")
    end

    local function tvlRecodeV2Fn_tvlDestroyPlantMarker(plant)
        local entry = tvlRecodeV2_plantEspState.plantEsp[plant]
        if not entry then return end
        tvlRecodeV2_plantEspState.plantEsp[plant] = nil
        if entry.connection then entry.connection:Disconnect() end
        if entry.gui and entry.gui.Parent then entry.gui:Destroy() end
    end
    tvlRecodeV2_plantEspState.destroyPlantMarker = tvlRecodeV2Fn_tvlDestroyPlantMarker

    local function tvlRecodeV2Fn_tvlCreatePlantMarker(plant, plantType)
        if not tvlRecodeV2_plantEspState.active or not tvlRecodeV2_plantEspState.selectedTypes[plantType] or not plant or not plant.Parent or tvlRecodeV2_plantEspState.plantEsp[plant] then return end

        local adornee
        if plant:IsA("BasePart") then
            adornee = plant
        elseif plant:IsA("Model") then
            adornee = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart")
        end
        if not adornee then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "TVLPlantESP"
        gui.Size = UDim2.new(0, 113, 0, 40)
        gui.Adornee = adornee
        gui.AlwaysOnTop = true
        gui.StudsOffset = Vector3.new(0, 3, 0)
        gui.MaxDistance = MAX_DISTANCE
        gui.Parent = tvlRecodeV2_GuiParent

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        nameLabel.Position = UDim2.new(0, 0, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextStrokeTransparency = 0.5
        nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameLabel.TextColor3 = mPlantColors[plantType] or Color3.fromRGB(255, 255, 255)
        nameLabel.TextSize = 11
        nameLabel.Font = Enum.Font.GothamMedium
        nameLabel.Text = plantType
        nameLabel.Parent = gui

        local distLabel = Instance.new("TextLabel")
        distLabel.Name = "DistLabel"
        distLabel.Size = UDim2.new(1, 0, 0.5, 0)
        distLabel.Position = UDim2.new(0, 0, 0.5, 0)
        distLabel.BackgroundTransparency = 1
        distLabel.TextStrokeTransparency = 0.5
        distLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
        distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        distLabel.TextSize = 10
        distLabel.Font = Enum.Font.GothamMedium
        distLabel.Text = ""
        distLabel.Parent = gui

        local entry = { gui = gui, plantType = plantType }
        tvlRecodeV2_plantEspState.plantEsp[plant] = entry
        entry.connection = plant.AncestryChanged:Connect(function(_, parent)
            if not parent then tvlRecodeV2Fn_tvlDestroyPlantMarker(plant) end
        end)
    end

    local function tvlRecodeV2Fn_tvlScanPlants()
        for plant, entry in pairs(tvlRecodeV2_plantEspState.plantEsp) do
            if not plant or not plant.Parent or not tvlRecodeV2_plantEspState.selectedTypes[entry.plantType] then
                tvlRecodeV2Fn_tvlDestroyPlantMarker(plant)
            end
        end

        local plantsFolder = tvlRecodeV2Fn_tvlFindPlantsFolder()
        if not plantsFolder then return end

        for _, obj in ipairs(plantsFolder:GetDescendants()) do
            for _, plantType in ipairs(mPlantTypes) do
                if obj.Name == plantType and tvlRecodeV2_plantEspState.selectedTypes[plantType] then
                    tvlRecodeV2Fn_tvlCreatePlantMarker(obj, plantType)
                    break
                end
            end
        end
    end
    tvlRecodeV2_plantEspState.scanPlants = tvlRecodeV2Fn_tvlScanPlants

    local function tvlRecodeV2Fn_tvlStartDistanceUpdater()
        if tvlRecodeV2_plantEspState.distanceConn then return end
        tvlRecodeV2_plantEspState.lastDistanceUpdate = 0
        tvlRecodeV2_plantEspState.distanceConn = mRunService.Heartbeat:Connect(function()
            if not tvlRecodeV2_plantEspState.active then return end

            local now = os.clock()
            if now - tvlRecodeV2_plantEspState.lastDistanceUpdate < DISTANCE_INTERVAL then return end
            tvlRecodeV2_plantEspState.lastDistanceUpdate = now

            local root = tvlRecodeV2Fn_tvlGetPlayerRoot()
            if not root then return end

            for plant, entry in pairs(tvlRecodeV2_plantEspState.plantEsp) do
                local gui = entry and entry.gui
                if not plant or not plant.Parent or not gui or not gui.Parent then
                    tvlRecodeV2Fn_tvlDestroyPlantMarker(plant)
                else
                    local adornee = gui.Adornee
                    if adornee and adornee.Parent then
                        local distLabel = gui:FindFirstChild("DistLabel")
                        if distLabel then
                            local text = tostring(math.floor((root.Position - adornee.Position).Magnitude)) .. " studs"
                            if distLabel.Text ~= text then distLabel.Text = text end
                        end
                    else
                        tvlRecodeV2Fn_tvlDestroyPlantMarker(plant)
                    end
                end
            end
        end)
    end

    local function tvlRecodeV2Fn_tvlStartScanLoop()
        if tvlRecodeV2_plantEspState.scanThread then return end
        tvlRecodeV2_plantEspState.scanRunId += 1
        local runId = tvlRecodeV2_plantEspState.scanRunId

        tvlRecodeV2_plantEspState.scanThread = task.spawn(function()
            while tvlRecodeV2_plantEspState.active and tvlRecodeV2_plantEspState.scanRunId == runId do
                task.wait(SCAN_INTERVAL)
                if tvlRecodeV2_plantEspState.active and tvlRecodeV2_plantEspState.scanRunId == runId then
                    pcall(tvlRecodeV2Fn_tvlScanPlants)
                end
            end

            if tvlRecodeV2_plantEspState.scanRunId == runId then
                tvlRecodeV2_plantEspState.scanThread = nil
            end
        end)
    end

    local function tvlRecodeV2Fn_tvlAttachFolderListeners(plantsFolder)
        if tvlRecodeV2_plantEspState.descendantAddedConn then tvlRecodeV2_plantEspState.descendantAddedConn:Disconnect() end
        if tvlRecodeV2_plantEspState.descendantRemovingConn then tvlRecodeV2_plantEspState.descendantRemovingConn:Disconnect() end

        tvlRecodeV2_plantEspState.descendantAddedConn = plantsFolder.DescendantAdded:Connect(function(obj)
            task.defer(function()
                if not tvlRecodeV2_plantEspState.active then return end
                for _, plantType in ipairs(mPlantTypes) do
                    if obj.Name == plantType and tvlRecodeV2_plantEspState.selectedTypes[plantType] then
                        tvlRecodeV2Fn_tvlCreatePlantMarker(obj, plantType)
                        break
                    end
                end
            end)
        end)

        tvlRecodeV2_plantEspState.descendantRemovingConn = plantsFolder.DescendantRemoving:Connect(function(obj)
            if tvlRecodeV2_plantEspState.plantEsp[obj] then tvlRecodeV2Fn_tvlDestroyPlantMarker(obj) end
        end)
    end

    local function tvlRecodeV2Fn_tvlInitStreamingListeners()
        local plantsFolder = tvlRecodeV2Fn_tvlFindPlantsFolder()
        if plantsFolder then
            tvlRecodeV2Fn_tvlAttachFolderListeners(plantsFolder)
            return
        end

        local interactables = mWorkspace:FindFirstChild("Interactables")
        if interactables then
            tvlRecodeV2_plantEspState.plantsWatcher = interactables.ChildAdded:Connect(function(child)
                if child.Name == "Plants" then
                    if tvlRecodeV2_plantEspState.plantsWatcher then tvlRecodeV2_plantEspState.plantsWatcher:Disconnect() tvlRecodeV2_plantEspState.plantsWatcher = nil end
                    tvlRecodeV2Fn_tvlAttachFolderListeners(child)
                    pcall(tvlRecodeV2Fn_tvlScanPlants)
                end
            end)
        else
            tvlRecodeV2_plantEspState.interactablesWatcher = mWorkspace.ChildAdded:Connect(function(child)
                if child.Name ~= "Interactables" then return end
                if tvlRecodeV2_plantEspState.interactablesWatcher then tvlRecodeV2_plantEspState.interactablesWatcher:Disconnect() tvlRecodeV2_plantEspState.interactablesWatcher = nil end
                local plants = child:FindFirstChild("Plants")
                if plants then
                    tvlRecodeV2Fn_tvlAttachFolderListeners(plants)
                    pcall(tvlRecodeV2Fn_tvlScanPlants)
                else
                    tvlRecodeV2_plantEspState.plantsWatcher = child.ChildAdded:Connect(function(subChild)
                        if subChild.Name == "Plants" then
                            if tvlRecodeV2_plantEspState.plantsWatcher then tvlRecodeV2_plantEspState.plantsWatcher:Disconnect() tvlRecodeV2_plantEspState.plantsWatcher = nil end
                            tvlRecodeV2Fn_tvlAttachFolderListeners(subChild)
                            pcall(tvlRecodeV2Fn_tvlScanPlants)
                        end
                    end)
                end
            end)
        end
    end

    tvlRecodeV2Fn_tvlScanPlants()
    tvlRecodeV2Fn_tvlStartDistanceUpdater()
    tvlRecodeV2Fn_tvlStartScanLoop()
    tvlRecodeV2Fn_tvlInitStreamingListeners()
end

local function tvlRecodeV2Fn_stopCompleteBodyJump()
    tvlRecodeV2_bodyJumpState.runId += 1
    tvlRecodeV2_bodyJumpState.thread = nil
end

local function tvlRecodeV2Fn_startCompleteBodyJump()
    if tvlRecodeV2_bodyJumpState.thread then
        return
    end

    if not tvlRecodeV2_bodyJumpState.loaded then
        local mPlayers = game:GetService("Players")
        local mVirtualInputManager = game:GetService("VirtualInputManager")

        tvlRecodeV2_bodyJumpState.players = mPlayers
        tvlRecodeV2_bodyJumpState.virtualInputManager = mVirtualInputManager
        tvlRecodeV2_bodyJumpState.localPlayer = mPlayers.LocalPlayer or mPlayers.PlayerAdded:Wait()
        tvlRecodeV2_bodyJumpState.loaded = true
    end

    local mPlayers = tvlRecodeV2_bodyJumpState.players
    local mVirtualInputManager = tvlRecodeV2_bodyJumpState.virtualInputManager
    local mLocalPlayer = tvlRecodeV2_bodyJumpState.localPlayer

    local function tvlRecodeV2Fn_bodyJumpResolvePlayerGui(timeout)
        local className = string.char(80, 108, 97, 121, 101, 114, 71, 117, 105)
        local player = mLocalPlayer or mPlayers.LocalPlayer
        if not player then return nil end
        local container = player:FindFirstChildOfClass(className) or player:FindFirstChild(className)
        if container then return container end
        return player:WaitForChild(className, timeout)
    end

    tvlRecodeV2_bodyJumpState.runId += 1
    local runId = tvlRecodeV2_bodyJumpState.runId

    tvlRecodeV2_bodyJumpState.thread = task.spawn(function()
        pcall(function()
            local gui = tvlRecodeV2Fn_bodyJumpResolvePlayerGui(10)
            if not gui then return end

            local screenUtils = gui:WaitForChild("ScreenUtils")

            while tvlRecodeV2_bodyJumpState.runId == runId do
                task.wait(math.random(16, 40) / 1000)
                if tvlRecodeV2_bodyJumpState.runId ~= runId then break end

                for _, child in screenUtils:GetChildren() do
                    local fired = false
                    for _, desc in child:GetDescendants() do
                        if tvlRecodeV2_bodyJumpState.runId ~= runId then break end
                        if desc:IsA("TextLabel") and desc.Text == "Clashing..." then
                            mVirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                            task.wait(math.random(16, 40) / 1000)
                            mVirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                            fired = true
                            break
                        end
                    end
                    if fired then break end
                end
            end
        end)

        if tvlRecodeV2_bodyJumpState.runId == runId then
            tvlRecodeV2_bodyJumpState.thread = nil
        end
    end)
end

local function tvlRecodeV2Fn_stopAimAssist()
