                local title_shine_seq = nil
                local title_white = rgb(255, 255, 255)

                -- static "shine band": accent everywhere with a soft white highlight
                -- centred at 0.5. Rebuilt only when the accent colour changes.
                local function title_build_shine(c)
                    local hi  = c:Lerp(title_white, 0.6)
                    local mid = c:Lerp(title_white, 0.22)
                    return rgbseq({
                        rgbkey(0.00, c),
                        rgbkey(0.32, c),
                        rgbkey(0.42, mid),
                        rgbkey(0.50, hi),
                        rgbkey(0.58, mid),
                        rgbkey(0.68, c),
                        rgbkey(1.00, c),
                    })
                end

                local function animate_title(grad)
                    insert(title_gradients, grad)
                    -- match the current shine immediately so a late-registered
                    -- gradient never flashes its previous colour
                    if title_shine_seq then grad.Color = title_shine_seq end
                    if title_driver_started then return end
                    title_driver_started = true

                    -- The old driver rewrote every gradient's .Color every frame,
                    -- which re-tessellates the text on each change. Now the colour is
                    -- a STATIC band (rebuilt only on accent change) and we just slide
                    -- UIGradient.Offset.X each frame: the same sweeping highlight, but
                    -- Offset writes never touch the text geometry, so it is basically
                    -- free. Offset clamps (no wrap), so we sweep from fully off the
                    -- left edge to fully off the right edge and reset while invisible.
                local SPEED = 0.4
                local cur_accent = nil
                local function title_gradient_visible(grad)
                    local node = grad and grad.Parent
                    while node do
                        if node:IsA("GuiObject") and not node.Visible then
                            return false
