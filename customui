-- Config save / load. Every element built through the UI registers into the library's
-- config_flags, so a saved config captures all toggles, sliders, dropdowns, keybinds and
-- colours. Files live in <directory>/configs/*.cfg (folder auto-created by the library).
local tvlRecodeV2_ConfigHttpService = game:GetService("HttpService")
local tvlRecodeV2_ConfigDir = (tvlRecodeV2_Library.directory or "milenium") .. "/configs"
local tvlRecodeV2_AutoLoadPath = tvlRecodeV2_ConfigDir .. "/autoload.json"

local function tvlRecodeV2Fn_extraConfigPath(name)
    return tvlRecodeV2_ConfigDir .. "/" .. name .. ".extra.json"
end

local function tvlRecodeV2Fn_collectExtraConfigData()
    local keybinds = {}
    for flag, entry in pairs(tvlRecodeV2_KeybindConfigRegistry) do
        keybinds[flag] = entry.get()
    end
    local colors = {}
    for flag, entry in pairs(tvlRecodeV2_ColorConfigRegistry) do
        colors[flag] = entry.get()
    end
    return { keybinds = keybinds, colors = colors }
end

local function tvlRecodeV2Fn_applyExtraConfigData(decoded)
    if type(decoded) ~= "table" then return end
    if type(decoded.keybinds) == "table" then
        for flag, value in pairs(decoded.keybinds) do
            local entry = tvlRecodeV2_KeybindConfigRegistry[flag]
            if entry then entry.set(value) end
        end
    end
    if type(decoded.colors) == "table" then
        for flag, value in pairs(decoded.colors) do
            local entry = tvlRecodeV2_ColorConfigRegistry[flag]
            if entry then entry.set(value) end
        end
    end
end

local function tvlRecodeV2Fn_saveExtraConfigData(name)
    if type(writefile) ~= "function" then return end
    pcall(function()
        writefile(tvlRecodeV2Fn_extraConfigPath(name), tvlRecodeV2_ConfigHttpService:JSONEncode(tvlRecodeV2Fn_collectExtraConfigData()))
    end)
end

local function tvlRecodeV2Fn_loadExtraConfigData(name)
    if type(readfile) ~= "function" then return end
    local ok, data = pcall(readfile, tvlRecodeV2Fn_extraConfigPath(name))
    if not ok or type(data) ~= "string" then return end
    local decodeOk, decoded = pcall(function() return tvlRecodeV2_ConfigHttpService:JSONDecode(data) end)
    if decodeOk then
        tvlRecodeV2Fn_applyExtraConfigData(decoded)
    end
end

local function tvlRecodeV2Fn_readAutoLoadSettings()
    if type(readfile) ~= "function" then return nil end
    local ok, data = pcall(readfile, tvlRecodeV2_AutoLoadPath)
    if not ok or type(data) ~= "string" then return nil end
    local decodeOk, decoded = pcall(function() return tvlRecodeV2_ConfigHttpService:JSONDecode(data) end)
    if not decodeOk or type(decoded) ~= "table" then return nil end
    return decoded
end

local function tvlRecodeV2Fn_writeAutoLoadSettings(settings)
    if type(writefile) ~= "function" then return end
    pcall(function()
        writefile(tvlRecodeV2_AutoLoadPath, tvlRecodeV2_ConfigHttpService:JSONEncode(settings))
    end)
end

do
    local tvlRecodeV2_ConfigSection = tvlRecodeV2_Tabs.Themes:AddSection("Configs", "right")
    local tvlRecodeV2_ConfigNative = tvlRecodeV2_ConfigSection._section
    local tvlRecodeV2_configListEl

    local function tvlRecodeV2Fn_listConfigNames()
        local names = {}
        if type(listfiles) == "function" then
            pcall(function()
                for _, file in ipairs(listfiles(tvlRecodeV2_ConfigDir)) do
                    local name = tostring(file):match("([^/\\]+)%.cfg$")
                    if name then names[#names + 1] = name end
                end
            end)
        end
        return names
    end

    local function tvlRecodeV2Fn_refreshConfigList()
        if tvlRecodeV2_configListEl and type(tvlRecodeV2_configListEl.refresh_options) == "function" then
            pcall(function() tvlRecodeV2_configListEl.refresh_options(tvlRecodeV2Fn_listConfigNames()) end)
        end
    end

    -- preferTyped: Save uses the typed name first; Load/Delete use the picked list item first.
    local function tvlRecodeV2Fn_configName(preferTyped)
        local f = tvlRecodeV2_Library.flags or {}
        local typed  = tostring(f["config_name_text"] or "")
        local picked = tostring(f["config_name_list"] or "")
        local name
        if preferTyped then
            name = (typed ~= "" and typed) or picked
        else
            name = (picked ~= "" and picked) or typed
        end
        return (name:gsub("^%s+", ""):gsub("%s+$", ""):gsub("[^%w%-_ ]", ""))
    end

    tvlRecodeV2_ConfigNative:textbox({ name = "Config name", flag = "config_name_text" })

    tvlRecodeV2_configListEl = tvlRecodeV2_ConfigNative:list({
        options = tvlRecodeV2Fn_listConfigNames(),
        flag = "config_name_list",
        callback = function() end,
    })

    tvlRecodeV2_ConfigNative:button({
        name = "Save",
        callback = function()
            local name = tvlRecodeV2Fn_configName(true)
            if name == "" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Type a config name first", "Error")
                return
            end
            if type(writefile) ~= "function" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Executor has no writefile", "Error")
                return
            end
            local ok, err = pcall(function()
                writefile(tvlRecodeV2_ConfigDir .. "/" .. name .. ".cfg", tvlRecodeV2_Library:get_config())
            end)
            if ok then
                tvlRecodeV2Fn_saveExtraConfigData(name)
                tvlRecodeV2Fn_refreshConfigList()
                tvlRecodeV2Fn_notifyFeature("Configs", "Saved: " .. name, "Info")
            else
                tvlRecodeV2Fn_notifyFeature("Configs", "Save failed: " .. tostring(err), "Error")
            end
        end,
    })

    tvlRecodeV2_ConfigNative:button({
        name = "Load",
        callback = function()
            local name = tvlRecodeV2Fn_configName(false)
            if name == "" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Pick or type a config first", "Error")
                return
            end
            if type(readfile) ~= "function" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Executor has no readfile", "Error")
                return
            end
            local ok, data = pcall(readfile, tvlRecodeV2_ConfigDir .. "/" .. name .. ".cfg")
            if not ok or type(data) ~= "string" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Config not found: " .. name, "Error")
                return
            end
            local ok2, err = pcall(function() tvlRecodeV2_Library:load_config(data) end)
            if ok2 then
                tvlRecodeV2Fn_loadExtraConfigData(name)
                tvlRecodeV2Fn_notifyFeature("Configs", "Loaded: " .. name, "Info")
            else
                tvlRecodeV2Fn_notifyFeature("Configs", "Load failed: " .. tostring(err), "Error")
            end
        end,
    })

    tvlRecodeV2_ConfigNative:button({
        name = "Delete",
        callback = function()
            local name = tvlRecodeV2Fn_configName(false)
            if name == "" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Pick a config to delete", "Error")
                return
            end
            if type(delfile) == "function" then
                pcall(function() delfile(tvlRecodeV2_ConfigDir .. "/" .. name .. ".cfg") end)
                pcall(function() delfile(tvlRecodeV2Fn_extraConfigPath(name)) end)
            end
            tvlRecodeV2Fn_refreshConfigList()
            tvlRecodeV2Fn_notifyFeature("Configs", "Deleted: " .. name, "Info")
        end,
    })

    tvlRecodeV2_ConfigNative:button({
        name = "Refresh List",
        callback = tvlRecodeV2Fn_refreshConfigList,
    })

    tvlRecodeV2_ConfigNative:toggle({
        name = "Auto Load Config",
        flag = "config_auto_load",
        type = "toggle",
        default = false,
        callback = function(enabled)
            local name = tvlRecodeV2Fn_configName(true)
            if enabled and name == "" then
                tvlRecodeV2Fn_notifyFeature("Configs", "Type or pick a config name first", "Error")
                return
            end
            tvlRecodeV2Fn_writeAutoLoadSettings({ enabled = enabled == true, name = name })
            tvlRecodeV2Fn_notifyFeature("Configs", enabled and ("Auto Load enabled: " .. name) or "Auto Load disabled")
        end,
    })
end

