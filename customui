local function tvlRecodeV2Fn_createCanBeAffectedController()
    local state = {
        enabled = false,
        abilityHandler = nil,
        originalCanBeAffected = nil,
        hadOriginal = false,
    }

    local function getAbilityHandler()
        local Players = game:GetService("Players")
        local localPlayer = Players.LocalPlayer
        local playerScripts = localPlayer and localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local abilityHandlerModule = moduleScripts and moduleScripts:WaitForChild("AbilityHandler", 5)
        if not abilityHandlerModule then
            return nil, "AbilityHandler unavailable"
        end

        local ok, abilityHandler = pcall(require, abilityHandlerModule)
        if not ok or not abilityHandler then
            return nil, "AbilityHandler require failed"
        end

        return abilityHandler
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            local abilityHandler, err = getAbilityHandler()
            if not abilityHandler then
                return false, err
            end

            state.abilityHandler = abilityHandler
            state.hadOriginal = abilityHandler.canBeAffected ~= nil
            state.originalCanBeAffected = abilityHandler.canBeAffected
            abilityHandler.canBeAffected = function()
                return true
            end
            state.enabled = true
            return true
        end

        if state.abilityHandler then
            if state.hadOriginal then
                state.abilityHandler.canBeAffected = state.originalCanBeAffected
            else
                state.abilityHandler.canBeAffected = nil
            end
        end

        state.enabled = false
        state.abilityHandler = nil
        state.originalCanBeAffected = nil
        state.hadOriginal = false
        return true
    end

    return controller
end

local function tvlRecodeV2Fn_getCanBeAffectedController()
    if not tvlRecodeV2_canBeAffectedState.controller then
        tvlRecodeV2_canBeAffectedState.controller = tvlRecodeV2Fn_createCanBeAffectedController()
    end
    return tvlRecodeV2_canBeAffectedState.controller
end

local function tvlRecodeV2Fn_startAutoDeploy()
