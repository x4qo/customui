    controller = nil,
}

local function tvlRecodeV2Fn_createAntiAnnoyController()
    local DISRUPTIVE_GC_NAMES = {
        SmallShake = true, StartShake = true, ShakeSustain = true,
        smallShake = true, startShake = true, shakeSustain = true,
        _startCameraShaker = true, sunBurn = true,
    }

    local DISRUPTIVE_UPVALUE_KEYWORDS = {
        "shake", "blackout", "flash", "blind", "burn", "darken", "fade", "overlay",
    }

    local function isDisruptiveName(name)
        if type(name) ~= "string" or name == "" then
            return false
        end
        local lowered = name:lower()
        for _, keyword in ipairs(DISRUPTIVE_UPVALUE_KEYWORDS) do
            if lowered:find(keyword, 1, true) then
                return true
            end
        end
        return false
    end

    local function neutralizeUpvalues(fn)
        if type(fn) ~= "function" then
            return 0
        end

        local ok, upvalues = pcall(debug.getupvalues, fn)
        if not ok or not upvalues then
            return 0
        end

        local neutralized = 0
        for index, value in pairs(upvalues) do
            if type(value) == "function" then
                local infoOk, info = pcall(debug.getinfo, value)
                if infoOk and info and isDisruptiveName(info.name) then
                    local setOk = pcall(debug.setupvalue, fn, index, function() end)
                    if setOk then
                        neutralized = neutralized + 1
                    end
                end
            end
        end

        return neutralized
    end

    local function disableSharedDisruptiveFunctions()
        task.spawn(function()
            local gc = (getgc and getgc(true)) or {}

            for _, v in ipairs(gc) do
                if type(v) == "function" then
                    local ok, info = pcall(debug.getinfo, v)
                    if ok and info and info.name and DISRUPTIVE_GC_NAMES[info.name] then
                        local neutralized = neutralizeUpvalues(v)
                        if neutralized == 0 then
                            pcall(function()
                                hookfunction(v, function() end)
                            end)
                        end
                    end
                elseif type(v) == "table" then
                    pcall(function()
                        local shaker = rawget(v, "_startCameraShaker")
                        if type(shaker) == "function" then
                            local neutralized = neutralizeUpvalues(shaker)
                            if neutralized == 0 then
                                hookfunction(shaker, function() end)
                            end
                        end

                        local sunBurn = rawget(v, "sunBurn")
                        if type(sunBurn) == "function" then
                            local neutralized = neutralizeUpvalues(sunBurn)
                            if neutralized == 0 then
                                hookfunction(sunBurn, function() end)
                            end
                        end
                    end)
                end
            end
        end)
    end

    local function patchAbilityUpvalues(modulePath, methodName)
        local success, moduleTable = pcall(function()
            return require(modulePath)
        end)
        if not success or type(moduleTable) ~= "table" then
            return false
        end

        local original = moduleTable[methodName]
        if type(original) ~= "function" then
            return false
        end

        neutralizeUpvalues(original)
        return true
    end

    local state = {
        enabled = false,
    }

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if not enable then
            state.enabled = false
            return true
        end

        state.enabled = true

        disableSharedDisruptiveFunctions()

        local localPlayer = game:GetService("Players").LocalPlayer
        if not localPlayer.PlayerScripts:FindFirstChild("ModuleScripts") then
            localPlayer.PlayerScripts:WaitForChild("ModuleScripts")
        end

        local AbilityHandler = localPlayer.PlayerScripts.ModuleScripts.AbilityHandler

        local targets = {
            { name = "SolarisImpulsus", path = AbilityHandler.SolarisImpulsus, method = "victim" },
            { name = "PsychicCompulsionSleep", path = AbilityHandler.PsychicCompulsion.Sleep, method = "activate" },
            { name = "AdSomnum", path = AbilityHandler.AdSomnum, method = "victim" },
            { name = "IllusionAttack", path = AbilityHandler.IllusionAttack, method = "punchEffect" },
            { name = "Sol", path = AbilityHandler.Sol, method = "victim" },
            { name = "SnapNeck", path = AbilityHandler.SnapNeck, method = "begin" },
            { name = "NecksnapLift", path = AbilityHandler.NecksnapLift, method = "knockout" },
            { name = "Ossox", path = AbilityHandler.Ossox, method = "begin" },
            { name = "MenedekQualSurenta", path = AbilityHandler.MenedekQualSurenta, method = "begin" },
            { name = "Sunbeam", path = AbilityHandler.Sunbeam, method = "victim" },
        }

        local hookedModules = {}

        local function applyHooks()
            local count = 0
            for _, target in ipairs(targets) do
                if not hookedModules[target.name] then
                    local ok = patchAbilityUpvalues(target.path, target.method)
                    if ok then
                        hookedModules[target.name] = true
                        count = count + 1
                    end
                else
                    count = count + 1
                end
            end
            return count
        end

        local initialCount = applyHooks()

        if initialCount < #targets then
            task.spawn(function()
                while state.enabled do
                    task.wait(30)
                    if not state.enabled then
                        break
                    end
                    local currentCount = applyHooks()
                    if currentCount >= #targets then
                        break
                    end
                end
            end)
        end

        return true
    end

    return controller
end

local function tvlRecodeV2Fn_getAntiAnnoyController()
    if not tvlRecodeV2_AntiAnnoyState.controller then
        tvlRecodeV2_AntiAnnoyState.controller = tvlRecodeV2Fn_createAntiAnnoyController()
    end
    return tvlRecodeV2_AntiAnnoyState.controller
