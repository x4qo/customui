        function library:close_element(new_path)
            local open_element = library.current_open

            if open_element and new_path ~= open_element then
                open_element.set_visible(false)
                open_element.open = false;
            end

            if new_path ~= open_element then
                library.current_open = new_path or nil;
            end
        end

        function library:create(instance, options)
            local ins = Instance.new(instance)

            for prop, value in options do
                ins[prop] = value
            end

            if options.FontFace == fonts.font then
                insert(font_users.main, ins)
            elseif options.FontFace == fonts.small then
                insert(font_users.small, ins)
            end

            return ins
        end

        function library:get_fonts()
            local names = {}
            for _, preset in font_presets do
                insert(names, preset.name)
            end
            return names
        end

        function library:set_font(name)
            local preset
            for _, p in font_presets do
                if p.name == name then preset = p break end
            end
            if not preset then return end

            fonts.font, fonts.small = preset.main, preset.small

            for _, obj in font_users.main do
                pcall(function() obj.FontFace = preset.main end)
            end
            for _, obj in font_users.small do
                pcall(function() obj.FontFace = preset.small end)
            end
        end

