        end
        return
    end
    tvlRecodeV2_autoDeployStarted = true

    local mPlayers = game:GetService("Players")
    local mRunService = game:GetService("RunService")
    local mUserInputService = game:GetService("UserInputService")

    local mLocalPlayer = mPlayers.LocalPlayer or mPlayers.PlayerAdded:Wait()

    local DEPLOY_BIND = "TVL_DeployBind_7F2A9C"

    local function tvlRecodeV2Fn_autoDeployResolvePlayerGui(timeout)
        local className = string.char(80, 108, 97, 121, 101, 114, 71, 117, 105)
        local player = mLocalPlayer or mPlayers.LocalPlayer
        if not player then return nil end
        local container = player:FindFirstChildOfClass(className) or player:FindFirstChild(className)
        if container then return container end
        return player:WaitForChild(className, timeout)
    end

    local mDeployState = {
        active = false,
        deployed = false,
        lastText = "",
        charConn = nil,
        inputConn = nil,
    }

    local function tvlRecodeV2Fn_tvlCleanupDeploy()
        mDeployState.active = false
        mDeployState.lastText = ""
        pcall(function() mRunService:UnbindFromRenderStep(DEPLOY_BIND) end)
        if mDeployState.charConn then
            mDeployState.charConn:Disconnect()
            mDeployState.charConn = nil
        end
    end

    local function tvlRecodeV2Fn_tvlFinishDeploy()
        if mDeployState.deployed then return end
        mDeployState.deployed = true
        tvlRecodeV2Fn_tvlCleanupDeploy()
    end

    local function tvlRecodeV2Fn_tvlFetchStartScreen()
        local gui = tvlRecodeV2Fn_autoDeployResolvePlayerGui(3)
        if not gui then return nil end
        return gui:FindFirstChild("StartScreen") or gui:WaitForChild("StartScreen", 3)
    end

    local function tvlRecodeV2Fn_tvlIsSelectionVisible()
        local ok, result = pcall(function()
            local screen = tvlRecodeV2Fn_tvlFetchStartScreen()
            if not screen then return false end
            return screen.MainHolder.SelectCharacterFrame.LeftArea.MiddleArea.TopArea.Visible
        end)
        return ok and result
    end

    local function tvlRecodeV2Fn_tvlIsAnnouncementClear(text)
        return text == "" or text == " " or #text == 0
    end

    local function tvlRecodeV2Fn_autoDeployFireButtonCallback(button)
        if not button or type(getconnections) ~= "function" then return false end
        local conns = getconnections(button.Activated)
        if conns[1] then
            conns[1].Function()
            return true
        end
        return false
    end

    local function tvlRecodeV2Fn_tvlDismissPrompts()
        local screen = tvlRecodeV2Fn_tvlFetchStartScreen()
        if not screen then return end
        for _, folder in pairs({ screen, screen:FindFirstChild("MainHolder") }) do
            if folder then
                for _, child in pairs(folder:GetChildren()) do
                    if string.find(child.Name, "Prompt") then
                        local btn = child:FindFirstChild("Confirm", true)
                            or child:FindFirstChild("Yes", true)
                            or child:FindFirstChild("Button", true)
                        if btn then tvlRecodeV2Fn_autoDeployFireButtonCallback(btn) end
        end
    end
end
        end
    end

    local function tvlRecodeV2Fn_tvlAttemptDeploy()
        if mDeployState.active then
            tvlRecodeV2Fn_tvlFinishDeploy()
            return true
        end

        tvlRecodeV2Fn_tvlCleanupDeploy()
        mDeployState.deployed = false

        local screen = tvlRecodeV2Fn_tvlFetchStartScreen()
        if not screen then return false end

        local ok = pcall(function()
            local holder = screen.MainHolder
            local announcement = holder.CharacterInfoMiddle.TakenAnnouncement
            local spawnBtn = holder.SelectCharacterFrame.LeftArea.BottomArea.Spawn

            mDeployState.active = true
            mDeployState.lastText = announcement.Text

            mDeployState.charConn = mLocalPlayer.CharacterAdded:Connect(tvlRecodeV2Fn_tvlFinishDeploy)

            if tvlRecodeV2Fn_tvlIsSelectionVisible() and tvlRecodeV2Fn_tvlIsAnnouncementClear(announcement.Text) then
                tvlRecodeV2Fn_autoDeployFireButtonCallback(spawnBtn)
                tvlRecodeV2Fn_tvlDismissPrompts()
            end

            mRunService:BindToRenderStep(DEPLOY_BIND, Enum.RenderPriority.Input.Value - 1, function()
                if not mDeployState.active or mDeployState.deployed then
                    tvlRecodeV2Fn_tvlCleanupDeploy()
                    return
                end
                local current = announcement.Text
                if current ~= mDeployState.lastText then
                    mDeployState.lastText = current
                    if tvlRecodeV2Fn_tvlIsSelectionVisible() and tvlRecodeV2Fn_tvlIsAnnouncementClear(current) then
                        tvlRecodeV2Fn_autoDeployFireButtonCallback(spawnBtn)
                        tvlRecodeV2Fn_tvlDismissPrompts()
                    end
                end
            end)
        end)

        if not ok then
            tvlRecodeV2Fn_tvlCleanupDeploy()
            return false
        end
        return true
    end

    tvlRecodeV2_autoDeployAttempt = tvlRecodeV2Fn_tvlAttemptDeploy
    tvlRecodeV2Fn_tvlAttemptDeploy()

    mDeployState.inputConn = mUserInputService.InputBegan:Connect(function(input, processed)
        if processed or input.KeyCode ~= tvlRecodeV2_autoDeployState.deployKey then return end
        tvlRecodeV2Fn_tvlAttemptDeploy()
    end)

    tvlRecodeV2_autoDeployState.stop = function()
        tvlRecodeV2Fn_tvlCleanupDeploy()
        if mDeployState.inputConn then
            mDeployState.inputConn:Disconnect()
            mDeployState.inputConn = nil
        end
        tvlRecodeV2_autoDeployStarted = false
        tvlRecodeV2_autoDeployAttempt = nil
        tvlRecodeV2_autoDeployState.stop = nil
    end
end

local function tvlRecodeV2Fn_setAutoDeployEnabled(enable)
