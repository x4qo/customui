        function library:apply_theme(instance, theme, property)
            insert(themes.utility[theme][property], instance)
        end

        function library:update_theme(theme, color)
            if themes.preset[theme] == color then
                return
            end

            for _, property in themes.utility[theme] do

                for m, object in property do
                    if object[_] == themes.preset[theme] then
                        object[_] = color
                    end
                end
            end

            themes.preset[theme] = color

            if theme == "accent" and library.brand_gradient then
                library.brand_gradient.Color = accent_sequence(color)
            end

            if theme == "accent" and library.game_gradient then
                library.game_gradient.Color = accent_sequence(color)
            end

            if theme == "accent" and library.keybind_title_gradient then
                library.keybind_title_gradient.Color = accent_sequence(color)
            end

            if theme == "accent" and library.keybind_icon_gradient then
                library.keybind_icon_gradient.Color = accent_sequence(color)
            end

            if theme == "accent" and library.presence_title_gradient then
                library.presence_title_gradient.Color = accent_sequence(color)
            end

            if theme == "accent" and library.presence_icon_gradient then
                library.presence_icon_gradient.Color = accent_sequence(color)
            end
        end

        function library:connection(signal, callback)
