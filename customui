local function tvlRecodeV2Fn_createAbilitySpammerController(config)
    config = config or {}
    local featureState = config.featureState or tvlRecodeV2_abilitySpammerState
    local maxBurstCount = tonumber(config.maxBurstCount) or 250
    local getMethod = config.getMethod
    local renderStepName = config.renderStepName or "TVLRecodeV2AbilitySpammer"

    local state = {
        enabled = false,
        active = false,
        currentAbility = nil,
        currentFunction = nil,
        connections = {},
        boundRenderStep = false,
        renderStepNames = {},
        runService = nil,
        userInputService = nil,
        abilityHandler = nil,
    }

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            local conn = state.connections[i]
            pcall(function()
                conn:Disconnect()
            end)
            state.connections[i] = nil
        end
    end

    local function updateAbility()
        local ability = state.abilityHandler and state.abilityHandler.activeAbility
        if ability ~= state.currentAbility then
            state.currentAbility = ability
            state.currentFunction = (ability and type(ability.activated) == "function") and ability.activated or nil
        end
    end

    local function fireAbility()
        if not state.active or not state.currentFunction then
            return
        end

        local count = math.clamp(math.floor(tonumber(featureState.burstCount) or 0), 0, maxBurstCount)
        local ability = state.currentAbility
        local currentFunction = state.currentFunction
        for _ = 1, count do
            task.spawn(function()
                if ability then
                    ability._isHolding = true
                end
                currentFunction(ability)
            end)
        end
    end

    local function step()
        if state.active then
            updateAbility()
            fireAbility()
        end
    end

    local function bindSpamLoop()
        local method = type(getMethod) == "function" and tostring(getMethod()) or "Method 2"

        if method == "Method 1" and type(state.runService.BindToRenderStep) == "function" then
            local laneCount = tonumber(config.renderStepLaneCount) or 1
            local basePriority = tonumber(config.renderStepPriority) or -1
            for lane = 1, math.max(1, laneCount) do
                local laneName = laneCount > 1 and (renderStepName .. "_" .. tostring(lane)) or renderStepName
                state.runService:BindToRenderStep(laneName, basePriority + lane - 1, step)
                table.insert(state.renderStepNames, laneName)
            end
            state.boundRenderStep = true
            return
        end

        if method == "Method 3" and state.runService.PostSimulation then
            addConnection(state.runService.PostSimulation:Connect(step))
            return
        end

        if method == "Method 4" and state.runService.RenderStepped then
            addConnection(state.runService.RenderStepped:Connect(step))
            return
        end

        addConnection(state.runService.Heartbeat:Connect(step))
    end

    local function connect()
        if state.enabled then
            return true
        end

        local Players = game:GetService("Players")
        state.runService = game:GetService("RunService")
        state.userInputService = game:GetService("UserInputService")

        local localPlayer = Players.LocalPlayer
        local playerScripts = localPlayer and localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local abilityHandlerModule = moduleScripts and moduleScripts:WaitForChild("AbilityHandler", 5)
        if not abilityHandlerModule then
            return false, "AbilityHandler unavailable"
        end

        local ok, abilityHandler = pcall(require, abilityHandlerModule)
        if not ok or not abilityHandler then
            return false, "AbilityHandler require failed"
        end

        state.abilityHandler = abilityHandler
        state.enabled = true

        addConnection(state.userInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then
                return
            end
            if input.KeyCode == featureState.keyCode then
                if featureState.activationMode == "Toggle" then
                    state.active = not state.active
                else
                    state.active = true
                end
                featureState.active = state.active
            end
        end))

        addConnection(state.userInputService.InputEnded:Connect(function(input)
            if input.KeyCode == featureState.keyCode then
                if featureState.activationMode ~= "Toggle" then
                    state.active = false
                    featureState.active = false
                end
            end
        end))

        bindSpamLoop()

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                state.active = false
                if state.boundRenderStep and state.runService then
                    for _, laneName in ipairs(state.renderStepNames) do
                        pcall(function()
                            state.runService:UnbindFromRenderStep(laneName)
                        end)
                    end
                    state.renderStepNames = {}
                    state.boundRenderStep = false
                end
                disconnectAll()
                return false, err
            end
            return true
        end

        state.enabled = false
        state.active = false
        featureState.active = false
        state.currentAbility = nil
        state.currentFunction = nil
        state.abilityHandler = nil
        if state.boundRenderStep and state.runService then
            for _, laneName in ipairs(state.renderStepNames) do
                pcall(function()
                    state.runService:UnbindFromRenderStep(laneName)
                end)
            end
            state.renderStepNames = {}
            state.boundRenderStep = false
        end
        disconnectAll()
        return true
    end

    function controller:setActive(value)
        state.active = value == true
        featureState.active = state.active
    end

    return controller
end

