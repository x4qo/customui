        -- One shared fps/ping sampler. Every widget that shows fps/ping (the topbar
        -- info row, the presence bar) registers a consumer here instead of opening
        -- its own RenderStepped connection. The single loop counts frames + reads
        -- ping at most twice a second; consumers do their own visibility guard and
        -- change dedupe, so a hidden widget costs nothing.
        function library:on_fps(callback)
            if not self.fps_consumers then
                self.fps_consumers = {}
                local accum, frames, fps = 0, 0, 0
                local sinceText = 0
                local ping = 0
                run.RenderStepped:Connect(function(dt)
                    accum     = accum + dt
                    sinceText = sinceText + dt
                    frames    = frames + 1
                    if accum >= 0.5 then
                        fps = floor(frames / accum + 0.5)
                        accum, frames = 0, 0
                    end
                    if sinceText < 0.5 then return end
                    sinceText = 0
                    pcall(function() ping = floor(lp:GetNetworkPing() * 1000 + 0.5) end)
                    local consumers = self.fps_consumers
                    for i = 1, #consumers do
                        pcall(consumers[i], fps, ping)
                    end
                end)
            end
            insert(self.fps_consumers, callback)
        end

        function library:resizify(frame)
            local Frame = Instance.new("TextButton")
            Frame.Position = dim2(1, -10, 1, -10)
            Frame.BorderColor3 = rgb(0, 0, 0)
            Frame.Size = dim2(0, 10, 0, 10)
            Frame.BorderSizePixel = 0
            Frame.BackgroundColor3 = rgb(255, 255, 255)
            Frame.Parent = frame
            Frame.BackgroundTransparency = 1
            Frame.Text = ""

            local start_size
            local start
            local og_size = frame.Size
            local resize_conn

            -- only listen to mouse movement while actively resizing, instead of a
            -- permanent InputChanged that runs on every mouse move
            local function on_resize(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement then
                    local viewport_x = camera.ViewportSize.X
                    local viewport_y = camera.ViewportSize.Y

                    local current_size = dim2(
                        start_size.X.Scale,
                        math.clamp(
                            start_size.X.Offset + (input.Position.X - start.X),
                            og_size.X.Offset,
                            viewport_x
                        ),
                        start_size.Y.Scale,
                        math.clamp(
                            start_size.Y.Offset + (input.Position.Y - start.Y),
                            og_size.Y.Offset,
                            viewport_y
                        )
                    )

                    frame.Size = current_size
                end
            end

            Frame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    start = input.Position
                    start_size = frame.Size
                    if resize_conn then resize_conn:Disconnect() end
                    resize_conn = uis.InputChanged:Connect(on_resize)
                end
            end)

            library:connection(uis.InputEnded, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if resize_conn then resize_conn:Disconnect(); resize_conn = nil end
                end
            end)
        end

