    library.search_items = {}
    function library:apply_search(query)
        query = tostring(query or ""):lower():gsub("^%s+", ""):gsub("%s+$", "")

        local sections, has_match = {}, {}
        for _, item in ipairs(self.search_items) do
            if item.frame and item.frame.Parent then
                local match = (query == "") or (item.name:find(query, 1, true) ~= nil)
                item.frame.Visible = match
                local sec = item.section
                if sec then
                    if has_match[sec] == nil then
                        has_match[sec] = false
                        sections[#sections + 1] = sec
                    end
                    if match then has_match[sec] = true end
                end
            end
        end

        for _, sec in ipairs(sections) do
            local box = sec.items and sec.items[ "outline" ]
            if box then
                box.Visible = (query == "") or has_match[sec]
            end
        end
    end

