        -- one shared poll loop. row is in the panel while the feature is
        -- ENABLED (toggled on in the UI); the right-side status reads "Held"
        -- while its key is physically down, "Off" otherwise.
        function library:start_keybind_loop()
            if library.keybind_loop_started then return end
            library.keybind_loop_started = true

            -- the status text only needs to refresh a few times a second;
            -- polling every frame was pure overhead.
            local acc = 0
            run.RenderStepped:Connect(function(dt)
                acc = acc + dt
                if acc < 0.1 then return end
                acc = 0

                -- do nothing while the on-screen list is turned off or empty.
                -- The panel can be hidden because no rows are active, so do not
                -- use panel.Visible as a guard; this loop is what lets it wake
                -- back up when a feature is enabled.
                if library.keybind_panel_enabled == false then
                    if library.keybind_list then library.keybind_list.Visible = false end
                    return
                end
                local entries = library.keybind_entries
                if not entries or not next(entries) then
                    library:refresh_keybind_panel()
                    return
                end

                for _, e in entries do
                    local enabled = e.get_enabled and (e.get_enabled() and true or false) or false

                    -- row only present while the feature is toggled on
                    if e.row.Visible ~= enabled then
                        e.row.Visible = enabled
                    end

                    if enabled then
                        -- active = the feature is actually firing. prefer the
                        -- feature's own state; fall back to physical key-hold.
                        local active
                        if e.get_active then
                            active = e.get_active() and true or false
                        else
                            local key = e.get_key and e.get_key() or nil
                            active = (typeof(key) == "EnumItem" and key.EnumType == Enum.KeyCode and uis:IsKeyDown(key)) and true or false
                        end

                        local mode = e.get_mode and e.get_mode() or nil
                        local label = active and ((mode == "Toggle") and "Toggled" or "Held") or "Off"
                        if e.row_key.Text ~= label then e.row_key.Text = label end

                        if active ~= e._held then
                            e._held = active
                            library:tween(e.row_name, { TextColor3 = active and rgb(255, 255, 255) or rgb(206, 206, 212) },   Enum.EasingStyle.Quint, 0.16)
                            library:tween(e.row_key,  { TextColor3 = active and themes.preset.accent or rgb(150, 150, 156) }, Enum.EasingStyle.Quint, 0.16)
                        end
                    end
                end

                library:refresh_keybind_panel()
            end)
        end

