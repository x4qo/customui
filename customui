local function tvlRecodeV2Fn_getFps(sampleTime)
    local RunService = game:GetService("RunService")
    local frames = 0
    local started = os.clock()

    while os.clock() - started < sampleTime do
        frames += 1
        RunService.RenderStepped:Wait()
    end

    local elapsed = math.max(os.clock() - started, 0.001)
    return math.floor((frames / elapsed) + 0.5)
end

