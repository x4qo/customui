        function library:refresh_keybind_panel()
            if not library.keybind_list then return end
            local visible = false
            if library.keybind_panel_enabled ~= false then
                local rows = library.keybind_rows
                if rows then
                    for _, row in rows do
                        if row and row.Parent and row.Visible then
                            visible = true
                            break
                        end
                    end
                end
            end
            library.keybind_list.Visible = visible
        end

        -- toggle the whole panel on/off (used by a UI setting)
        function library:set_keybind_panel_enabled(bool)
            library.keybind_panel_enabled = bool and true or false
            library:refresh_keybind_panel()
        end

