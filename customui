                BackgroundTransparency = 1;
                BorderSizePixel = 0;
                Position = dim2(1, -12, 0, 0);
                Size = dim2(0, 64, 1, 0);
                ZIndex = 62;
            })

            local entry = {
                row = row, row_name = row_name, row_key = row_key,
                get_key = opts.get_key, get_enabled = opts.get_enabled,
                get_active = opts.get_active, get_mode = opts.get_mode,
                _held = false,
            }

            function entry:set_name(n) row_name.Text = n or "Keybind" end
            function entry:remove()
                row:Destroy()
                local i = find(library.keybind_entries, entry); if i then remove(library.keybind_entries, i) end
                local j = find(library.keybind_rows, row);       if j then remove(library.keybind_rows, j) end
                library:refresh_keybind_panel()
            end

            insert(library.keybind_rows, row)
            insert(library.keybind_entries, entry)

            library:start_keybind_loop()
            return entry
        end

