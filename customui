do
    local function register(self, opts)
        pcall(function()
            local elements = self and self.items and self.items[ "elements" ]
            local name = opts and (opts.name or opts.Name)
            if not (elements and name) then return end
            local kids = elements:GetChildren()
            for i = #kids, 1, -1 do
                if kids[i]:IsA("GuiObject") then
                    table.insert(library.search_items, { frame = kids[i], name = tostring(name):lower(), section = self })
                    break
                end
            end
        end)
    end

    for _, method in ipairs({ "toggle", "slider", "dropdown", "colorpicker", "textbox", "keybind", "button" }) do
        local original = library[method]
        if original then
            library[method] = function(self, opts, ...)
                local result = original(self, opts, ...)
                register(self, opts)
                return result
            end
        end
    end
end

return library
