local function tvlRecodeV2Fn_makeCustomWheelController()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local state = {
        enabled = false,
        loaded = false,
        backgroundImage = "17878312749",
        enhancedClarity = false,
        bindable = nil,
        remote = nil,
    }
    local controller = {}

    local function resolve()
        if state.loaded then return true end
        local ok = pcall(function()
            state.bindable = ReplicatedStorage
                :WaitForChild("Bindables")
                :WaitForChild("FusionStates")
                :WaitForChild("EnabledAbilityWheelDecoration")
            state.remote = ReplicatedStorage
                :WaitForChild("Remotes")
                :WaitForChild("GameServices")
                :WaitForChild("ToClient")
                :WaitForChild("EnabledAbilityWheelDecoration")
        end)
        state.loaded = ok and state.bindable ~= nil
        return state.loaded
    end

    local function fire(canDecorate)
        local settings = {
            backgroundImage = state.backgroundImage,
            imageSize = "large",
            enhancedClarity = state.enhancedClarity,
            cursorImage = "128332235381778",
            canDecorate = canDecorate,
        }
        pcall(function() state.bindable:Fire(settings) end)
        if getconnections and state.remote then
            local ok, conns = pcall(getconnections, state.remote.OnClientEvent)
            if ok and conns then
                for _, connection in pairs(conns) do
                    pcall(function() connection:Fire(settings) end)
                end
            end
        end
    end

    function controller:setBackgroundImage(text)
        state.backgroundImage = (tostring(text or ""):gsub("%s+", ""))
        if state.enabled then fire(true) end
        return state.backgroundImage
    end

    function controller:setEnhancedClarity(value)
        state.enhancedClarity = value == true
        if state.enabled then fire(true) end
        return state.enhancedClarity
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end
        if enable then
            if not resolve() then
                return false, "Could not resolve ability wheel decoration"
            end
            state.enabled = true
            fire(true)
            return true
        end
        state.enabled = false
        if state.loaded then fire(false) end
        return true
    end

    return controller
end

