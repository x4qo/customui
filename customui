    tvlRecodeV2_plantEspState.scanRunId += 1
    tvlRecodeV2_plantEspState.scanThread = nil

    if tvlRecodeV2_plantEspState.distanceConn then
        tvlRecodeV2_plantEspState.distanceConn:Disconnect()
        tvlRecodeV2_plantEspState.distanceConn = nil
    end
    if tvlRecodeV2_plantEspState.descendantAddedConn then
        tvlRecodeV2_plantEspState.descendantAddedConn:Disconnect()
        tvlRecodeV2_plantEspState.descendantAddedConn = nil
    end
    if tvlRecodeV2_plantEspState.descendantRemovingConn then
        tvlRecodeV2_plantEspState.descendantRemovingConn:Disconnect()
        tvlRecodeV2_plantEspState.descendantRemovingConn = nil
    end
    if tvlRecodeV2_plantEspState.interactablesWatcher then
        tvlRecodeV2_plantEspState.interactablesWatcher:Disconnect()
