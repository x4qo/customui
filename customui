local function tvlRecodeV2Fn_startAimAssist()
    if tvlRecodeV2_aimAssistState.enabled then
        return
    end

    tvlRecodeV2_aimAssistState.enabled = true

    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local localPlayer = Players.LocalPlayer
    local entities = workspace:WaitForChild("Entities")
    local playerModules = localPlayer.PlayerScripts:WaitForChild("ModuleScripts")
    local abilityBindables = localPlayer.PlayerScripts.Bindables.Abilities
    local abilityHandler = require(playerModules.AbilityHandler)

    local HitDetection = require(ReplicatedStorage.ModuleScripts.TargetSystem.HitDetection.i)
    local fakeMouse = { X = 0, Y = 0 }

    local activeRange
    local activeOrigin
    local restricted = false

    local restrictedAbilities = {
        DarkJosieTeleport = true,
        MuseTeleport = true,
        PsychicTeleport = true,
        VisSeraPortus = true,
        Invisique = true,
    }

    if tvlRecodeV2_aimAssistState.abilityConn then
        tvlRecodeV2_aimAssistState.abilityConn:Disconnect()
        tvlRecodeV2_aimAssistState.abilityConn = nil
    end

    tvlRecodeV2_aimAssistState.abilityConn = abilityBindables.MainAbilitiesChanged.Event:Connect(function(abilityName)
        if abilityName then
            task.wait()
            local ability = abilityHandler.activeAbility
            activeRange = ability and ability._range or nil
            activeOrigin = ability and ability._character and ability._character.PrimaryPart or nil
            restricted = restrictedAbilities[abilityName] == true
        else
            activeRange, activeOrigin, restricted = nil, nil, false
        end
    end)

    local function hookMouse(func)
        for index, upvalue in debug.getupvalues(func) do
            if typeof(upvalue) == "Instance" and upvalue:IsA("Mouse") then
                table.insert(tvlRecodeV2_aimAssistState.mouseHooks, {
                    func = func,
                    index = index,
                    original = upvalue,
                })
                debug.setupvalue(func, index, fakeMouse)
            end
        end
    end

    hookMouse(HitDetection.Hitscan)
    for _, mod in pairs(playerModules.AbilityHandler:GetChildren()) do
        for _, f in pairs(require(mod)) do if typeof(f) == "function" then hookMouse(f) end end
    end

    local function scanTargets()
        if not tvlRecodeV2_aimAssistState.enabled then return end

        local character = localPlayer.Character
        local camera = workspace.CurrentCamera
        if not character or not camera then return end

        local liveAbility = abilityHandler.activeAbility
        activeRange = liveAbility and liveAbility._range or nil

        if restricted then
            local m = localPlayer:GetMouse()
            fakeMouse.X, fakeMouse.Y = m.X, m.Y
            return
        end

        local origin = activeOrigin and activeOrigin.Position
        local mousePosition = UserInputService:GetMouseLocation()
        local bestDistance = math.huge
        local bestPosition = nil

        for _, entity in ipairs(entities:GetChildren()) do
            if entity:IsA("Model") and entity ~= character then
                local humanoid = entity:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local targetPart = entity:FindFirstChild("HumanoidRootPart")

                    if targetPart and targetPart:IsA("BasePart") then
                        if tvlRecodeV2_aimAssistState.ignoreFriends then
                            local ownerPlayer = Players:GetPlayerFromCharacter(entity)
                            if ownerPlayer and tvlRecodeV2Fn_aimAssistIsFriendCached(ownerPlayer) then
                                continue
                            end
                        end

                        if origin and activeRange and (origin - targetPart.Position).Magnitude > activeRange then
                            continue
                        end

                        local screen, onScreen = camera:WorldToScreenPoint(targetPart.Position)
                        if onScreen and screen.Z > 0 then
                            local distance = (Vector2.new(screen.X, screen.Y) - mousePosition).Magnitude
                            if distance < bestDistance then
                                bestDistance = distance
                                bestPosition = targetPart.Position
                            end
                        end
                    end
                end
            end
        end

        if bestPosition ~= nil then
            local screen = camera:WorldToScreenPoint(bestPosition)
            fakeMouse.X, fakeMouse.Y = screen.X, screen.Y
        else
            local m = localPlayer:GetMouse()
            fakeMouse.X, fakeMouse.Y = m.X, m.Y
        end
    end

    tvlRecodeV2_aimAssistState.runService = RunService
    pcall(function()
        RunService:UnbindFromRenderStep(tvlRecodeV2_aimAssistState.bindName)
    end)
    RunService:BindToRenderStep(tvlRecodeV2_aimAssistState.bindName, Enum.RenderPriority.Last.Value, scanTargets)
end

local function tvlRecodeV2Fn_stopAimLock()
    tvlRecodeV2_aimLockState.enabled = false
    tvlRecodeV2_aimLockState.active = false
    tvlRecodeV2_aimLockState.lockedTarget = nil
    tvlRecodeV2_aimLockState.setActive = nil

    if tvlRecodeV2_aimLockState.runService then
        pcall(function()
            tvlRecodeV2_aimLockState.runService:UnbindFromRenderStep(tvlRecodeV2_aimLockState.bindName)
        end)
    end

    for i = #tvlRecodeV2_aimLockState.inputConns, 1, -1 do
        pcall(function() tvlRecodeV2_aimLockState.inputConns[i]:Disconnect() end)
        tvlRecodeV2_aimLockState.inputConns[i] = nil
    end
end

local function tvlRecodeV2Fn_startAimLock()
    if tvlRecodeV2_aimLockState.enabled then
        return
    end

    tvlRecodeV2_aimLockState.enabled = true

    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")

    local localPlayer = Players.LocalPlayer
    local entities = workspace:WaitForChild("Entities")

    -- mobile has no cursor, so acquire relative to the middle of the screen; desktop uses the cursor.
    tvlRecodeV2_aimLockState.useScreenCenter =
        UserInputService.TouchEnabled and not UserInputService.MouseEnabled and not UserInputService.KeyboardEnabled
    -- start idle; the keybind (desktop) or the on-screen button (mobile) turns the lock on.
    tvlRecodeV2_aimLockState.active = false
    tvlRecodeV2_aimLockState.lockedTarget = nil
    tvlRecodeV2_aimLockState.runService = RunService

    -- camera lock: no ability hooks or fake mouse, just point the camera at a target

    local function isWhitelisted(ownerPlayer)
        if not tvlRecodeV2_aimLockState.whitelistEnabled then return true end
        if not ownerPlayer then return false end
        return tvlRecodeV2_aimLockState.whitelist[ownerPlayer.Name] == true
    end

    local function isValidTarget(entity)
        if not entity or entity.Parent ~= entities or entity == localPlayer.Character then
            return false
        end
        local humanoid = entity:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then return false end
        if not entity:FindFirstChild("HumanoidRootPart") then return false end
        local ownerPlayer = Players:GetPlayerFromCharacter(entity)
        if not isWhitelisted(ownerPlayer) then return false end
        if tvlRecodeV2_aimAssistState.ignoreFriends and ownerPlayer
            and tvlRecodeV2Fn_aimAssistIsFriendCached(ownerPlayer) then
            return false
        end
        return true
    end

    -- pick the valid entity whose HRP is nearest the reference point (cursor / screen centre)
    local function acquireClosest(camera, reference)
        local best, bestDistance = nil, math.huge
        for _, entity in ipairs(entities:GetChildren()) do
            if entity:IsA("Model") and isValidTarget(entity) then
                local hrp = entity:FindFirstChild("HumanoidRootPart")
                local screen, onScreen = camera:WorldToViewportPoint(hrp.Position)
                if onScreen and screen.Z > 0 then
                    local distance = (Vector2.new(screen.X, screen.Y) - reference).Magnitude
                    if distance < bestDistance then
                        bestDistance = distance
                        best = entity
                    end
                end
            end
        end
        return best
    end

    -- each frame (only while active), keep the camera pointed at the locked entity's HRP
    local function onRenderStep()
        if not tvlRecodeV2_aimLockState.active then return end

        local camera = workspace.CurrentCamera
        if not camera then return end

        -- keep the current target while it stays valid; otherwise grab the closest one.
        -- while a valid target is held this skips the entity scan entirely.
        local target = tvlRecodeV2_aimLockState.lockedTarget
        if not isValidTarget(target) then
            local reference
            if tvlRecodeV2_aimLockState.useScreenCenter then
                local vp = camera.ViewportSize
                reference = Vector2.new(vp.X / 2, vp.Y / 2)
            else
                reference = UserInputService:GetMouseLocation()
            end
            target = acquireClosest(camera, reference)
            tvlRecodeV2_aimLockState.lockedTarget = target
        end

        if not target then return end
        local hrp = target:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        camera.CFrame = CFrame.new(camera.CFrame.Position, hrp.Position)
    end

    -- Bind the RenderStep loop ONLY while actively locking. When Aim Lock is toggled on
    -- but idle (key not pressed / button not tapped) there is no per-frame callback at all.
    local renderBound = false
    local function setAimLockActive(on)
        on = on and true or false
        if on == tvlRecodeV2_aimLockState.active and on == renderBound then return end
        tvlRecodeV2_aimLockState.active = on
        if on then
            if not renderBound then
                pcall(function() RunService:UnbindFromRenderStep(tvlRecodeV2_aimLockState.bindName) end)
                -- bind just after the default camera update so our CFrame wins each frame
                RunService:BindToRenderStep(tvlRecodeV2_aimLockState.bindName, Enum.RenderPriority.Camera.Value + 1, onRenderStep)
                renderBound = true
            end
        else
            tvlRecodeV2_aimLockState.lockedTarget = nil
            if renderBound then
                pcall(function() RunService:UnbindFromRenderStep(tvlRecodeV2_aimLockState.bindName) end)
                renderBound = false
            end
        end
    end
    tvlRecodeV2_aimLockState.setActive = setAimLockActive

    -- lightweight, event-driven keybind: only fires on key press/release, no polling
    for i = #tvlRecodeV2_aimLockState.inputConns, 1, -1 do
        pcall(function() tvlRecodeV2_aimLockState.inputConns[i]:Disconnect() end)
        tvlRecodeV2_aimLockState.inputConns[i] = nil
    end
    table.insert(tvlRecodeV2_aimLockState.inputConns, UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == tvlRecodeV2_aimLockState.keyCode then
            if tvlRecodeV2_aimLockState.activationMode == "Toggle" then
                setAimLockActive(not tvlRecodeV2_aimLockState.active)
            else
                setAimLockActive(true)
            end
        end
    end))
    table.insert(tvlRecodeV2_aimLockState.inputConns, UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == tvlRecodeV2_aimLockState.keyCode then
            if tvlRecodeV2_aimLockState.activationMode ~= "Toggle" then
                setAimLockActive(false)
            end
        end
    end))
end

local tvlRecodeV2_rangeExpansionState = {
    enabled = false,
    mult = 1.25,
    conn = nil,
    originalRanges = {},
}

local function tvlRecodeV2Fn_applyRangeExpansion(ability)
    if not ability or not ability._range then return end
    local state = tvlRecodeV2_rangeExpansionState
    if state.originalRanges[ability] == nil then
        state.originalRanges[ability] = ability._range
    end
    ability._range = state.originalRanges[ability] * state.mult
end

local function tvlRecodeV2Fn_stopRangeExpansion()
    tvlRecodeV2_rangeExpansionState.enabled = false

    if tvlRecodeV2_rangeExpansionState.conn then
        tvlRecodeV2_rangeExpansionState.conn:Disconnect()
        tvlRecodeV2_rangeExpansionState.conn = nil
    end

    for ability, original in pairs(tvlRecodeV2_rangeExpansionState.originalRanges) do
        pcall(function()
            if ability and ability._range then
                ability._range = original
            end
        end)
    end
    tvlRecodeV2_rangeExpansionState.originalRanges = {}

    if type(getgenv) == "function" then
        getgenv().rangeExpander = nil
    end
end

local function tvlRecodeV2Fn_startRangeExpansion()
    if tvlRecodeV2_rangeExpansionState.enabled then
        return
    end

    tvlRecodeV2_rangeExpansionState.enabled = true
    tvlRecodeV2_rangeExpansionState.originalRanges = {}

    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local PlayerScripts = LocalPlayer.PlayerScripts
    local PlayerModules = PlayerScripts:WaitForChild("ModuleScripts")
    local LocalBindables = PlayerScripts.Bindables
    local AbilityBindables = LocalBindables.Abilities
    local AbilityHandler = require(PlayerModules.AbilityHandler)

    if type(getgenv) == "function" and getgenv().rangeExpander then
        getgenv().rangeExpander:Disconnect()
    end

    local conn = AbilityBindables.MainAbilitiesChanged.Event:Connect(function(abilityName)
        if not tvlRecodeV2_rangeExpansionState.enabled then return end
        if abilityName then
            task.wait()
            local ability = AbilityHandler.activeAbility
            if ability and ability._name then
                tvlRecodeV2Fn_applyRangeExpansion(ability)
            end
        end
    end)

    tvlRecodeV2_rangeExpansionState.conn = conn

    pcall(function()
        tvlRecodeV2Fn_applyRangeExpansion(AbilityHandler.activeAbility)
    end)

    if type(getgenv) == "function" then
        getgenv().rangeExpander = conn
    end
end

local tvlRecodeV2_LatestInventionState = {
    controller = nil,
    uiEnabled = false,
    active = false,
    keyCode = Enum.KeyCode.F,
    activationMode = "Hold",
    callsPerSecond = 1200,
}

local function tvlRecodeV2Fn_createLatestInventionController()
    local EXCLUDE_FRIENDS = false
    local AIM_ASSIST_BIND_NAME = "LatestInventionAimAssist"
    local RESTRICTED_AIM_ABILITIES = {
        DarkJosieTeleport = true,
        MuseTeleport = true,
        PsychicTeleport = true,
        VisSeraPortus = true,
        Invisique = true,
        Motus = true,
    }
    local ADSOMNUM_CASTER_ANIMATION_ID = "rbxassetid://14589451404"
    local IMMOBILUS_ACTIVATED_ANIMATION_ID = "rbxassetid://103809123106748"
    local ERROXFEMUS_VICTIM_ANIMATION_IDS = {
        ["rbxassetid://14589356771"] = true,
        ["rbxassetid://14589362277"] = true,
        ["rbxassetid://14589366411"] = true,
        ["rbxassetid://14589370013"] = true,
    }
    local ERROXFEMUS_ACTIVATED_ANIMATION_ID = "rbxassetid://6713148336"
    local PHASMATOSMOTUSINCENDIAMOS_ACTIVATED_ANIMATION_ID = "rbxassetid://5533028295"
    local ICTUS_ACTIVATED_ANIMATION_ID = "rbxassetid://6900156131"
    local HEADSIPHON_CASTER_ANIMATION_IDS = {
        ["rbxassetid://12955966256"] = true,
        ["rbxassetid://12955990988"] = true,
    }
    local ARMBREAK_CASTER_ANIMATION_ID = "rbxassetid://125965536527103"

    local state = {
        enabled = false,
        active = false,
        connections = {},
        runService = nil,
        userInputService = nil,
        players = nil,
        collectionService = nil,
        entities = nil,
        rangeExpansionOriginalRanges = setmetatable({}, { __mode = "k" }),
        abilityRemote = nil,
        abilityHandler = nil,
        abilityHandlerModuleInstance = nil,
        abilityData = nil,
        victimAnimationLookup = nil,
        casterAnimationLookup = nil,
        abilitiesWithoutVictimData = nil,
        localAnimationConnections = {},
        clientDebounce = nil,
        cooldownEvent = nil,
        abilityActivatedEvent = nil,
        abilityNameEnum = nil,
        adSomnumTag = nil,
        immobilusTag = nil,
        erroxFemusTag = nil,
        phasmatosMotusIncendiamosAbilityName = nil,
        ictusAbilityName = nil,
        headSiphonAbilityName = nil,
        armBreakAbilityName = nil,
        localAnimator = nil,
        targetAnimatorCharacter = nil,
        targetAnimatorConnection = nil,
        currentAbilityName = nil,
        fireAttempts = 0,
        remoteFires = 0,
        adSomnumTagHits = 0,
        immobilusTagHits = 0,
        phasmatosMotusIncendiamosHits = 0,
        ictusHits = 0,
        headSiphonHits = 0,
        armBreakHits = 0,
        erroxFemusHits = 0,
        genericVictimHits = 0,
        casterAnimationHits = 0,
        fireAccumulator = 0,
        mouseHooks = {},
        aimAssistBound = false,
        activeRange = nil,
        activeOrigin = nil,
        restrictedAbility = false,
        friendCache = {},
        hasTarget = false,
        targetPart = nil,
    }

    local reactedTracks = setmetatable({}, { __mode = "k" })
    local reactedVictimAnimations = setmetatable({}, { __mode = "k" })
    local currentForcedTrack = nil
    local fakeMouse = { X = 0, Y = 0 }
    local monitorState = {
        hooked = false,
    }

    local function isVictimAnimationReacted(character, animationId)
        local set = reactedVictimAnimations[character]
        return set ~= nil and set[animationId] == true
    end

    local function markVictimAnimationReacted(character, animationId, track)
        if not character then return end

        local set = reactedVictimAnimations[character]
        if not set then
            set = {}
            reactedVictimAnimations[character] = set
        end
        set[animationId] = true

        if track then
            local conn
            conn = track.Stopped:Connect(function()
                local liveSet = reactedVictimAnimations[character]
                if liveSet then
                    liveSet[animationId] = nil
                end
                conn:Disconnect()
            end)
        end
    end

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectConnection(conn)
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
    end

    local function restoreMouseHooks()
        for i = #state.mouseHooks, 1, -1 do
            local hook = state.mouseHooks[i]
            pcall(function()
                debug.setupvalue(hook.func, hook.index, hook.original)
            end)
            state.mouseHooks[i] = nil
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            disconnectConnection(state.connections[i])
            state.connections[i] = nil
        end
        if state.aimAssistBound and state.runService then
            pcall(function() state.runService:UnbindFromRenderStep(AIM_ASSIST_BIND_NAME) end)
            state.aimAssistBound = false
        end
        restoreMouseHooks()
        if state.targetAnimatorConnection then
            disconnectConnection(state.targetAnimatorConnection)
            state.targetAnimatorConnection = nil
        end
        state.targetAnimatorCharacter = nil
        for i = #state.localAnimationConnections, 1, -1 do
            disconnectConnection(state.localAnimationConnections[i])
            state.localAnimationConnections[i] = nil
        end
    end

    local function refreshCurrentAbilityName()
        local ability = state.abilityHandler and state.abilityHandler.activeAbility
        state.currentAbilityName = ability and ability._name or nil
    end

    local function applyRangeExpansion(ability)
        if not tvlRecodeV2_rangeExpansionState.enabled then return end
        if not ability or not ability._range then return end

        if state.rangeExpansionOriginalRanges[ability] == nil then
            state.rangeExpansionOriginalRanges[ability] = ability._range
        end
        ability._range = state.rangeExpansionOriginalRanges[ability] * tvlRecodeV2_rangeExpansionState.mult
    end

    local function restoreRangeExpansion()
        for ability, original in pairs(state.rangeExpansionOriginalRanges) do
            pcall(function()
                if ability and ability._range then
                    ability._range = original
                end
            end)
        end
        state.rangeExpansionOriginalRanges = setmetatable({}, { __mode = "k" })
    end

    local function getAnimatorForCharacter(character)
        if not character then return nil end

        local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 1)
        if not humanoid then return nil end

        return humanoid:FindFirstChildOfClass("Animator") or humanoid:WaitForChild("Animator", 1)
    end

    local onLocalCasterAnimationPlayed
    local onHeadSiphonCasterAnimationPlayed
    local onArmBreakCasterAnimationPlayed

    local ACTION_ANIMATION_PRIORITIES = {
        [Enum.AnimationPriority.Action] = true,
        [Enum.AnimationPriority.Action2] = true,
        [Enum.AnimationPriority.Action3] = true,
        [Enum.AnimationPriority.Action4] = true,
    }

    local function isActionAnimationTrack(track)
        return track ~= nil and ACTION_ANIMATION_PRIORITIES[track.Priority] == true
    end

    local function stopConflictingActionTracks(exceptTrack)
        if not state.localAnimator then return end

        for _, existingTrack in ipairs(state.localAnimator:GetPlayingAnimationTracks()) do
            if existingTrack ~= exceptTrack and isActionAnimationTrack(existingTrack) then
                pcall(function()
                    existingTrack:Stop(0)
                end)
                if existingTrack == currentForcedTrack then
                    currentForcedTrack = nil
                end
            end
        end
    end

    local function hookCharacterAnimator(character)
        for i = #state.localAnimationConnections, 1, -1 do
            disconnectConnection(state.localAnimationConnections[i])
            state.localAnimationConnections[i] = nil
        end

        currentForcedTrack = nil
        state.localAnimator = getAnimatorForCharacter(character)
        if not state.localAnimator then return end

        table.insert(state.localAnimationConnections, state.localAnimator.AnimationPlayed:Connect(function(track)
            if isActionAnimationTrack(track) then
                stopConflictingActionTracks(track)
            end
            onHeadSiphonCasterAnimationPlayed(track)
            onArmBreakCasterAnimationPlayed(track)
            onLocalCasterAnimationPlayed(track)
        end))
    end

    local function isPartOfCurrentTarget(instance)
        local targetPart = state.targetPart
        if not targetPart then return false end

        local targetCharacter = targetPart.Parent
        if not targetCharacter then return false end

        return instance == targetCharacter or instance:IsDescendantOf(targetCharacter)
    end

    local function forceCasterAnimation(animationId)
        if not state.localAnimator then return end

        pcall(function()
            stopConflictingActionTracks(nil)

            local animation = Instance.new("Animation")
            animation.AnimationId = animationId
            local track = state.localAnimator:LoadAnimation(animation)
            track.Priority = Enum.AnimationPriority.Action4
            track:Play(0, 1, 1)
            currentForcedTrack = track
        end)
    end

    local function setAbilityCooldown(abilityName)
        if not abilityName then return end

        local abilityData = state.abilityData and state.abilityData[abilityName]
        local cooldownDuration = abilityData and abilityData.timeout

        if state.clientDebounce and type(state.clientDebounce.set) == "function" then
            pcall(function()
                state.clientDebounce.set(abilityName, cooldownDuration)
            end)
        end

        if state.abilityActivatedEvent then
            pcall(function()
                state.abilityActivatedEvent:Fire(abilityName)
            end)
        end

        if state.cooldownEvent then
            pcall(function()
                state.cooldownEvent:Fire(abilityName)
            end)
        end
    end

    onHeadSiphonCasterAnimationPlayed = function(track)
        if not track or reactedTracks[track] then return end

        local abilityName = state.headSiphonAbilityName
        if not abilityName then return end

        local animation = track.Animation
        local animationId = animation and animation.AnimationId
        if not animationId or not HEADSIPHON_CASTER_ANIMATION_IDS[animationId] then return end

        reactedTracks[track] = true
        state.headSiphonHits = state.headSiphonHits + 1
        setAbilityCooldown(abilityName)
    end

    onArmBreakCasterAnimationPlayed = function(track)
        if not track or reactedTracks[track] then return end

        local abilityName = state.armBreakAbilityName
        if not abilityName then return end

        local animation = track.Animation
        local animationId = animation and animation.AnimationId
        if animationId ~= ARMBREAK_CASTER_ANIMATION_ID then return end

        reactedTracks[track] = true
        state.armBreakHits = state.armBreakHits + 1
        setAbilityCooldown(abilityName)
    end

    local function onAdSomnumTagAdded(instance)
        if not isPartOfCurrentTarget(instance) then return end
        state.adSomnumTagHits = state.adSomnumTagHits + 1
        forceCasterAnimation(ADSOMNUM_CASTER_ANIMATION_ID)
        setAbilityCooldown(state.adSomnumTag or state.currentAbilityName)
    end

    local function onImmobilusTagAdded(instance)
        if not isPartOfCurrentTarget(instance) then return end
        state.immobilusTagHits = state.immobilusTagHits + 1
        forceCasterAnimation(IMMOBILUS_ACTIVATED_ANIMATION_ID)
        setAbilityCooldown(state.immobilusTag or state.currentAbilityName)
    end

    local function isVictimAnimationName(animationName)
        if type(animationName) ~= "string" then return false end
        return animationName:lower():find("victim", 1, true) ~= nil
    end

    local function isLoopingAnimationName(animationName)
        if type(animationName) ~= "string" then return false end
        return animationName:lower() == "idle"
    end

    local function buildAnimationLookups(abilityData)
        local victimIdToAbility = {}
        local victimAmbiguous = {}
        local casterIdToAbility = {}
        local casterAmbiguous = {}
        local abilitiesWithoutVictimData = {}

        for abilityName, data in pairs(abilityData) do
            local anims = type(data) == "table" and data.abilityAnimations
            if type(anims) == "table" then
                local hasVictimKey = false

                for key, id in pairs(anims) do
                    if isVictimAnimationName(key) and type(id) == "string" then
                        hasVictimKey = true
                        if victimIdToAbility[id] and victimIdToAbility[id] ~= abilityName then
                            victimAmbiguous[id] = true
                        else
                            victimIdToAbility[id] = abilityName
                        end
                    end
                end

                if not hasVictimKey then
                    abilitiesWithoutVictimData[abilityName] = true
                    for key, id in pairs(anims) do
                        if type(key) == "string" and type(id) == "string" and not isVictimAnimationName(key) and not isLoopingAnimationName(key) then
                            if casterIdToAbility[id] and casterIdToAbility[id] ~= abilityName then
                                casterAmbiguous[id] = true
                            else
                                casterIdToAbility[id] = abilityName
                            end
                        end
                    end
                end
            end
        end

        for id in pairs(victimAmbiguous) do
            victimIdToAbility[id] = nil
        end
        for id in pairs(casterAmbiguous) do
            casterIdToAbility[id] = nil
        end

        return victimIdToAbility, casterIdToAbility, abilitiesWithoutVictimData
    end

    local function onGenericVictimAnimationPlayed(track, animationId, character)
        local abilityName = state.victimAnimationLookup and state.victimAnimationLookup[animationId]
        if not abilityName then return end
        if state.erroxFemusTag and abilityName == state.erroxFemusTag then return end
        if isVictimAnimationReacted(character, animationId) then return end

        markVictimAnimationReacted(character, animationId, track)
        state.genericVictimHits = state.genericVictimHits + 1
        setAbilityCooldown(abilityName)
    end

    local function isHandledSeparately(abilityName)
        return (state.adSomnumTag and abilityName == state.adSomnumTag)
            or (state.immobilusTag and abilityName == state.immobilusTag)
            or (state.erroxFemusTag and abilityName == state.erroxFemusTag)
    end

    onLocalCasterAnimationPlayed = function(track)
        if not track or reactedTracks[track] then return end

        local animation = track.Animation
        local animationId = animation and animation.AnimationId
        if not animationId then return end

        local abilityName = state.casterAnimationLookup and state.casterAnimationLookup[animationId]

        if not abilityName then
            local currentAbilityName = state.currentAbilityName
            if currentAbilityName and state.abilitiesWithoutVictimData and state.abilitiesWithoutVictimData[currentAbilityName] then
                local abilityData = state.abilityData and state.abilityData[currentAbilityName]
                local anims = abilityData and abilityData.abilityAnimations
                if type(anims) == "table" then
                    for key, id in pairs(anims) do
                        if type(key) == "string" and not isVictimAnimationName(key) and not isLoopingAnimationName(key) and id == animationId then
                            abilityName = currentAbilityName
                            break
                        end
                    end
                end
            end
        end

        if not abilityName or isHandledSeparately(abilityName) then return end

        reactedTracks[track] = true
        state.casterAnimationHits = state.casterAnimationHits + 1
        setAbilityCooldown(abilityName)
    end

    local function onTargetAnimationPlayed(track)
        if not track then return end

        local animation = track.Animation
        local animationId = animation and animation.AnimationId
        if not animationId then return end

        local character = state.targetAnimatorCharacter
        if not character then return end

        if isVictimAnimationReacted(character, animationId) then return end

        if ERROXFEMUS_VICTIM_ANIMATION_IDS[animationId] then
            markVictimAnimationReacted(character, animationId, track)
            state.erroxFemusHits = state.erroxFemusHits + 1
            forceCasterAnimation(ERROXFEMUS_ACTIVATED_ANIMATION_ID)
            setAbilityCooldown(state.erroxFemusTag or state.currentAbilityName)
            return
        end

        onGenericVictimAnimationPlayed(track, animationId, character)
    end

    local function connectTargetAnimator(animator)
        state.targetAnimatorConnection = animator.AnimationPlayed:Connect(onTargetAnimationPlayed)

        local ok, tracks = pcall(function() return animator:GetPlayingAnimationTracks() end)
        if ok and tracks then
            for _, track in ipairs(tracks) do
                onTargetAnimationPlayed(track)
            end
        end
    end

    local function updateTargetAnimatorHook(character)
        if character == state.targetAnimatorCharacter then return end

        if state.targetAnimatorConnection then
            pcall(function() state.targetAnimatorConnection:Disconnect() end)
            state.targetAnimatorConnection = nil
        end
        state.targetAnimatorCharacter = character
        if not character then return end

        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
        if animator then
            connectTargetAnimator(animator)
            return
        end

        task.spawn(function()
            local waitedHumanoid = character:WaitForChild("Humanoid", 5)
            local waitedAnimator = waitedHumanoid and waitedHumanoid:WaitForChild("Animator", 5)
            if not waitedAnimator or state.targetAnimatorCharacter ~= character then return end

            connectTargetAnimator(waitedAnimator)
        end)
    end

    local function hookNamecall()
        if monitorState.hooked then return end
        if typeof(hookmetamethod) ~= "function" or typeof(getnamecallmethod) ~= "function" then return end

        monitorState.hooked = true
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            if state.enabled and self == state.abilityRemote and getnamecallmethod() == "FireServer" then
                state.remoteFires = state.remoteFires + 1
            end

            return oldNamecall(self, ...)
        end))
    end

    local function hookMouseUpvalue(func)
        if type(func) ~= "function" then return end
        local ok, upvalues = pcall(debug.getupvalues, func)
        if not ok or not upvalues then return end

        for index, upvalue in pairs(upvalues) do
            if typeof(upvalue) == "Instance" and upvalue:IsA("Mouse") then
                table.insert(state.mouseHooks, { func = func, index = index, original = upvalue })
                pcall(debug.setupvalue, func, index, fakeMouse)
            end
        end
    end

    local function findHitscanTableViaGc()
        if typeof(getgc) ~= "function" then return nil end

        for _, v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v, "Hitscan") and rawget(v, "AreaCheck") and not rawget(v, "CreateTargetProximityPrompt") then
                return v
            end
        end

        return nil
    end

    local function installSilentAimHooks()
        local hitscanTable = findHitscanTableViaGc()
        if hitscanTable and type(hitscanTable.Hitscan) == "function" then
            hookMouseUpvalue(hitscanTable.Hitscan)
        end

        if state.abilityHandlerModuleInstance then
            for _, mod in ipairs(state.abilityHandlerModuleInstance:GetChildren()) do
                local ok, moduleTable = pcall(require, mod)
                if ok and type(moduleTable) == "table" then
                    for _, f in pairs(moduleTable) do
                        if type(f) == "function" then
                            hookMouseUpvalue(f)
                        end
                    end
                end
            end
        end
    end

    local function isFriendCached(player)
        if not player or player == state.players.LocalPlayer then return false end

        local userId = player.UserId
        local cached = state.friendCache[userId]
        if cached == nil then
            state.friendCache[userId] = "loading"
            task.spawn(function()
                local ok, isFriend = pcall(function() return state.players.LocalPlayer:IsFriendsWith(userId) end)
                state.friendCache[userId] = ok and isFriend == true
            end)
            return false
        end

        return cached == true
    end

    local function scanTargets()
        if not state.enabled then return end

        local localPlayer = state.players.LocalPlayer
        local character = localPlayer.Character
        local camera = workspace.CurrentCamera
        if not character or not camera then return end

        local liveAbility = state.abilityHandler and state.abilityHandler.activeAbility
        state.activeRange = liveAbility and liveAbility._range or nil

        if state.restrictedAbility then
            local m = localPlayer:GetMouse()
            fakeMouse.X, fakeMouse.Y = m.X, m.Y
            state.hasTarget = false
            state.targetPart = nil
            updateTargetAnimatorHook(nil)
            return
        end

        local origin = state.activeOrigin and state.activeOrigin.Position
        local mousePosition = state.userInputService:GetMouseLocation()
        local bestDistance = math.huge
        local bestPart = nil

        for _, entity in ipairs(state.entities:GetChildren()) do
            if entity:IsA("Model") and entity ~= character then
                local humanoid = entity:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local targetPart = entity:FindFirstChild("HumanoidRootPart")

                    if targetPart and targetPart:IsA("BasePart") then
                        local skip = false

                        if EXCLUDE_FRIENDS then
                            local ownerPlayer = state.players:GetPlayerFromCharacter(entity)
                            if ownerPlayer and isFriendCached(ownerPlayer) then
                                skip = true
                            end
                        end

                        if not skip and origin and state.activeRange and (origin - targetPart.Position).Magnitude > state.activeRange then
                            skip = true
                        end

                        if not skip then
                            local screen, onScreen = camera:WorldToScreenPoint(targetPart.Position)
                            if onScreen and screen.Z > 0 then
                                local distance = (Vector2.new(screen.X, screen.Y) - mousePosition).Magnitude
                                if distance < bestDistance then
                                    bestDistance = distance
                                    bestPart = targetPart
                                end
                            end
                        end
                    end
                end
            end
        end

        if bestPart then
            state.targetPart = bestPart
            state.hasTarget = true
            local screen = camera:WorldToScreenPoint(bestPart.Position)
            fakeMouse.X, fakeMouse.Y = screen.X, screen.Y
            updateTargetAnimatorHook(bestPart.Parent)
        else
            state.hasTarget = false
            state.targetPart = nil
            updateTargetAnimatorHook(nil)
            local m = localPlayer:GetMouse()
            fakeMouse.X, fakeMouse.Y = m.X, m.Y
        end
    end

    local function triggerOptimisticAbilityReaction(abilityName, animationId, hitsField)
        if not abilityName or state.currentAbilityName ~= abilityName then return end

        local isAlive = state.clientDebounce
            and type(state.clientDebounce.isAlive) == "function"
            and state.clientDebounce.isAlive(abilityName)
        if isAlive then return end

        state[hitsField] = state[hitsField] + 1
        forceCasterAnimation(animationId)
        setAbilityCooldown(abilityName)
    end

    local function executeSpamRemote()
        if not state.active or not state.hasTarget or not state.abilityRemote then return end

        local part = state.targetPart
        local targetChar = part and part.Parent
        if not targetChar then return end

        if not targetChar:IsA("Model") then
            targetChar = part:FindFirstAncestorOfClass("Model")
        end
        if not targetChar then return end

        local fired = pcall(state.abilityRemote.FireServer, state.abilityRemote, targetChar)
        state.fireAttempts = state.fireAttempts + 1
        if fired then
            state.remoteFires = state.remoteFires + 1
        end

        triggerOptimisticAbilityReaction(state.phasmatosMotusIncendiamosAbilityName, PHASMATOSMOTUSINCENDIAMOS_ACTIVATED_ANIMATION_ID, "phasmatosMotusIncendiamosHits")
        triggerOptimisticAbilityReaction(state.ictusAbilityName, ICTUS_ACTIVATED_ANIMATION_ID, "ictusHits")
    end

    local function setActive(value)
        state.active = value == true
        tvlRecodeV2_LatestInventionState.active = state.active
        if not state.active then
            state.fireAccumulator = 0
        end
    end

    local function connect()
        if state.enabled then return true end

        state.players = game:GetService("Players")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        state.runService = game:GetService("RunService")
        state.userInputService = game:GetService("UserInputService")
        state.collectionService = game:GetService("CollectionService")

        local localPlayer = state.players.LocalPlayer
        if not localPlayer then
            return false, "LocalPlayer unavailable"
        end

        task.spawn(function()
            local contentProvider = game:GetService("ContentProvider")
            local preloadInstances = {}
            for _, animationId in ipairs({
                ADSOMNUM_CASTER_ANIMATION_ID,
                IMMOBILUS_ACTIVATED_ANIMATION_ID,
                ERROXFEMUS_ACTIVATED_ANIMATION_ID,
                PHASMATOSMOTUSINCENDIAMOS_ACTIVATED_ANIMATION_ID,
            }) do
                local animation = Instance.new("Animation")
                animation.AnimationId = animationId
                table.insert(preloadInstances, animation)
            end
            pcall(function()
                contentProvider:PreloadAsync(preloadInstances)
            end)
        end)

        state.entities = workspace:WaitForChild("Entities", 5)
        if not state.entities then
            return false, "Entities unavailable"
        end

        local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
        local abilityService = remotesFolder and remotesFolder:FindFirstChild("AbilityService")
        local toServer = abilityService and abilityService:FindFirstChild("ToServer")
        state.abilityRemote = (toServer and toServer:FindFirstChild("AbilityActivated____")) or ReplicatedStorage:FindFirstChild("AbilityActivated____", true)
        if not state.abilityRemote then
            return false, "AbilityActivated remote unavailable"
        end

        local playerScripts = localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local abilityHandlerModule = moduleScripts and moduleScripts:FindFirstChild("AbilityHandler")
        if abilityHandlerModule then
            state.abilityHandlerModuleInstance = abilityHandlerModule
            local handlerOk, abilityHandler = pcall(require, abilityHandlerModule)
            if handlerOk then
                state.abilityHandler = abilityHandler
            end
        end

        local replicatedModuleScripts = ReplicatedStorage:FindFirstChild("ModuleScripts")
        local enumsFolder = replicatedModuleScripts and replicatedModuleScripts:FindFirstChild("Enums")
        local abilityNameModule = enumsFolder and enumsFolder:FindFirstChild("AbilityName")
        if abilityNameModule then
            local enumOk, abilityNameEnum = pcall(require, abilityNameModule)
            if enumOk then
                state.abilityNameEnum = abilityNameEnum
                state.adSomnumTag = abilityNameEnum.AdSomnum
                state.immobilusTag = abilityNameEnum.Immobilus
                state.erroxFemusTag = abilityNameEnum.ErroxFemus
                state.phasmatosMotusIncendiamosAbilityName = abilityNameEnum.PhasmatosMotusIncendiamos
                state.ictusAbilityName = abilityNameEnum.Ictus
                state.headSiphonAbilityName = abilityNameEnum.HeadSiphon
                state.armBreakAbilityName = abilityNameEnum.ArmBreak
            end
        end

        local dataFolder = replicatedModuleScripts and replicatedModuleScripts:FindFirstChild("Data")
        local abilityDataModule = dataFolder and dataFolder:FindFirstChild("AbilityData")
        if abilityDataModule then
            local dataOk, abilityData = pcall(require, abilityDataModule)
            if dataOk then
                state.abilityData = abilityData
                local lookupOk, victimLookup, casterLookup, noVictimSet = pcall(buildAnimationLookups, abilityData)
                if lookupOk then
                    state.victimAnimationLookup = victimLookup
                    state.casterAnimationLookup = casterLookup
                    state.abilitiesWithoutVictimData = noVictimSet
                end
            end
        end

        local clientDebounceModule = moduleScripts and moduleScripts:FindFirstChild("ClientDebounce")
        if clientDebounceModule then
            local debounceOk, clientDebounce = pcall(require, clientDebounceModule)
            if debounceOk then
                state.clientDebounce = clientDebounce
            end
        end

        local bindablesFolder = ReplicatedStorage:FindFirstChild("Bindables")
        local fusionStates = bindablesFolder and bindablesFolder:FindFirstChild("FusionStates")
        state.cooldownEvent = fusionStates and fusionStates:FindFirstChild("CooldownChanged")

        refreshCurrentAbilityName()

        local abilitiesBindable = playerScripts and playerScripts:FindFirstChild("Bindables") and playerScripts.Bindables:FindFirstChild("Abilities")
        state.abilityActivatedEvent = abilitiesBindable and abilitiesBindable:FindFirstChild("AbilityActivated")
        local mainAbilitiesChanged = abilitiesBindable and abilitiesBindable:FindFirstChild("MainAbilitiesChanged")
        if mainAbilitiesChanged then
            addConnection(mainAbilitiesChanged.Event:Connect(function(abilityName)
                task.wait(0.1)
                refreshCurrentAbilityName()

                if abilityName then
                    local ability = state.abilityHandler and state.abilityHandler.activeAbility
                    applyRangeExpansion(ability)
                    state.activeRange = ability and ability._range or nil
                    state.activeOrigin = ability and ability._character and ability._character.PrimaryPart or nil
                    state.restrictedAbility = RESTRICTED_AIM_ABILITIES[abilityName] == true
                else
                    state.activeRange = nil
                    state.activeOrigin = nil
                    state.restrictedAbility = false
                end
            end))
        end

        pcall(function()
            applyRangeExpansion(state.abilityHandler and state.abilityHandler.activeAbility)
        end)

        installSilentAimHooks()

        state.fireAttempts = 0
        state.remoteFires = 0
        state.fireAccumulator = 0
        state.hasTarget = false
        state.targetPart = nil
        state.friendCache = {}
        state.enabled = true

        hookNamecall()

        pcall(function()
            state.runService:UnbindFromRenderStep(AIM_ASSIST_BIND_NAME)
        end)
        pcall(function()
            state.runService:BindToRenderStep(AIM_ASSIST_BIND_NAME, Enum.RenderPriority.Last.Value, scanTargets)
            state.aimAssistBound = true
        end)

        if localPlayer.Character then
            hookCharacterAnimator(localPlayer.Character)
        end
        addConnection(localPlayer.CharacterAdded:Connect(hookCharacterAnimator))

        if state.adSomnumTag then
            addConnection(state.collectionService:GetInstanceAddedSignal(state.adSomnumTag):Connect(onAdSomnumTagAdded))
        end

        if state.immobilusTag then
            addConnection(state.collectionService:GetInstanceAddedSignal(state.immobilusTag):Connect(onImmobilusTagAdded))
        end

        addConnection(state.userInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode == tvlRecodeV2_LatestInventionState.keyCode then
                if tvlRecodeV2_LatestInventionState.activationMode == "Toggle" then
                    setActive(not state.active)
                else
                    setActive(true)
                end
            end
        end))

        addConnection(state.userInputService.InputEnded:Connect(function(input)
            if input.KeyCode == tvlRecodeV2_LatestInventionState.keyCode and tvlRecodeV2_LatestInventionState.activationMode ~= "Toggle" then
                setActive(false)
            end
        end))

        addConnection(state.runService.RenderStepped:Connect(function(dt)
            if not state.enabled or not state.active then
                state.fireAccumulator = 0
                return
            end

            local cps = tvlRecodeV2_LatestInventionState.callsPerSecond
            if type(cps) ~= "number" or cps <= 0 then
                cps = 500
            end

            local interval = 1 / cps
            state.fireAccumulator = state.fireAccumulator + dt
            if state.fireAccumulator < interval then return end

            local fireCount = math.floor(state.fireAccumulator / interval)
            state.fireAccumulator = state.fireAccumulator - (fireCount * interval)

            scanTargets()

            for _ = 1, fireCount do
                executeSpamRemote()
            end
        end))

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                setActive(false)
                disconnectAll()
                return false, err
            end
            return true
        end

        state.enabled = false
        setActive(false)
        restoreRangeExpansion()
        state.entities = nil
        state.abilityRemote = nil
        state.abilityHandler = nil
        state.abilityHandlerModuleInstance = nil
        state.abilityData = nil
        state.victimAnimationLookup = nil
        state.casterAnimationLookup = nil
        state.abilitiesWithoutVictimData = nil
        state.clientDebounce = nil
        state.cooldownEvent = nil
        state.abilityActivatedEvent = nil
        state.abilityNameEnum = nil
        state.adSomnumTag = nil
        state.immobilusTag = nil
        state.erroxFemusTag = nil
        state.phasmatosMotusIncendiamosAbilityName = nil
        state.ictusAbilityName = nil
        state.headSiphonAbilityName = nil
        state.armBreakAbilityName = nil
        state.localAnimator = nil
        state.currentAbilityName = nil
        state.fireAccumulator = 0
        state.activeRange = nil
        state.activeOrigin = nil
        state.restrictedAbility = false
        state.hasTarget = false
        state.targetPart = nil
        disconnectAll()
        return true
    end

    function controller:setActive(value)
        setActive(value)
    end

    return controller
end

local function tvlRecodeV2Fn_getLatestInventionController()
    if not tvlRecodeV2_LatestInventionState.controller then
        tvlRecodeV2_LatestInventionState.controller = tvlRecodeV2Fn_createLatestInventionController()
    end
    return tvlRecodeV2_LatestInventionState.controller
end

local tvlRecodeV2_AutoCompelOptions = {
    { key = "FollowMe", fallback = "Follow me" },
    { key = "WalkAway", fallback = "Walk away" },
    { key = "Sleep", fallback = "Sleep" },
    { key = "MakeInvisible", fallback = "Make me invisible" },
    { key = "Nevermind", fallback = "Nevermind" },
}

local tvlRecodeV2_autoCompelState = {
    controller = nil,
    selectedAction = tvlRecodeV2_AutoCompelOptions[1].fallback,
}

local function tvlRecodeV2Fn_getAutoCompelDropdownOptions()
    local options = {}
    for _, definition in ipairs(tvlRecodeV2_AutoCompelOptions) do
        table.insert(options, definition.fallback)
    end
    return options
end

local function tvlRecodeV2Fn_unwrapAutoCompelDropdownValue(value)
    if type(value) ~= "table" then return value end
    local selected = value[1] or value.CurrentOption or value.Option or value.Value
    if type(selected) == "table" then return tvlRecodeV2Fn_unwrapAutoCompelDropdownValue(selected) end
    return selected
end

local function tvlRecodeV2Fn_createAutoCompelController()
    local GuiService = game:GetService("GuiService")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")

    local state = {
        enabled = false,
        selectedAction = tvlRecodeV2_autoCompelState.selectedAction,
        connection = nil,
        wholeScreen = nil,
        compulsionActionNames = nil,
    }

    local function loadCompulsionActionNames()
        if state.compulsionActionNames then return state.compulsionActionNames end
        local moduleScripts = ReplicatedStorage:FindFirstChild("ModuleScripts")
        local enums = moduleScripts and moduleScripts:FindFirstChild("Enums")
        local module = enums and enums:FindFirstChild("CompulsionActionNames")
        if not module then return nil end
        local ok, result = pcall(require, module)
        if ok and type(result) == "table" then
            state.compulsionActionNames = result
            return result
        end
        return nil
    end

    local function getActionLabel(definition)
        local names = loadCompulsionActionNames()
        local moduleValue = names and names[definition.key]
        if type(moduleValue) == "string" and moduleValue ~= "" then return moduleValue end
        return definition.fallback
    end

    local function normalizeText(value)
        return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
    end

    local function unwrapDropdownValue(value)
        if type(value) ~= "table" then return value end
        local selected = value[1] or value.CurrentOption or value.Option or value.Value
        if type(selected) == "table" then return unwrapDropdownValue(selected) end
        return selected
    end

    local function resolveAction(value)
        local wanted = normalizeText(unwrapDropdownValue(value))
        if wanted == "" then return state.selectedAction end
        local loweredWanted = wanted:lower()
        for _, definition in ipairs(tvlRecodeV2_AutoCompelOptions) do
            local label = getActionLabel(definition)
            if loweredWanted == label:lower()
                or loweredWanted == definition.key:lower()
                or loweredWanted == definition.fallback:lower()
            then
                return label
            end
        end
        return wanted
    end

    local function selectButton(button)
        button.Selectable = true
        button.Active = true
        GuiService.SelectedObject = button
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
    end

    local function trySelectCompulsion(compulsionList)
        if not state.enabled or not compulsionList or compulsionList.Name ~= "compulsionList" then return false end
        for _, descendant in ipairs(compulsionList:GetDescendants()) do
            if descendant:IsA("TextButton") then
                for _, child in ipairs(descendant:GetDescendants()) do
                    if child:IsA("TextLabel") and child.Text == state.selectedAction then
                        selectButton(descendant)
                        return true
                    end
                end
            end
        end
        return false
    end

    local function handleCompulsionList(child)
        if child.Name ~= "compulsionList" then return end
        task.defer(function() trySelectCompulsion(child) end)
    end

    local function getWholeScreen()
        if state.wholeScreen and state.wholeScreen.Parent then return state.wholeScreen end
        local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
        local mainInterface = playerGui:WaitForChild("MainInterface")
        state.wholeScreen = mainInterface:WaitForChild("WholeScreenComponents")
        return state.wholeScreen
    end

    local function disconnect()
        if state.connection then
            state.connection:Disconnect()
            state.connection = nil
        end
    end

    local function connect()
        if state.connection then return true end
        local wholeScreen = getWholeScreen()
        state.connection = wholeScreen.ChildAdded:Connect(handleCompulsionList)
        local currentList = wholeScreen:FindFirstChild("compulsionList")
        if currentList then handleCompulsionList(currentList) end
        return true
    end

    local controller = {}

    function controller:getOptions()
        local options = {}
        for _, definition in ipairs(tvlRecodeV2_AutoCompelOptions) do
            table.insert(options, getActionLabel(definition))
        end
        return options
    end

    function controller:getAction()
        return state.selectedAction
    end

    function controller:setAction(value)
        state.selectedAction = resolveAction(value)
        tvlRecodeV2_autoCompelState.selectedAction = state.selectedAction
        if state.enabled then
            task.defer(function()
                local wholeScreen = state.wholeScreen
                local currentList = wholeScreen and wholeScreen:FindFirstChild("compulsionList")
                if currentList then trySelectCompulsion(currentList) end
            end)
        end
        return state.selectedAction
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end
        if enable then
            state.enabled = true
            local ok, err = pcall(connect)
            if not ok then
                state.enabled = false
                disconnect()
                return false, err
            end
            return true
        end
        state.enabled = false
        disconnect()
        return true
    end

    return controller
end

local function tvlRecodeV2Fn_getAutoCompelController()
    if not tvlRecodeV2_autoCompelState.controller then
        tvlRecodeV2_autoCompelState.controller = tvlRecodeV2Fn_createAutoCompelController()
        tvlRecodeV2_autoCompelState.controller:setAction(tvlRecodeV2_autoCompelState.selectedAction)
    end
    return tvlRecodeV2_autoCompelState.controller
end

local tvlRecodeV2_autoIctusState = {
    controller = nil,
    humanDelayEnabled = true,
    minDelay = 0.15,
    maxDelay = 0.4,
}

local function tvlRecodeV2Fn_createAutoIctusController()
    local AutoIctus = {
        Enabled = false,
        Connections = {},
        lastSwapAt = 0,
        swapCooldown = 0.2,
        restoreDelay = 0.05,
        radius = 60,
        abilityClient = nil,
    }

    local equipOnlyAnimations = {
        ["rbxassetid://71157109677249"] = true,
        ["rbxassetid://81743171989186"] = true,
    }

    local equipAndClickAnimations = {
        ["rbxassetid://13632446588"] = true,
        ["rbxassetid://11493553665"] = true,
        ["rbxassetid://12308799798"] = true,
    }

    local Players = game:GetService("Players")
    local StarterPlayer = game:GetService("StarterPlayer")
    local LocalPlayer = Players.LocalPlayer

    local function addConn(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(AutoIctus.Connections, conn)
        end
    end

    local function disconnectAll()
        for i = #AutoIctus.Connections, 1, -1 do
            local conn = AutoIctus.Connections[i]
            pcall(function()
                conn:Disconnect()
            end)
            AutoIctus.Connections[i] = nil
        end
    end

    local function getAbilityClient()
        local module

        local ok = pcall(function()
            module = require(
                StarterPlayer
                    .StarterPlayerScripts
                    .ClientServices
                    .AbilityClient
                    ._
            )
        end)

        if ok and module then
            return module
        end

        ok = pcall(function()
            module = require(
                LocalPlayer
                    .PlayerScripts
                    .ClientServices
                    .AbilityClient
                    ._
            )
        end)

        if ok and module then
            return module
        end

        return nil
    end

    local function getPrimaryPart(char)
        if not char then
            return nil
        end

        return char.PrimaryPart
            or char:FindFirstChild("HumanoidRootPart")
            or char:FindFirstChild("UpperTorso")
            or char:FindFirstChild("Torso")
    end

    local function isWithinRadius(otherChar)
        local localChar = LocalPlayer.Character
        if not localChar or not otherChar then
            return false
        end

        local localPP = getPrimaryPart(localChar)
        local otherPP = getPrimaryPart(otherChar)

        if not localPP or not otherPP then
            return false
        end

        return (otherPP.Position - localPP.Position).Magnitude <= AutoIctus.radius
    end

    local function equipIctus(doClick)
        if not AutoIctus.Enabled or not AutoIctus.abilityClient then
            return
        end

        local now = os.clock()
        if now - AutoIctus.lastSwapAt < AutoIctus.swapCooldown then
            return
        end

        AutoIctus.lastSwapAt = now

        pcall(function()
            local abilityClient = AutoIctus.abilityClient
            local previous = nil

            if abilityClient.getEquippedAbility then
                previous = abilityClient.getEquippedAbility()
            end

            abilityClient.setAbility("Ictus")

            if doClick and type(mouse1click) == "function" then
                mouse1click()
            end

            task.delay(AutoIctus.restoreDelay, function()
                if not AutoIctus.Enabled or not AutoIctus.abilityClient then
                    return
                end

                local current = nil

                if abilityClient.getEquippedAbility then
                    current = abilityClient.getEquippedAbility()
                end

                if previous and previous ~= "Ictus" and current == "Ictus" then
                    abilityClient.setAbility(previous)
                end
            end)
        end)
    end

    local function reactTo(char, doClick)
        if not AutoIctus.Enabled or not isWithinRadius(char) then
            return
        end
        equipIctus(doClick)
    end

    local function handleAnimation(animId, char)
        if not animId or not AutoIctus.Enabled then
            return
        end

        if not isWithinRadius(char) then
            return
        end

        local doClick
        if equipAndClickAnimations[animId] then
            doClick = true
        elseif equipOnlyAnimations[animId] then
            doClick = false
        else
            return
        end

        if tvlRecodeV2_autoIctusState.humanDelayEnabled then
            local lo = math.min(tvlRecodeV2_autoIctusState.minDelay, tvlRecodeV2_autoIctusState.maxDelay)
            local hi = math.max(tvlRecodeV2_autoIctusState.minDelay, tvlRecodeV2_autoIctusState.maxDelay)
            local delay = lo + math.random() * (hi - lo)
            task.delay(delay, reactTo, char, doClick)
        else
            reactTo(char, doClick)
        end
    end

    local function hookCharacter(char)
        local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5)
        if not hum then
            return
        end

        addConn(hum.AnimationPlayed:Connect(function(track)
            if not AutoIctus.Enabled then
                return
            end

            local anim = track.Animation
            local animId = anim and anim.AnimationId

            handleAnimation(animId, char)
        end))
    end

    local function hookPlayer(player)
        if player == LocalPlayer then
            return
        end

        if player.Character then
            hookCharacter(player.Character)
        end

        addConn(player.CharacterAdded:Connect(function(char)
            if AutoIctus.Enabled then
                hookCharacter(char)
            end
        end))
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true

        if AutoIctus.Enabled == enable then
            return true
        end

        if enable then
            local abilityClient = getAbilityClient()
            if not abilityClient then
                return false
            end

            AutoIctus.abilityClient = abilityClient
            AutoIctus.Enabled = true

            for _, player in ipairs(Players:GetPlayers()) do
                hookPlayer(player)
            end

            addConn(Players.PlayerAdded:Connect(function(player)
                if AutoIctus.Enabled then
                    hookPlayer(player)
                end
            end))

            if type(getgenv) == "function" then
                getgenv().AutoIctus = AutoIctus
                getgenv().SetAutoIctusEnabled = function(enabled)
                    return controller:setEnabled(enabled)
                end
            end

            return true
        end

        AutoIctus.Enabled = false
        AutoIctus.abilityClient = nil
        disconnectAll()

        if type(getgenv) == "function" then
            getgenv().AutoIctus = nil
            getgenv().SetAutoIctusEnabled = nil
        end

        return true
    end

    return controller
end

