            label.Text = o.Title or tostring(flag)
            label.Parent = row

            keyText = Instance.new("TextLabel")
            keyText.Name = "\0"
            keyText.AnchorPoint = Vector2.new(1, 0.5)
            keyText.Position = UDim2.new(1, 0, 0.5, 0)
            keyText.Size = UDim2.new(0, 80, 1, 0)
            keyText.Font = Enum.Font.Gotham
            keyText.TextSize = 13
            keyText.TextColor3 = Color3.fromRGB(150, 150, 150)
            keyText.TextXAlignment = Enum.TextXAlignment.Right
            keyText.Parent = row
        end

        keyText.Text = current and ("[" .. current.Name .. "]") or "[None]"

        tvlRecodeV2_KeybindConfigRegistry[tostring(flag)] = {
            get = function()
                return current and current.Name or nil
            end,
            set = function(name)
                current = tvlRecodeV2Fn_keyCodeFromName(name)
                keyText.Text = current and ("[" .. current.Name .. "]") or "[None]"
                if o.ChangedCallback then o.ChangedCallback(current) end
            end,
        }

        local awaiting = false
        local captureConn
        cog.MouseButton1Click:Connect(function()
            if awaiting then return end
            awaiting = true
            cog.ImageColor3 = Color3.fromRGB(255, 255, 255)
            keyText.Text = "[ ... ]"
            captureConn = tvlRecodeV2_UIS.InputBegan:Connect(function(input, gameProcessed)
                if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
                if not awaiting then return end
                awaiting = false
                if captureConn then captureConn:Disconnect(); captureConn = nil end
                cog.ImageColor3 = Color3.fromRGB(150, 150, 150)
                if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
                    current = nil
                    keyText.Text = "[None]"
                else
                    current = input.KeyCode
                    keyText.Text = "[" .. current.Name .. "]"
                    if o.ChangedCallback then o.ChangedCallback(current) end
                end
            end)
        end)

        if current and o.ChangedCallback then
            o.ChangedCallback(current)
        end

        if o.List and type(tvlRecodeV2_Library.add_keybind_entry) == "function" then
            local listName = o.ListName or o.Title or tostring(flag)
            if not tvlRecodeV2_KeybindListAdded[listName] then
                tvlRecodeV2_KeybindListAdded[listName] = true
                pcall(function()
                    tvlRecodeV2_Library:add_keybind_entry({
                        name = listName,
                        get_key = function() return current end,
                        get_enabled = o.GetEnabled,
                        get_active = o.GetActive,
                        get_mode = o.GetMode,
                    })
                end)
            end
        end

        return {}
    end

    return secObj
end

local function tvlRecodeV2Fn_addRealTab(o)
    tvlRecodeV2Fn_buildYield()
    o = o or {}
    local title = o.Title or "Tab"
    local self = tvlRecodeV2_Window
    local page = self:tab({ name = title, tabs = { title } })
    local leftColumn  = tvlRecodeV2Fn_scrollColumn(page:column({ size = 1 }))
    local rightColumn = tvlRecodeV2Fn_scrollColumn(page:column({ size = 1 }))

    pcall(function()
        local holder = self.button_holder
        if holder then
            local kids = holder:GetChildren()
            for i = #kids, 1, -1 do
                local btn = kids[i]
                if btn:IsA("TextButton") then
                    local lbl = btn:FindFirstChildWhichIsA("TextLabel")
                    local img = btn:FindFirstChildWhichIsA("ImageLabel")
                    if lbl and lbl.Text == title and img then
                        local iconId = tvlRecodeV2_TAB_ICON_MAP[o.Icon]
                        if iconId then img.Image = iconId end
                        tvlRecodeV2_tabIconLabels[#tvlRecodeV2_tabIconLabels + 1] = img
                        break
                    end
                end
            end
        end
    end)

    local tabObj = { _columns = { leftColumn, rightColumn }, _next = 1 }
    function tabObj:AddSection(sname, side)
        local column
        if side == "left" then
            column = self._columns[1]
        elseif side == "right" then
            column = self._columns[2]
        else
            column = self._columns[self._next]
            self._next = (self._next == 1) and 2 or 1
        end
        return tvlRecodeV2Fn_makeSection(column, sname)
    end
    tabObj._title = title
    return tabObj
end

-- Lazily-created hidden tab that absorbs every section not kept in safe mode. It is a
-- fully real tab so all library calls on its sections (colorpickers, textboxes, elements
-- access, etc.) succeed exactly as they would normally — only its side button is hidden,
-- so the disallowed content builds without erroring but is never shown to the user.
local tvlRecodeV2_SafeSinkTab = nil
local function tvlRecodeV2Fn_getSafeSinkTab()
    if not tvlRecodeV2_SafeSinkTab then
        tvlRecodeV2_SafeSinkTab = tvlRecodeV2Fn_addRealTab({ Title = "\0safesink", Icon = "solar/home-bold" })
        pcall(function()
            local holder = tvlRecodeV2_Window.button_holder
            if holder then
                for _, btn in ipairs(holder:GetChildren()) do
                    if btn:IsA("TextButton") then
                        local lbl = btn:FindFirstChildWhichIsA("TextLabel")
                        if lbl and lbl.Text == "\0safesink" then
                            -- Reparent out of the button holder so the UIListLayout leaves
                            -- no gap, then hide it. The instance stays alive so any icon
                            -- references collected during tab creation remain valid.
                            btn.Visible = false
                            btn.Parent = holder.Parent
                            break
                        end
                    end
                end
            end
        end)
    end
    return tvlRecodeV2_SafeSinkTab
end

function tvlRecodeV2_Window:AddTab(o)
    o = o or {}
    local title = o.Title or "Tab"

    if not tvlRecodeV2_SafeMode then
        return tvlRecodeV2Fn_addRealTab(o)
    end

    local policy = tvlRecodeV2_SafeTabPolicy[title]

    -- Whole tab hidden: route every section to the hidden sink, create no visible tab.
    if policy == nil then
        local sink = tvlRecodeV2Fn_getSafeSinkTab()
        local proxy = {}
        function proxy:AddSection(sname, side)
            return sink:AddSection(sname, side)
        end
        return proxy
    end

    local realTab = tvlRecodeV2Fn_addRealTab(o)

    -- Whole tab kept.
    if policy == true then
        return realTab
    end

    -- Partial tab: keep listed sections, send the rest to the hidden sink.
    local allowed = policy
    local wrapper = { _real = realTab, _title = title }
    function wrapper:AddSection(sname, side)
        if allowed[sname] then
            return realTab:AddSection(sname, side)
        end
        return tvlRecodeV2Fn_getSafeSinkTab():AddSection(sname, side)
    end
    return wrapper
end

