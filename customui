                        local c = themes.preset.accent
                        if c ~= cur_accent then
                            cur_accent = c
                            title_shine_seq = title_build_shine(c)
                            for idx = #title_gradients, 1, -1 do
                                local g = title_gradients[idx]
                                if g.Parent then
                                    g.Color = title_shine_seq
                                else
                                    remove(title_gradients, idx)
                                end
                            end
                        end

                        local off = vec2(-0.75 + 1.5 * ((tick() * SPEED) % 1), 0)
                        for idx = #title_gradients, 1, -1 do
                            local g = title_gradients[idx]
                            if g.Parent then
