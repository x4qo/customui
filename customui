            local conn = state.connections[i]
            pcall(function()
                conn:Disconnect()
            end)
            state.connections[i] = nil
        end
        for i = #state.renderStepNames, 1, -1 do
            local name = state.renderStepNames[i]
            if state.runService then
                pcall(function()
                    state.runService:UnbindFromRenderStep(name)
                end)
            end
            state.renderStepNames[i] = nil
        end
    end

    local function spamTick()
        if not state.active then
            return
        end

        local ability = state.abilityHandler and state.abilityHandler.activeAbility
        if not ability then
            return
        end

        local targetSystem = ability._targetSystem
        if not targetSystem then
            return
        end

        -- spamTick is bound to ~14 render/step hooks per frame; the target info is
        -- identical within a single frame, so resolve it once per frame and reuse the
        -- cached args across every hook instead of recomputing GetTargetInfo 14x.
        -- Same fire rate, far less CPU (this is the main multi-feature lag source).
        local now = os.clock()
        local args = state._spamArgs
        if not args or (now - (state._spamArgsTime or 0)) >= 1 / 90 then
            local ok, fresh = pcall(function()
                return table.pack(targetSystem:GetTargetInfo())
            end)
            if not ok or not fresh or fresh.n == 0 or fresh[1] == nil then
                state._spamArgs = nil
                return
            end
            args = fresh
            state._spamArgs = fresh
            state._spamArgsTime = now
        end

        local remote = state.abilityRemote
        for _ = 1, tvlRecodeV2_domainExpansionState.burst do
            pcall(function()
                remote:FireServer(table.unpack(args, 1, args.n))
            end)
        end
    end

    local function visualTick()
        if not state.active then
            return
        end

        local ability = state.abilityHandler and state.abilityHandler.activeAbility
        if not ability then
            return
        end

        ability._isHolding = true
        pcall(function()
            ability:activated()
        end)
    end

    local function connect()
        if state.enabled then
            return true
        end

        local Players = game:GetService("Players")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        state.runService = game:GetService("RunService")
        state.userInputService = game:GetService("UserInputService")

        local localPlayer = Players.LocalPlayer
        local playerScripts = localPlayer and localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local abilityHandlerModule = moduleScripts and moduleScripts:WaitForChild("AbilityHandler", 5)
        if not abilityHandlerModule then
            return false, "AbilityHandler unavailable"
        end

        local handlerOk, abilityHandler = pcall(require, abilityHandlerModule)
        if not handlerOk or not abilityHandler then
            return false, "AbilityHandler require failed"
        end

        local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
        local abilityService = remotesFolder and remotesFolder:FindFirstChild("AbilityService")
        local toServer = abilityService and abilityService:FindFirstChild("ToServer")
        local abilityRemote = toServer and toServer:FindFirstChild("AbilityActivated____")
        if not abilityRemote then
            return false, "AbilityActivated remote unavailable"
        end

        state.abilityHandler = abilityHandler
        state.abilityRemote = abilityRemote
        state.enabled = true

        addConnection(state.userInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then
                return
            end
            if input.KeyCode == tvlRecodeV2_domainExpansionState.keyCode then
                if tvlRecodeV2_domainExpansionState.activationMode == "Toggle" then
                    state.active = not state.active
                else
                    state.active = true
                end
                tvlRecodeV2_domainExpansionState.active = state.active
            end
        end))

        addConnection(state.userInputService.InputEnded:Connect(function(input)
            if input.KeyCode == tvlRecodeV2_domainExpansionState.keyCode then
                if tvlRecodeV2_domainExpansionState.activationMode ~= "Toggle" then
                    state.active = false
                    tvlRecodeV2_domainExpansionState.active = false
                end
            end
        end))

        for i, name in ipairs({"SpamA", "SpamB", "SpamC", "SpamD", "SpamE"}) do
            pcall(function() state.runService:UnbindFromRenderStep(name) end)
            pcall(function() state.runService:BindToRenderStep(name, Enum.RenderPriority.First.Value - i, spamTick) end)
            table.insert(state.renderStepNames, name)
        end

        for _, data in ipairs({
            {"MaxSpeed", Enum.RenderPriority.First.Value},
            {"MaxSpeedMid", Enum.RenderPriority.Camera.Value},
            {"MaxSpeedLate", Enum.RenderPriority.Last.Value},
        }) do
            pcall(function() state.runService:UnbindFromRenderStep(data[1]) end)
            pcall(function() state.runService:BindToRenderStep(data[1], data[2], spamTick) end)
            table.insert(state.renderStepNames, data[1])
        end

        for _, name in ipairs({"RenderStepped", "Stepped", "Heartbeat", "PreRender", "PreSimulation", "PostSimulation"}) do
            pcall(function() addConnection(state.runService[name]:Connect(spamTick)) end)
        end

        addConnection(state.runService.Heartbeat:Connect(function()
            task.spawn(visualTick)
        end))

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                state.active = false
                disconnectAll()
                return false, err
            end
            return true
        end

        state.enabled = false
        state.active = false
        tvlRecodeV2_domainExpansionState.active = false
        state.abilityHandler = nil
        state.abilityRemote = nil
        disconnectAll()
        return true
    end

    function controller:setActive(value)
        state.active = value == true
        tvlRecodeV2_domainExpansionState.active = state.active
    end

    return controller
end

local function tvlRecodeV2Fn_getDomainExpansionController()
    if not tvlRecodeV2_domainExpansionState.controller then
        tvlRecodeV2_domainExpansionState.controller = tvlRecodeV2Fn_createDomainExpansionController()
    end
    return tvlRecodeV2_domainExpansionState.controller
end

local function tvlRecodeV2Fn_createVelOnlyController()
    local state = {
        enabled = false,
        active = false,
        currentRawTarget = nil,
        networkAccumulator = 0,
        lastDischargeTime = 0,
        frameDischargeCount = 0,
        carryHooked = false,
        connections = {},
        runService = nil,
        userInputService = nil,
        replicatedStorage = nil,
        collectionService = nil,
        workspace = workspace,
        entities = nil,
        abilityActivated = nil,
        fireAbility = nil,
        renderStepName = "ChronoMatrixPrioritySpam",
        renderStepBound = false,
    }

    local SCAN_RANGE = 120.0
    local SCAN_RANGE_SQ = SCAN_RANGE * SCAN_RANGE
    local CADENCE_LIMIT = 0.0105

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            local conn = state.connections[i]
            pcall(function()
                conn:Disconnect()
            end)
            state.connections[i] = nil
        end

        if state.renderStepBound and state.runService then
            pcall(function()
                state.runService:UnbindFromRenderStep(state.renderStepName)
            end)
            state.renderStepBound = false
        end
    end

    local function setActive(value)
        state.active = value == true
        tvlRecodeV2_velOnlyState.active = state.active
        if not state.active then
            state.networkAccumulator = 0
        end
    end

    local function scanTarget()
        local camera = state.workspace and state.workspace.CurrentCamera
        local players = game:GetService("Players")
        local localPlayer = players.LocalPlayer
        local character = localPlayer and localPlayer.Character
        local localHrp = character and character:FindFirstChild("HumanoidRootPart")

        if not localHrp or not camera or not state.entities then
            state.currentRawTarget = nil
            return
        end

        local mousePos = state.userInputService:GetMouseLocation()
        local mpx, mpy = mousePos.X, mousePos.Y
        local localHrpPos = localHrp.Position
        local lx, ly, lz = localHrpPos.X, localHrpPos.Y, localHrpPos.Z
        local closestDistSq = math.huge
        local bestPart = nil
        local rawModel = nil
        local targets = state.entities:GetChildren()
        local tagged = state.collectionService:GetTagged("CanBeCarried")

        for i = 1, #targets + #tagged do
            local entity = targets[i] or (tagged[i - #targets] and tagged[i - #targets].Parent)

            if entity and entity:IsA("Model") and entity ~= character then
                local root = entity:FindFirstChild("HumanoidRootPart") or entity.PrimaryPart
                local realTargetModel = entity

                if entity.Parent ~= state.workspace and entity.Parent ~= state.entities then
                    local carrierChar = entity:FindFirstAncestorOfClass("Model")
                    if carrierChar and carrierChar ~= entity and carrierChar:FindFirstChild("HumanoidRootPart") then
                        root = carrierChar.HumanoidRootPart
                        realTargetModel = carrierChar
                    end
                end

                if root then
                    local rootPos = root.Position
                    local dx = lx - rootPos.X
                    local dy = ly - rootPos.Y
                    local dz = lz - rootPos.Z
                    local currentDistanceSq = (dx * dx + dy * dy + dz * dz)

                    if currentDistanceSq <= SCAN_RANGE_SQ then
                        local screen, onScreen = camera:WorldToScreenPoint(rootPos)
                        if onScreen and screen.Z > 0 then
                            local mx = screen.X - mpx
                            local my = screen.Y - mpy
                            local mouseDistSq = mx * mx + my * my
                            if mouseDistSq < closestDistSq then
                                closestDistSq = mouseDistSq
                                bestPart = root
                                rawModel = realTargetModel
                            end
                        end
                    end
                end
            end
        end

        if bestPart and rawModel then
            state.currentRawTarget = rawModel
        elseif not state.active then
            state.currentRawTarget = nil
        end
    end

    local function executeCoreDischarge()
        if state.active and state.currentRawTarget and state.abilityActivated then
            local now = os.clock()

            if state.frameDischargeCount >= 2 and (now - state.lastDischargeTime) > 0.002 then
                return
            end

            state.frameDischargeCount = state.frameDischargeCount + 1
            state.lastDischargeTime = now

            local currentTarget = state.currentRawTarget

            task.spawn(state.fireAbility, state.abilityActivated, currentTarget)
            task.spawn(state.fireAbility, state.abilityActivated, currentTarget)

            task.defer(function()
                if state.active and state.currentRawTarget == currentTarget then
                    task.spawn(state.fireAbility, state.abilityActivated, currentTarget)
                    task.spawn(state.fireAbility, state.abilityActivated, currentTarget)
                end
            end)
        end
    end

    local function hookCarryCooldown()
        if state.carryHooked or type(getgc) ~= "function" then
            return
        end

        state.carryHooked = true
        task.spawn(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" and rawget(v, "set") and rawget(v, "isAlive") and rawget(v, "kill") then
                    local oldSet = v.set
                    v.set = function(name, timeout)
                        if state.active and name == "carry" then
                            return true
                        end
                        return oldSet(name, timeout)
                    end
                    break
                end
            end
        end)
    end

    local function connect()
        if state.enabled then
            return true
        end

        local Players = game:GetService("Players")
        state.runService = game:GetService("RunService")
        state.userInputService = game:GetService("UserInputService")
        state.replicatedStorage = game:GetService("ReplicatedStorage")
        state.collectionService = game:GetService("CollectionService")
        state.workspace = workspace

        local localPlayer = Players.LocalPlayer
        if not localPlayer then
            return false, "LocalPlayer unavailable"
        end

        state.entities = state.workspace:WaitForChild("Entities", 5)
        if not state.entities then
            return false, "Entities unavailable"
        end

        local remotes = state.replicatedStorage:FindFirstChild("Remotes")
        local toServer = remotes and remotes:FindFirstChild("GameServices") and remotes.GameServices:FindFirstChild("ToServer")
        state.abilityActivated = toServer and toServer:FindFirstChild("AbilityActivated____") or state.replicatedStorage:FindFirstChild("AbilityActivated____", true)
        if not state.abilityActivated then
            return false, "AbilityActivated remote unavailable"
        end

        state.fireAbility = state.abilityActivated.FireServer
        state.enabled = true

        addConnection(state.runService.Heartbeat:Connect(scanTarget))
        addConnection(state.runService.PreSimulation:Connect(function()
            state.frameDischargeCount = 0
            executeCoreDischarge()
        end))
        addConnection(state.runService.PostSimulation:Connect(function(deltaTime)
            if not state.active or not state.currentRawTarget then
                state.networkAccumulator = 0
                return
            end
            state.networkAccumulator = state.networkAccumulator + deltaTime
            while state.networkAccumulator >= CADENCE_LIMIT do
                executeCoreDischarge()
                state.networkAccumulator = state.networkAccumulator - CADENCE_LIMIT
            end
        end))
        addConnection(state.runService.Heartbeat:Connect(executeCoreDischarge))
        pcall(function()
            state.runService:BindToRenderStep(state.renderStepName, Enum.RenderPriority.Input.Value + 1, executeCoreDischarge)
            state.renderStepBound = true
        end)

        addConnection(state.userInputService.InputBegan:Connect(function(input, processed)
            if processed then
                return
            end
            if input.KeyCode == tvlRecodeV2_velOnlyState.keyCode then
                if tvlRecodeV2_velOnlyState.activationMode == "Toggle" then
                    setActive(not state.active)
                else
                    setActive(true)
                end
            end
        end))

        addConnection(state.userInputService.InputEnded:Connect(function(input)
            if input.KeyCode == tvlRecodeV2_velOnlyState.keyCode and tvlRecodeV2_velOnlyState.activationMode ~= "Toggle" then
                setActive(false)
            end
        end))

        hookCarryCooldown()

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                setActive(false)
                disconnectAll()
                return false, err
            end
            return true
        end

        state.enabled = false
        setActive(false)
        state.currentRawTarget = nil
        state.abilityActivated = nil
        state.fireAbility = nil
        disconnectAll()
        return true
    end

    function controller:setActive(value)
        setActive(value)
    end

    return controller
end

local function tvlRecodeV2Fn_getVelOnlyController()
    if not tvlRecodeV2_velOnlyState.controller then
        tvlRecodeV2_velOnlyState.controller = tvlRecodeV2Fn_createVelOnlyController()
    end
    return tvlRecodeV2_velOnlyState.controller
end

local function tvlRecodeV2Fn_createPrivateAutoDeployController()
    local state = {
        enabled = false,
        connections = {},
        selectedName = nil,
        selectedRace = nil,
        spamming = false,
        killCurrentSpam = nil,
        lastPress = 0,
    }

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            local conn = state.connections[i]
            pcall(function() conn:Disconnect() end)
            state.connections[i] = nil
        end
    end

    local function stopSpam()
        if state.killCurrentSpam then
            state.killCurrentSpam()
        end
    end

    local function startSpam()
        if state.spamming then
            stopSpam()
            return
        end
        if not state.selectedName or not state.selectedRace then
            return
        end

        state.spamming = true
        tvlRecodeV2_privateAutoDeployState.active = true

        local RunService = game:GetService("RunService")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local Player = game:GetService("Players").LocalPlayer
        local Entities = workspace:WaitForChild("Entities")

        local RENDER_STEP_NAME = "TVLRecodeV2PrivateAutoDeploySpam"

        local stopped = false
        local finalized = false
        local cleanedUp = false
        local inFlight = 0
        local MAX_INFLIGHT = 4
        local spamConnections = {}

        local function spamCleanup()
            if cleanedUp then return end
            cleanedUp = true
            for _, conn in ipairs(spamConnections) do
                pcall(function() conn:Disconnect() end)
            end
            pcall(function() RunService:UnbindFromRenderStep(RENDER_STEP_NAME) end)
        end

        local function killSwitch()
            if stopped then return end
            stopped = true
            state.spamming = false
            tvlRecodeV2_privateAutoDeployState.active = false
            state.killCurrentSpam = nil
            spamCleanup()
        end

        state.killCurrentSpam = killSwitch

        local function finalizeSpawn(spawnData)
            if finalized then return end
            finalized = true
            stopped = true
            state.spamming = false
            tvlRecodeV2_privateAutoDeployState.active = false
            state.killCurrentSpam = nil
            spamCleanup()

            pcall(function()
                ReplicatedStorage.Bindables.GameServices.Client.PlayerSpawned:Fire(spawnData)
            end)
            local menu = Player:WaitForChild("PlayerGui"):FindFirstChild("CharacterSelection", true)
            if menu and menu:IsA("ScreenGui") then
                menu.Enabled = false
            end
        end

        local function watchEntityModel(model)
            table.insert(spamConnections, model.AttributeChanged:Connect(killSwitch))
        end

        local existingEntity = Entities:FindFirstChild(Player.Name)
        if existingEntity then
            watchEntityModel(existingEntity)
        end

        table.insert(spamConnections, Entities.ChildAdded:Connect(function(child)
            if child.Name == Player.Name then
                killSwitch()
                watchEntityModel(child)
            end
        end))

        table.insert(spamConnections, Entities.DescendantAdded:Connect(function(descendant)
            local model = descendant
            while model and model.Parent ~= Entities do
                model = model.Parent
            end
            if model and model.Name == Player.Name then
                killSwitch()
            end
        end))

        table.insert(spamConnections, Player:GetPropertyChangedSignal("Character"):Connect(killSwitch))
        table.insert(spamConnections, Player.CharacterAdded:Connect(killSwitch))

        pcall(function()
            local mainAbilitiesChanged = Player
                :WaitForChild("PlayerScripts")
                :WaitForChild("Bindables")
                :WaitForChild("Abilities")
                :WaitForChild("MainAbilitiesChanged")
            table.insert(spamConnections, mainAbilitiesChanged.Event:Connect(killSwitch))
        end)

        local ok, err = pcall(function()
            local CS = require(ReplicatedStorage.ModuleScripts.Data.CharacterSpecies)
            local species = nil
            for speciesName, characters in pairs(CS) do
                if characters[state.selectedName] then
                    species = speciesName
                    break
                end
            end

            local outfits = ReplicatedStorage.Remotes.GameServices.ToServer.RequestCharacterOutfitList:InvokeServer()
            local CharacterSelectedFunction = ReplicatedStorage.Remotes.GameServices.ToServer.CharacterSelectedFunction

            local function fireOne()
                if stopped or inFlight >= MAX_INFLIGHT then return end
                inFlight += 1
                task.spawn(function()
                    pcall(function()
                        local success, spawnData = CharacterSelectedFunction:InvokeServer(state.selectedName, species, outfits, nil, true)
                        if success and spawnData then
                            finalizeSpawn(spawnData)
                        end
                    end)
                    inFlight -= 1
                end)
            end

            local function topUp()
                if stopped then return end
                while inFlight < MAX_INFLIGHT do
                    fireOne()
                end
            end

            table.insert(spamConnections, RunService.PreSimulation:Connect(topUp))
            table.insert(spamConnections, RunService.PostSimulation:Connect(topUp))
            table.insert(spamConnections, RunService.Heartbeat:Connect(topUp))
            RunService:BindToRenderStep(RENDER_STEP_NAME, Enum.RenderPriority.Input.Value + 1, topUp)

            topUp()
        end)

        if not ok then
            killSwitch()
        end
    end

    local TVL_PRIVATE_AUTO_DEPLOY_SHOW_NOTIFICATIONS = false
    local function silenceNotifyPlayer(replicatedStorage)
        if TVL_PRIVATE_AUTO_DEPLOY_SHOW_NOTIFICATIONS or type(getconnections) ~= "function" then
            return
        end
        pcall(function()
            local notifyPlayer = replicatedStorage.Remotes.GameServices.ToClient.NotifyPlayer
            for _, connection in ipairs(getconnections(notifyPlayer.OnClientEvent)) do
                connection:Disable()
            end
        end)
    end

    local function connect()
        if state.enabled then
            return true
        end

        local userInputService = game:GetService("UserInputService")
        local replicatedStorage = game:GetService("ReplicatedStorage")

        local ok, selectionEvent = pcall(function()
            return replicatedStorage:WaitForChild("Bindables"):WaitForChild("FusionStates"):WaitForChild("SelectedCharacterInformation")
        end)
        if not ok or not selectionEvent then
            return false, "SelectedCharacterInformation unavailable"
        end

        silenceNotifyPlayer(replicatedStorage)

        state.enabled = true

        addConnection(selectionEvent.Event:Connect(function(name, _, race)
            state.selectedName = name
            state.selectedRace = race
        end))

        addConnection(userInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode ~= tvlRecodeV2_privateAutoDeployState.keyCode then return end
            state.triggerSpam()
        end))

        return true
    end

    function state.triggerSpam()
        local now = os.clock()
        if now - state.lastPress < 0.5 then return end
        state.lastPress = now

        if state.spamming then
            stopSpam()
            tvlRecodeV2Fn_notifyFeature("Private Auto Deploy", "Spamming Off")
            return
        end

        startSpam()
        tvlRecodeV2Fn_notifyFeature("Private Auto Deploy", state.spamming and "Spamming On" or "Spamming Off")
    end

    local controller = {}

    function controller:trigger()
        if not state.enabled then
            tvlRecodeV2Fn_notifyFeature("Private Auto Deploy", "Enable it first")
            return false
        end
        state.triggerSpam()
        return true
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                disconnectAll()
                return false, err
            end
            return true
        end

        stopSpam()
        state.enabled = false
        state.selectedName = nil
        state.selectedRace = nil
        disconnectAll()
        return true
    end

    return controller
end

local function tvlRecodeV2Fn_getPrivateAutoDeployController()
    if not tvlRecodeV2_privateAutoDeployState.controller then
        tvlRecodeV2_privateAutoDeployState.controller = tvlRecodeV2Fn_createPrivateAutoDeployController()
    end
    return tvlRecodeV2_privateAutoDeployState.controller
end

local tvlRecodeV2_toolSpammerState = {
    controller = nil,
    keyCode = Enum.KeyCode.R,
}

local function tvlRecodeV2Fn_createToolSpammerController()
    local state = {
        enabled = false,
        holding = false,
        connections = {},
        runService = nil,
        userInputService = nil,
        toolHandler = nil,
        toolActivated = nil,
    }

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            local conn = state.connections[i]
            pcall(function()
                conn:Disconnect()
            end)
            state.connections[i] = nil
        end
    end

    local function fire()
        if not state.holding then
            return
        end

        local tool = state.toolHandler and state.toolHandler.activeTool
        if not tool or not tool._targetSystem then
            return
        end

        local target = tool._targetSystem.ValidTarget
        if target then
            pcall(function()
                state.toolActivated:FireServer(target)
            end)
        end
    end

    local function connect()
        if state.enabled then
            return true
        end

        local Players = game:GetService("Players")
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        state.runService = game:GetService("RunService")
        state.userInputService = game:GetService("UserInputService")

        local localPlayer = Players.LocalPlayer
        local playerScripts = localPlayer and localPlayer:WaitForChild("PlayerScripts", 5)
        local moduleScripts = playerScripts and playerScripts:WaitForChild("ModuleScripts", 5)
        local toolHandlerModule = moduleScripts and moduleScripts:WaitForChild("ToolHandler", 5)
        if not toolHandlerModule then
            return false, "ToolHandler unavailable"
        end

        local handlerOk, toolHandler = pcall(require, toolHandlerModule)
        if not handlerOk or not toolHandler then
            return false, "ToolHandler require failed"
        end

        local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
        local toolService = remotesFolder and remotesFolder:FindFirstChild("ToolService")
        local toServer = toolService and toolService:FindFirstChild("ToServer")
        local toolActivated = toServer and toServer:FindFirstChild("ToolActivated")
        if not toolActivated then
            return false, "ToolActivated remote unavailable"
        end

        state.toolHandler = toolHandler
        state.toolActivated = toolActivated
        state.enabled = true

        addConnection(state.userInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then
                return
            end
            if input.KeyCode == tvlRecodeV2_toolSpammerState.keyCode then
                state.holding = true
            end
        end))

        addConnection(state.userInputService.InputEnded:Connect(function(input)
            if input.KeyCode == tvlRecodeV2_toolSpammerState.keyCode then
                state.holding = false
            end
        end))

        addConnection(state.runService.Heartbeat:Connect(fire))
        addConnection(state.runService.Stepped:Connect(fire))
        addConnection(state.runService.RenderStepped:Connect(fire))

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            local ok, err = connect()
            if not ok then
                state.enabled = false
                state.holding = false
                disconnectAll()
                return false, err
            end
            return true
        end

        state.enabled = false
        state.holding = false
        state.toolHandler = nil
        state.toolActivated = nil
        disconnectAll()
        return true
    end

    return controller
end

