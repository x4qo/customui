local function tvlRecodeV2Fn_refreshAimLockPlayers()
    local dd = tvlRecodeV2_aimLockState.dropdown
    if not dd or type(dd.refresh_options) ~= "function" then return end
    local options = tvlRecodeV2Fn_getAimLockPlayerOptions()
    dd.options = options
    pcall(function() dd.refresh_options(options) end)
    -- prune anyone who left, keep the rest selected/highlighted
    local present = {}
    for _, name in ipairs(options) do present[name] = true end
    local stillSelected = {}
    for name in pairs(tvlRecodeV2_aimLockState.whitelist) do
        if present[name] then table.insert(stillSelected, name) end
    end
    tvlRecodeV2Fn_setAimLockWhitelist(stillSelected)
    pcall(function() dd.set(stillSelected) end)
end
