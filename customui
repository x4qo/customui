local function tvlRecodeV2Fn_setAccent(color)
    if tvlRecodeV2_lastAppliedAccent == color then
        return
    end
    tvlRecodeV2_lastAppliedAccent = color
    tvlRecodeV2_currentAccent = color
    tvlRecodeV2_Library:update_theme("accent", color)
    for _, img in ipairs(tvlRecodeV2_tabIconLabels) do
        if img.ImageColor3 ~= color then
            img.ImageColor3 = color
        end
    end
    for i = #tvlRecodeV2_accentListeners, 1, -1 do
        local callback = tvlRecodeV2_accentListeners[i]
        local ok = pcall(callback, color)
        if not ok then
            table.remove(tvlRecodeV2_accentListeners, i)
        end
    end
end

local function tvlRecodeV2Fn_setRainbow(on)
    if on and not tvlRecodeV2_rainbowConn then
        local acc = 0
        tvlRecodeV2_rainbowConn = tvlRecodeV2_RunService.Heartbeat:Connect(function(dt)
            acc = acc + dt
            if acc < 1 / 10 then return end
            acc = 0
            tvlRecodeV2Fn_setAccent(Color3.fromHSV((tick() * 0.15) % 1, 0.8, 1))
        end)
    elseif not on and tvlRecodeV2_rainbowConn then
        tvlRecodeV2_rainbowConn:Disconnect()
        tvlRecodeV2_rainbowConn = nil
        tvlRecodeV2Fn_setAccent(tvlRecodeV2_manualAccent)
    end
end


