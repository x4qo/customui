        invisible = "Invisible",
        crow = "Crow",
        wolf = "Wolf",
    }

    local function tvlRecodeV2Fn_tvlTrackConn(sig, fn)
        local conn = sig:Connect(fn)
        table.insert(tvlRecodeV2_playerEspState.connections, conn)
        return conn
    end

    local function tvlRecodeV2Fn_tvlDestroyPlayerMarker(model)
        local entry = tvlRecodeV2_playerEspState.playerEsp[model]
        if not entry then return end
        tvlRecodeV2_playerEspState.playerEsp[model] = nil
        if entry.connection then entry.connection:Disconnect() end
        if entry.bodyJumpedConnection then entry.bodyJumpedConnection:Disconnect() end
        if entry.visibilityConnections then
            for _, conn in ipairs(entry.visibilityConnections) do
                conn:Disconnect()
            end
        end
        if entry.toolConnections then
            for _, conn in ipairs(entry.toolConnections) do
                conn:Disconnect()
            end
        end
        if entry.gui and entry.gui.Parent then entry.gui:Destroy() end
    end

    local function tvlRecodeV2Fn_tvlGetCharacterColor(player, model, charName)
        local charColor = Color3.fromRGB(255, 255, 255)
        local specieType = (player.Character and player.Character:GetAttribute("SpecieType")) or model:GetAttribute("SpecieType")
        if specieType and specieType ~= "" and mSpeciesData and mSpeciesData[specieType] then
            charColor = mSpeciesData[specieType].specieColor
        end
        if mSpecialCharColors[charName] then
            charColor = mSpecialCharColors[charName]
        end
        return charColor
    end

    local function tvlRecodeV2Fn_tvlGetSpecieTypeColor(specieType, fallbackColor)
        if specieType and specieType ~= "" and mSpeciesData and mSpeciesData[specieType] and mSpeciesData[specieType].specieColor then
            return mSpeciesData[specieType].specieColor
        end
        return fallbackColor
    end

    local function tvlRecodeV2Fn_tvlCleanEspUsername(username)
        return tostring(username or ""):gsub("^@", "")
    end

    local function tvlRecodeV2Fn_tvlGetEspNameText(player)
        local username = tvlRecodeV2Fn_tvlCleanEspUsername(player.Name)
        local displayName = tvlRecodeV2Fn_tvlCleanEspUsername(player.DisplayName)
        if tvlRecodeV2_playerEspState.displayNameEspEnabled and displayName ~= "" and displayName ~= username then
            return displayName .. " (" .. username .. ")"
        end
        return username
    end

    tvlRecodeV2_playerEspState.refreshFriendCache = tvlRecodeV2Fn_espRefreshFriendCache

    local function tvlRecodeV2Fn_tvlIsFriendCached(player)
        if not player or player == mLocalPlayer then return false end

        local userId = player.UserId
        local cached = tvlRecodeV2_playerEspState.friendCache[userId]
        if cached == nil then
            tvlRecodeV2_playerEspState.friendCache[userId] = "loading"
            tvlRecodeV2Fn_espRefreshFriendCache()
            return false
        end

        return cached == true
    end

    local function tvlRecodeV2Fn_tvlGetUsernameColor(player, fallbackColor)
        if tvlRecodeV2_playerEspState.friendsEnabled and tvlRecodeV2Fn_tvlIsFriendCached(player) then
            return tvlRecodeV2Fn_tvlGetFriendColor()
        end
        return fallbackColor
    end

    local function tvlRecodeV2Fn_tvlColorText(colorHex, text)
        return string.format("<font color=\"%s\">%s</font>", colorHex, text)
    end

    local function tvlRecodeV2Fn_tvlBuildPlayerEspLabel(parts)
        local formatName = tvlRecodeV2_playerEspState.espFormat
        local nameText = tvlRecodeV2Fn_tvlColorText(parts.usernameColorHex, parts.nameText)
        local charText = parts.charName ~= "" and tvlRecodeV2Fn_tvlColorText(parts.charColorHex, parts.charName) or ""
        local specieInline = parts.specieType ~= "" and string.format(
            "<font color=\"#777777\"> - </font>%s",
            tvlRecodeV2Fn_tvlColorText(parts.specieColorHex, parts.specieType)
        ) or ""
        local specieStart = parts.specieType ~= "" and tvlRecodeV2Fn_tvlColorText(parts.specieColorHex, parts.specieType) or ""
        local specieSuffix = parts.specieType ~= "" and string.format(
            " %s",
            tvlRecodeV2Fn_tvlColorText(parts.specieColorHex, "(" .. parts.specieType .. ")")
        ) or ""
        local specieLine = parts.specieType ~= "" and string.format(
            "\n%s",
            tvlRecodeV2Fn_tvlColorText(parts.specieColorHex, parts.specieType)
        ) or ""
        local visibilityInline = parts.visibilityText ~= "" and string.format(
            "<font color=\"#777777\"> - </font>%s",
            tvlRecodeV2Fn_tvlColorText(parts.visibilityColorHex, parts.visibilityText)
        ) or ""
        local visibilitySuffix = parts.visibilityText ~= "" and string.format(
            " %s",
            tvlRecodeV2Fn_tvlColorText(parts.visibilityColorHex, "(" .. parts.visibilityText .. ")")
        ) or ""
        local visibilityBar = parts.visibilityText ~= "" and string.format(
            "<font color=\"#777777\"> | </font>%s",
            tvlRecodeV2Fn_tvlColorText(parts.visibilityColorHex, parts.visibilityText)
        ) or ""
        local visibilityLine = parts.visibilityText ~= "" and string.format(
            "<font color=\"#777777\"> - </font>%s\n",
            tvlRecodeV2Fn_tvlColorText(parts.visibilityColorHex, parts.visibilityText)
        ) or ""

        if parts.charName ~= "" then
            if formatName == "Format 1" then
                return string.format("%s%s\n%s%s%s", charText, specieSuffix, nameText, visibilitySuffix, parts.toolLine)
            elseif formatName == "Format 2" then
                return string.format("%s\n%s%s%s%s", charText, nameText, specieInline, visibilityInline, parts.toolLine)
            elseif formatName == "Format 4" then
                return string.format("%s%s\n%s%s%s", charText, specieLine, nameText, visibilityBar, parts.toolLine)
            end

            return string.format("%s\n%s%s%s%s", charText, specieStart, visibilityLine, nameText, parts.toolLine)
        end

        if formatName == "Format 1" then
            return string.format("%s%s%s%s", nameText, specieSuffix, visibilitySuffix, parts.toolLine)
        elseif formatName == "Format 2" then
            return string.format("%s%s%s%s", nameText, specieInline, visibilityInline, parts.toolLine)
        elseif formatName == "Format 4" then
            return string.format("%s%s%s%s", specieLine, nameText, visibilityBar, parts.toolLine)
        end

        return string.format("%s%s%s%s", specieStart, visibilityLine, nameText, parts.toolLine)
    end

    local function tvlRecodeV2Fn_tvlUpdateVisibilityStatus(entry, model)
        if model:GetAttribute("Creature") == true then
            entry.visibilityStatus = "wolf"
            return
        end

        if model:FindFirstChild("StarlingModel") then
            entry.visibilityStatus = "crow"
            return
        end

        local head = model:FindFirstChild("Head")
        if head and head:IsA("BasePart") and head.Transparency >= 1 then
            entry.visibilityStatus = "invisible"
        else
            entry.visibilityStatus = "visible"
        end
    end

    local function tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        local p = entry.player
        local model = entry.model
        local label = entry.label
        if not p or not model or not label then return end

        local charName = entry.bodyJumped and BODY_JUMP_CHAR or tostring(p:GetAttribute("CharacterName") or "")
        local baseUsernameColor = Color3.fromRGB(200, 200, 200)
        local usernameColor = tvlRecodeV2Fn_tvlGetUsernameColor(p, baseUsernameColor)
        local usernameColorHex = tvlRecodeV2Fn_tvlColorToHex(usernameColor)
        local nameText = tvlRecodeV2Fn_tvlGetEspNameText(p)
        local visibilityText = tvlRecodeV2_playerEspState.visibilityStatusEnabled and entry.visibilityStatus
        local visibilityColor = visibilityText and (mVisibilityStatusColors[visibilityText] or baseUsernameColor)
        local toolLine = (tvlRecodeV2_playerEspState.toolEspEnabled and entry.toolStatus and entry.toolStatus ~= "")
            and string.format("\n<font color=\"#A8A8A8\">%s</font>", entry.toolStatus)
            or ""
        local specieType = tvlRecodeV2_playerEspState.specieTypeEspEnabled and tostring(model:GetAttribute("SpecieType") or "")
        local charColor = baseUsernameColor
        local charColorHex = tvlRecodeV2Fn_tvlColorToHex(charColor)

        if charName ~= "" then
            charColor = tvlRecodeV2Fn_tvlGetCharacterColor(p, model, charName)
            charColorHex = tvlRecodeV2Fn_tvlColorToHex(charColor)
        end

        entry.charColor = charColor
        label.Text = tvlRecodeV2Fn_tvlBuildPlayerEspLabel({
            charName = charName,
            charColorHex = charColorHex,
            nameText = nameText,
            usernameColorHex = usernameColorHex,
            specieType = specieType or "",
            specieColorHex = tvlRecodeV2Fn_tvlColorToHex(tvlRecodeV2Fn_tvlGetSpecieTypeColor(specieType, charColor)),
            visibilityText = visibilityText and (mVisibilityStatusLabels[visibilityText] or visibilityText) or "",
            visibilityColorHex = tvlRecodeV2Fn_tvlColorToHex(visibilityColor or baseUsernameColor),
            toolLine = toolLine,
        })
    end

    local function tvlRecodeV2Fn_tvlRefreshAllPlayerLabels()
        for _, entry in pairs(tvlRecodeV2_playerEspState.playerEsp) do
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end
    end
    tvlRecodeV2_playerEspState.refreshLabels = tvlRecodeV2Fn_tvlRefreshAllPlayerLabels

    local function tvlRecodeV2Fn_tvlWatchVisibilityStatus(entry, model)
        entry.visibilityConnections = {}

        local function tvlRecodeV2Fn_visibilityTrackConnection(signal, callback)
            local conn = signal:Connect(callback)
            table.insert(entry.visibilityConnections, conn)
        end

        local function tvlRecodeV2Fn_visibilityRefreshStatus()
            tvlRecodeV2Fn_tvlUpdateVisibilityStatus(entry, model)
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end

        local function tvlRecodeV2Fn_watchHead(head)
            if head and head:IsA("BasePart") then
                tvlRecodeV2Fn_visibilityTrackConnection(head:GetPropertyChangedSignal("Transparency"), tvlRecodeV2Fn_visibilityRefreshStatus)
            end
        end

        tvlRecodeV2Fn_watchHead(model:FindFirstChild("Head"))
        tvlRecodeV2Fn_visibilityTrackConnection(model:GetAttributeChangedSignal("Creature"), tvlRecodeV2Fn_visibilityRefreshStatus)
        tvlRecodeV2Fn_visibilityTrackConnection(model.ChildAdded, function(child)
            if child.Name == "Head" then
                tvlRecodeV2Fn_watchHead(child)
            end
            if child.Name == "StarlingModel" then
                tvlRecodeV2Fn_visibilityRefreshStatus()
            end
        end)
        tvlRecodeV2Fn_visibilityTrackConnection(model.ChildRemoved, function(child)
            if child.Name == "StarlingModel" or child.Name == "Head" then
                tvlRecodeV2Fn_visibilityRefreshStatus()
            end
        end)

        tvlRecodeV2Fn_visibilityRefreshStatus()
    end

    local function tvlRecodeV2Fn_tvlUpdateToolStatus(entry, player)
        local backpack = player:FindFirstChild("Backpack")
        local character = player.Character
        local hasCure = (backpack and backpack:FindFirstChild("TheCure") ~= nil) or (character and character:FindFirstChild("TheCure") ~= nil)
        local hasStake = (backpack and backpack:FindFirstChild("IndestructibleWhiteOakStake") ~= nil) or (character and character:FindFirstChild("IndestructibleWhiteOakStake") ~= nil)

        local tools = {}
        if hasCure then table.insert(tools, "Cure") end
        if hasStake then table.insert(tools, "IndWhiteOak") end

        entry.toolStatus = table.concat(tools, ", ")
    end

    local function tvlRecodeV2Fn_tvlWatchToolStatus(entry, player)
        entry.toolConnections = {}

        local function tvlRecodeV2Fn_toolTrackConnection(signal, callback)
            local conn = signal:Connect(callback)
            table.insert(entry.toolConnections, conn)
        end

        local function tvlRecodeV2Fn_toolRefreshStatus()
            tvlRecodeV2Fn_tvlUpdateToolStatus(entry, player)
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end

        local function tvlRecodeV2Fn_watchBackpack(backpack)
            if not backpack then return end
            tvlRecodeV2Fn_toolTrackConnection(backpack.ChildAdded, function(child)
                if child.Name == "TheCure" or child.Name == "IndestructibleWhiteOakStake" then
                    tvlRecodeV2Fn_toolRefreshStatus()
                end
            end)
            tvlRecodeV2Fn_toolTrackConnection(backpack.ChildRemoved, function(child)
                if child.Name == "TheCure" or child.Name == "IndestructibleWhiteOakStake" then
                    tvlRecodeV2Fn_toolRefreshStatus()
                end
            end)
        end

        local function tvlRecodeV2Fn_watchCharacter(character)
            if not character then return end
            tvlRecodeV2Fn_toolTrackConnection(character.ChildAdded, function(child)
                if child.Name == "TheCure" or child.Name == "IndestructibleWhiteOakStake" then
                    tvlRecodeV2Fn_toolRefreshStatus()
                end
            end)
            tvlRecodeV2Fn_toolTrackConnection(character.ChildRemoved, function(child)
                if child.Name == "TheCure" or child.Name == "IndestructibleWhiteOakStake" then
                    tvlRecodeV2Fn_toolRefreshStatus()
                end
            end)
        end

        tvlRecodeV2Fn_watchBackpack(player:FindFirstChild("Backpack"))
        tvlRecodeV2Fn_watchCharacter(player.Character)
        tvlRecodeV2Fn_toolTrackConnection(player.ChildAdded, function(child)
            if child.Name == "Backpack" then
                tvlRecodeV2Fn_watchBackpack(child)
                tvlRecodeV2Fn_toolRefreshStatus()
            end
        end)
        tvlRecodeV2Fn_toolTrackConnection(player.CharacterAdded, function(character)
            tvlRecodeV2Fn_watchCharacter(character)
            tvlRecodeV2Fn_toolRefreshStatus()
        end)

        tvlRecodeV2Fn_toolRefreshStatus()
    end

    local function tvlRecodeV2Fn_tvlCreatePlayerMarker(model)
        if not tvlRecodeV2_playerEspState.active or not model or not model:IsA("Model") or tvlRecodeV2_playerEspState.playerEsp[model] then return end
        local targetPlayer = mPlayers:FindFirstChild(model.Name)
        if not targetPlayer or targetPlayer == mLocalPlayer then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "TVLPlayerESP"
        gui.Size = UDim2.new(0, 220, 0, 76)
        gui.AlwaysOnTop = true
        gui.StudsOffset = Vector3.new(0, 2.5, 0)
        gui.MaxDistance = MAX_DISTANCE
        gui.Parent = tvlRecodeV2_GuiParent

        local label = Instance.new("TextLabel")
        label.Parent = gui
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(1, 0, 1, 0)
        label.Font = Enum.Font.GothamMedium
        label.TextSize = 11
        label.TextWrapped = false
        label.RichText = true
        label.TextYAlignment = Enum.TextYAlignment.Top
        label.TextXAlignment = Enum.TextXAlignment.Center
        label.TextTruncate = Enum.TextTruncate.AtEnd
        label.TextColor3 = Color3.fromRGB(200, 200, 200)
        label.TextStrokeTransparency = 0.5
        label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        label.Text = ""

        local entry = { gui = gui, label = label, model = model, player = targetPlayer, connections = {} }
        tvlRecodeV2_playerEspState.playerEsp[model] = entry
        tvlRecodeV2Fn_tvlWatchVisibilityStatus(entry, model)
        tvlRecodeV2Fn_tvlWatchToolStatus(entry, targetPlayer)

        local function tvlRecodeV2Fn_trackPlayerMarkerConnection(signal, callback)
            local conn = signal:Connect(callback)
            table.insert(entry.connections, conn)
        end

        local function tvlRecodeV2Fn_getTargetRoot()
            return model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head")
        end

        local function tvlRecodeV2Fn_refreshAdornee()
            gui.Adornee = tvlRecodeV2Fn_getTargetRoot()
        end

        local function tvlRecodeV2Fn_tvlRefreshBodyJump()
            entry.bodyJumped = targetPlayer:GetAttribute("BodyJumped") ~= nil
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end
        tvlRecodeV2Fn_tvlRefreshBodyJump()

        tvlRecodeV2Fn_trackPlayerMarkerConnection(targetPlayer:GetAttributeChangedSignal("BodyJumped"), tvlRecodeV2Fn_tvlRefreshBodyJump)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(targetPlayer:GetAttributeChangedSignal("CharacterName"), function()
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(targetPlayer:GetPropertyChangedSignal("DisplayName"), function()
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(model:GetAttributeChangedSignal("SpecieType"), function()
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end)
        if targetPlayer.Character then
            tvlRecodeV2Fn_trackPlayerMarkerConnection(targetPlayer.Character:GetAttributeChangedSignal("SpecieType"), function()
                tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
            end)
        end
        tvlRecodeV2Fn_trackPlayerMarkerConnection(targetPlayer.CharacterAdded, function(character)
            tvlRecodeV2Fn_trackPlayerMarkerConnection(character:GetAttributeChangedSignal("SpecieType"), function()
                tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
            end)
            tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
        end)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(model.ChildAdded, function(child)
            if child.Name == "HumanoidRootPart" or child.Name == "Head" then
                tvlRecodeV2Fn_refreshAdornee()
            end
        end)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(model.ChildRemoved, function(child)
            if child.Name == "HumanoidRootPart" or child.Name == "Head" then
                tvlRecodeV2Fn_refreshAdornee()
            end
        end)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(model.AncestryChanged, function(_, parent)
            if not parent then tvlRecodeV2Fn_tvlDestroyPlayerMarker(model) end
        end)
        tvlRecodeV2Fn_trackPlayerMarkerConnection(targetPlayer.AncestryChanged, function(_, parent)
            if not parent then tvlRecodeV2Fn_tvlDestroyPlayerMarker(model) end
        end)

        tvlRecodeV2Fn_refreshAdornee()
        tvlRecodeV2Fn_tvlRefreshPlayerLabel(entry)
    end

    local function tvlRecodeV2Fn_tvlDestroyStakeMarker(model)
        local entry = tvlRecodeV2_playerEspState.stakeEsp[model]
        if not entry then return end
        tvlRecodeV2_playerEspState.stakeEsp[model] = nil
        if entry.connection then entry.connection:Disconnect() end
        if entry.gui and entry.gui.Parent then entry.gui:Destroy() end
    end

    local function tvlRecodeV2Fn_tvlCreateStakeMarker(model)
        if not tvlRecodeV2_playerEspState.active or not model or not model:IsA("Model") or model.Name ~= STAKE_NAME or tvlRecodeV2_playerEspState.stakeEsp[model] then return end
        local main = model:FindFirstChild("Main") or model:WaitForChild("Main", 3)
        if not main or not main:IsA("BasePart") then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "TVLStakeESP"
        gui.Size = UDim2.new(0, 120, 0, 25)
        gui.Adornee = main
        gui.AlwaysOnTop = true
        gui.MaxDistance = MAX_DISTANCE
        gui.StudsOffset = Vector3.new(0, 3, 0)
        gui.Parent = tvlRecodeV2_GuiParent

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextStrokeTransparency = 0.5
        label.TextStrokeColor3 = Color3.new(0, 0, 0)
        label.TextSize = 11
        label.Text = "White Oak Stake"
        label.Font = Enum.Font.GothamMedium
        label.Parent = gui

        local entry = { gui = gui }
        tvlRecodeV2_playerEspState.stakeEsp[model] = entry
        entry.connection = model.AncestryChanged:Connect(function(_, parent)
            if not parent then tvlRecodeV2Fn_tvlDestroyStakeMarker(model) end
        end)
    end

    local function tvlRecodeV2Fn_tvlDestroyCureMarker(obj)
        local entry = tvlRecodeV2_playerEspState.cureEsp[obj]
        if not entry then return end
        tvlRecodeV2_playerEspState.cureEsp[obj] = nil
        if entry.connection then entry.connection:Disconnect() end
        if entry.gui and entry.gui.Parent then entry.gui:Destroy() end
    end

    local function tvlRecodeV2Fn_tvlScanCureMarker()
        local interactables = mWorkspace:FindFirstChild("Interactables")
        local silasTomb = interactables and interactables:FindFirstChild("SilasTomb")
        local cureBox = silasTomb and silasTomb:FindFirstChild("CureBox")
        local theCure = cureBox and cureBox:FindFirstChild("TheCure")
        local cureAvailable = false
        if theCure then
            local takenUI = theCure:FindFirstChild("TakenUI")
            cureAvailable = not takenUI or not takenUI.Enabled
        end

        for obj in pairs(tvlRecodeV2_playerEspState.cureEsp) do
            if obj ~= theCure or not cureAvailable or not obj or not obj.Parent then
                tvlRecodeV2Fn_tvlDestroyCureMarker(obj)
            end
        end

        if not theCure or not cureAvailable or tvlRecodeV2_playerEspState.cureEsp[theCure] then return end

        local attachPart
        if theCure:IsA("BasePart") then
            attachPart = theCure
        elseif theCure:IsA("Model") then
            attachPart = theCure.PrimaryPart or theCure:FindFirstChildWhichIsA("BasePart")
        end
        if not attachPart then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "TVLCureESP"
        gui.Size = UDim2.new(0, 113, 0, 60)
        gui.Adornee = attachPart
        gui.AlwaysOnTop = true
        gui.MaxDistance = MAX_DISTANCE
        gui.StudsOffset = Vector3.new(0, 2.5, 0)
        gui.Parent = tvlRecodeV2_GuiParent

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0.25, 0)
        label.Position = UDim2.new(0, 0, 0.375, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 0, 0)
        label.TextStrokeTransparency = 0.5
        label.TextStrokeColor3 = Color3.new(0, 0, 0)
        label.TextSize = 11
        label.Text = "THE CURE"
        label.Font = Enum.Font.GothamMedium
        label.Parent = gui

        local entry = { gui = gui }
        tvlRecodeV2_playerEspState.cureEsp[theCure] = entry
        entry.connection = theCure.AncestryChanged:Connect(function(_, parent)
            if not parent then tvlRecodeV2Fn_tvlDestroyCureMarker(theCure) end
        end)
    end

    for _, entity in ipairs(mEntities:GetChildren()) do
        tvlRecodeV2Fn_tvlCreatePlayerMarker(entity)
    end

    for _, obj in ipairs(mWorkspace:GetChildren()) do
        if obj.Name == STAKE_NAME then tvlRecodeV2Fn_tvlCreateStakeMarker(obj) end
    end

    tvlRecodeV2Fn_tvlScanCureMarker()

    tvlRecodeV2Fn_tvlTrackConn(mEntities.ChildAdded, tvlRecodeV2Fn_tvlCreatePlayerMarker)
    tvlRecodeV2Fn_tvlTrackConn(mEntities.ChildRemoved, tvlRecodeV2Fn_tvlDestroyPlayerMarker)

    tvlRecodeV2Fn_tvlTrackConn(mWorkspace.ChildAdded, function(obj)
        if obj.Name == STAKE_NAME then tvlRecodeV2Fn_tvlCreateStakeMarker(obj) end
    end)

    tvlRecodeV2Fn_tvlTrackConn(mWorkspace.ChildRemoved, function(obj)
        if obj.Name == STAKE_NAME then tvlRecodeV2Fn_tvlDestroyStakeMarker(obj) end
    end)

    tvlRecodeV2Fn_tvlTrackConn(mRunService.Heartbeat, function()
        local now = os.clock()
        if now - tvlRecodeV2_playerEspState.lastCureScan >= CURE_SCAN_INTERVAL then
            tvlRecodeV2_playerEspState.lastCureScan = now
            pcall(tvlRecodeV2Fn_tvlScanCureMarker)
        end
    end)

    tvlRecodeV2Fn_tvlTrackConn(mPlayers.PlayerAdded, function(player)
        if player == mLocalPlayer then return end
        local model = mEntities:FindFirstChild(player.Name)
        if model then tvlRecodeV2Fn_tvlCreatePlayerMarker(model) end
    end)
end

local function tvlRecodeV2Fn_stopAstralEsp()
    tvlRecodeV2_astralEspState.active = false

    for _, conn in ipairs(tvlRecodeV2_astralEspState.connections) do
        pcall(function() conn:Disconnect() end)
    end
    table.clear(tvlRecodeV2_astralEspState.connections)

    for _, conn in ipairs(tvlRecodeV2_astralEspState.astralFolderConns) do
        pcall(function() conn:Disconnect() end)
    end
    table.clear(tvlRecodeV2_astralEspState.astralFolderConns)

    for model, entry in pairs(tvlRecodeV2_astralEspState.astralEsp) do
        for _, conn in ipairs(entry.connections or {}) do
            pcall(function() conn:Disconnect() end)
        end
        if entry.gui and entry.gui.Parent then entry.gui:Destroy() end
        tvlRecodeV2_astralEspState.astralEsp[model] = nil
    end
end

local function tvlRecodeV2Fn_startAstralEsp()
    if tvlRecodeV2_astralEspState.active then
        return
    end

    if not tvlRecodeV2_astralEspState.loaded then
        tvlRecodeV2_astralEspState.runService = game:GetService("RunService")
        tvlRecodeV2_astralEspState.workspace = game:GetService("Workspace")
        tvlRecodeV2_astralEspState.loaded = true
    end

    tvlRecodeV2_astralEspState.active = true

    local mWorkspace = tvlRecodeV2_astralEspState.workspace
    local MAX_DISTANCE = 3000

    local function tvlRecodeV2Fn_tvlFindAstralAdornee(model)
        return model.PrimaryPart
            or model:FindFirstChild("HumanoidRootPart", true)
            or model:FindFirstChild("Head", true)
            or model:FindFirstChildWhichIsA("BasePart", true)
    end

    local function tvlRecodeV2Fn_tvlRefreshAstralAdornee(model)
        local entry = tvlRecodeV2_astralEspState.astralEsp[model]
        if entry and entry.gui then
            entry.gui.Adornee = tvlRecodeV2Fn_tvlFindAstralAdornee(model)
        end
    end

    local function tvlRecodeV2Fn_tvlDestroyAstralMarker(model)
        local entry = tvlRecodeV2_astralEspState.astralEsp[model]
        if not entry then return end
        tvlRecodeV2_astralEspState.astralEsp[model] = nil
        for _, conn in ipairs(entry.connections or {}) do
            pcall(function() conn:Disconnect() end)
        end
        if entry.gui and entry.gui.Parent then entry.gui:Destroy() end
    end

    local function tvlRecodeV2Fn_tvlCreateAstralMarker(model)
        if not tvlRecodeV2_astralEspState.active or not model or not model:IsA("Model") or tvlRecodeV2_astralEspState.astralEsp[model] then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "TVLAstralESP"
        gui.Size = UDim2.new(0, 150, 0, 34)
        gui.Adornee = tvlRecodeV2Fn_tvlFindAstralAdornee(model)
        gui.AlwaysOnTop = true
        gui.MaxDistance = MAX_DISTANCE
        gui.StudsOffset = Vector3.new(0, 3, 0)
        gui.Parent = tvlRecodeV2_GuiParent

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(210, 245, 255)
        label.TextStrokeTransparency = 0.5
        label.TextStrokeColor3 = Color3.new(0, 0, 0)
        label.TextSize = 11
        label.Text = "Freya Mikaelson\n(astral body)"
        label.Font = Enum.Font.GothamMedium
        label.Parent = gui

        local entry = { gui = gui, connections = {} }
        tvlRecodeV2_astralEspState.astralEsp[model] = entry

        table.insert(entry.connections, model.AncestryChanged:Connect(function(_, parent)
            if not parent then tvlRecodeV2Fn_tvlDestroyAstralMarker(model) end
        end))
        table.insert(entry.connections, model.DescendantAdded:Connect(function(obj)
            if obj:IsA("BasePart") then tvlRecodeV2Fn_tvlRefreshAstralAdornee(model) end
        end))
        table.insert(entry.connections, model.DescendantRemoving:Connect(function(obj)
            if obj == gui.Adornee then
                task.defer(function() tvlRecodeV2Fn_tvlRefreshAstralAdornee(model) end)
            end
        end))
        pcall(function()
            table.insert(entry.connections, model:GetPropertyChangedSignal("PrimaryPart"):Connect(function()
                tvlRecodeV2Fn_tvlRefreshAstralAdornee(model)
            end))
        end)
    end

    local function tvlRecodeV2Fn_tvlClearAstralFolderConns()
        for _, conn in ipairs(tvlRecodeV2_astralEspState.astralFolderConns) do
            pcall(function() conn:Disconnect() end)
        end
        table.clear(tvlRecodeV2_astralEspState.astralFolderConns)
    end

    local function tvlRecodeV2Fn_tvlAttachAstralFolderListeners(folder)
        tvlRecodeV2Fn_tvlClearAstralFolderConns()
        if not folder then return end
        table.insert(tvlRecodeV2_astralEspState.astralFolderConns, folder.ChildAdded:Connect(function(child)
            task.defer(function() tvlRecodeV2Fn_tvlCreateAstralMarker(child) end)
        end))
        table.insert(tvlRecodeV2_astralEspState.astralFolderConns, folder.ChildRemoved:Connect(function(child)
            tvlRecodeV2Fn_tvlDestroyAstralMarker(child)
        end))
    end

    local function tvlRecodeV2Fn_tvlScanAstralFolder()
        local folder = mWorkspace:FindFirstChild("AstralProjection")
        if not folder then return nil end
        for model in pairs(tvlRecodeV2_astralEspState.astralEsp) do
            if not model or not model.Parent or not model:IsDescendantOf(folder) then
                tvlRecodeV2Fn_tvlDestroyAstralMarker(model)
            else
                tvlRecodeV2Fn_tvlRefreshAstralAdornee(model)
            end
        end
        for _, child in ipairs(folder:GetChildren()) do
            tvlRecodeV2Fn_tvlCreateAstralMarker(child)
        end
        return folder
    end

    tvlRecodeV2Fn_tvlAttachAstralFolderListeners(tvlRecodeV2Fn_tvlScanAstralFolder())

    table.insert(tvlRecodeV2_astralEspState.connections, mWorkspace.ChildAdded:Connect(function(child)
        if child.Name == "AstralProjection" then
            tvlRecodeV2Fn_tvlAttachAstralFolderListeners(tvlRecodeV2Fn_tvlScanAstralFolder())
        end
    end))

    table.insert(tvlRecodeV2_astralEspState.connections, mWorkspace.ChildRemoved:Connect(function(child)
        if child.Name == "AstralProjection" then
            tvlRecodeV2Fn_tvlClearAstralFolderConns()
            for model in pairs(tvlRecodeV2_astralEspState.astralEsp) do
                tvlRecodeV2Fn_tvlDestroyAstralMarker(model)
            end
        end
    end))
end

local function tvlRecodeV2Fn_stopPlantEsp()
