    task.spawn(function()
        local friendIds = {}
        local ok, pages = pcall(function()
            return Players:GetFriendsAsync(localPlayer.UserId)
        end)

        if ok and pages then
            local guard = 0
            while true do
                local pageOk = pcall(function()
                    for _, info in ipairs(pages:GetCurrentPage()) do
                        if info.Id then friendIds[info.Id] = true end
                    end
                end)
                if not pageOk or pages.IsFinished then break end
                guard += 1
                if guard > 100 then break end
                local advanced = pcall(function() pages:AdvanceToNextPageAsync() end)
                if not advanced then break end
            end
        end

        local cache = {}
        local list = playersToCache or Players:GetPlayers()
        for _, player in ipairs(list) do
            if player ~= localPlayer then
                cache[player.UserId] = friendIds[player.UserId] == true
            end
        end
        tvlRecodeV2_playerEspState.friendCache = cache
        tvlRecodeV2_friendCacheRefreshing = false

        if tvlRecodeV2_playerEspState.refreshLabels then
            tvlRecodeV2_playerEspState.refreshLabels()
        end
    end)
end
