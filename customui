local function tvlRecodeV2Fn_fetchPrivateAccess(hwid)
    hwid = tvlRecodeV2Fn_normalizeHwid(hwid)
    if hwid == "" then
        return false, nil
    end

    local requestFunc = tvlRecodeV2Fn_getRequestFunction()
    if type(requestFunc) ~= "function" then
        return false, nil
    end

    local HttpService = game:GetService("HttpService")
    local ok, response = pcall(function()
        return requestFunc({
            Url = "https://velhub.live/feature-access?feature=private&hwid=" .. HttpService:UrlEncode(hwid),
            Method = "GET",
            Headers = { ["User-Agent"] = "MyHub" },
        })
    end)

    if not ok then
        return false, nil
    end

    local body = type(response) == "table" and response.Body or response
    if type(body) ~= "string" then
        return false, nil
    end

    local decodedOk, decoded = pcall(function()
        return HttpService:JSONDecode(body)
    end)

    if decodedOk and type(decoded) == "table" then
        return decoded.allowed == true, decoded.tier
    end

    return false, nil
end

