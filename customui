-- SECURITY: access is decided solely by the licensing server, keyed to this HWID.
-- The __VELS_AUTH_TIER / __VELS_PRIVATE_ACCESS globals are attacker-controllable — anyone
-- can set them in getgenv()/_G before running the script — so they are NEVER trusted to
-- grant access. Access and tier come only from the server response; a spoofed global
-- cannot promote a user who the server does not already authorise.
local tvlRecodeV2_AuthHwid = tvlRecodeV2Fn_getDirectHwid()
local tvlRecodeV2_AuthTier = "regular"
local tvlRecodeV2_PrivateAccess = false
local tvlRecodeV2_VelAccess = false

do
    -- Vel access implies private access, so check it first: vel users need only one request.
    local velAllowed, velTier = tvlRecodeV2Fn_fetchVelAccess(tvlRecodeV2_AuthHwid)
    if velAllowed == true then
        tvlRecodeV2_VelAccess = true
        tvlRecodeV2_PrivateAccess = true
        if velTier then tvlRecodeV2_AuthTier = tostring(velTier):lower() end
    else
        local privAllowed, privTier = tvlRecodeV2Fn_fetchPrivateAccess(tvlRecodeV2_AuthHwid)
        if privAllowed == true then
            tvlRecodeV2_PrivateAccess = true
            if privTier then tvlRecodeV2_AuthTier = tostring(privTier):lower() end
        end
    end
end

local tvlRecodeV2_PrivateOnly = tvlRecodeV2_AuthTier == "private spammer"

local function tvlRecodeV2Fn_loadCustomUiSource(source)
    if type(source) ~= "string" or source == "" then
        return nil
    end

    local ok, result = pcall(function()
        return loadstring(source)()
    end)

    if ok and result then
        return result
    end

    return nil
end

local function tvlRecodeV2Fn_loadRequestedSource(url)
    return tvlRecodeV2Fn_loadCustomUiSource(tvlRecodeV2Fn_requestText(url))
end

local function tvlRecodeV2Fn_runRequestedSource(url)
    local source = tvlRecodeV2Fn_requestText(url)
    if type(source) ~= "string" or source == "" then
        return false
    end
    local ok, chunk = pcall(loadstring, source)
    if not ok or type(chunk) ~= "function" then
        return false
    end
    return pcall(chunk)
end

local function tvlRecodeV2Fn_loadCustomUiLibrary()
    -- raw.githubusercontent.com sits behind a CDN cache, so right after an update it will
    -- sometimes serve a stale copy. A unique query string busts that cache and guarantees
    -- the latest library every execution.
    local base = "https://raw.githubusercontent.com/x4qo/customui/refs/heads/main/customui"
    local bust = base .. "?cb=" .. tostring(os.time()) .. "_" .. tostring(math.random(0, 1000000))
    return tvlRecodeV2Fn_loadRequestedSource(bust)
end

local tvlRecodeV2_Library = tvlRecodeV2Fn_loadCustomUiLibrary()
tvlRecodeV2_Library = tvlRecodeV2_Library or getgenv().library
do
    local rawUpdateTheme = tvlRecodeV2_Library and tvlRecodeV2_Library.update_theme
    local lastThemeColor = {}
    if type(rawUpdateTheme) == "function" then
        function tvlRecodeV2_Library:update_theme(theme, color)
            if lastThemeColor[theme] == color then
                return
            end
            lastThemeColor[theme] = color
            return rawUpdateTheme(self, theme, color)
        end
    end
end

