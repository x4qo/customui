local function tvlRecodeV2Fn_createStaffNotifierController()
    local state = {
        enabled = false,
        connections = {},
    }

    local function addConnection(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            table.insert(state.connections, conn)
        end
    end

    local function disconnectAll()
        for i = #state.connections, 1, -1 do
            local conn = state.connections[i]
            pcall(function() conn:Disconnect() end)
            state.connections[i] = nil
        end
    end

    local function announce(player, role)
        tvlRecodeV2Fn_playNotificationPing()
        tvlRecodeV2Fn_notifyStats("Staff Notifier", player.Name .. " joined", "Rank: " .. role)
    end

    local function checkPlayer(player)
        task.spawn(function()
            local ok, role = pcall(function()
                return player:GetRoleInGroup(tvlRecodeV2_staffNotifierState.groupId)
            end)
            if state.enabled and ok and role and tvlRecodeV2_staffNotifierRanks[role] then
                announce(player, role)
            end
        end)
    end

    local function connect()
        if state.enabled then
            return true
        end

        local Players = game:GetService("Players")
        state.enabled = true

        for _, player in ipairs(Players:GetPlayers()) do
            checkPlayer(player)
        end

        addConnection(Players.PlayerAdded:Connect(checkPlayer))

        return true
    end

    local controller = {}

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then
            return true
        end

        if enable then
            connect()
            return true
        end

        state.enabled = false
        disconnectAll()
        return true
    end

    return controller
end

