local function tvlRecodeV2Fn_visualWaitForNode(root, pathParts, timeoutSeconds)
    local deadline = os.clock() + (timeoutSeconds or 30)
    while os.clock() < deadline do
        local node = root
        local found = true
        for i = 1, #pathParts do
            node = node and node:FindFirstChild(pathParts[i])
            if not node then found = false break end
        end
        if found and node then return node end
        task.wait(0.1)
    end
    return nil
end

local function tvlRecodeV2Fn_makeVisualColorController(abilityEnumKey, fallbackPreset)
    local CollectionService = game:GetService("CollectionService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer or Players.PlayerAdded:Wait()

    local state = {
        enabled = false,
        selected = fallbackPreset or "Valeria",
        customColor = nil,
        useCustom = false,
        tagName = nil,
        tagConn = nil,
    }

    local controller = {}

    local function getColor()
        if state.useCustom and state.customColor then
            return state.customColor
        end
        return tvlRecodeV2_VISUAL_COLORS[state.selected] or tvlRecodeV2_VISUAL_COLORS[fallbackPreset or "Valeria"]
    end

    local function isLocalTagged(tagged)
        return tagged and tagged.Name == tostring(LocalPlayer.UserId)
    end

    local function applyColor(tagged)
        if not state.enabled or not isLocalTagged(tagged) then return end
        pcall(function() tagged:SetAttribute("CustomColor", getColor()) end)
    end

    local function clearColor(tagged)
        if not isLocalTagged(tagged) then return end
        pcall(function() tagged:SetAttribute("CustomColor", nil) end)
    end

    local function refreshAllTagged()
        if not state.tagName then return end
        for _, tagged in ipairs(CollectionService:GetTagged(state.tagName)) do
            applyColor(tagged)
        end
    end

    local function clearAllTagged()
        if not state.tagName then return end
        for _, tagged in ipairs(CollectionService:GetTagged(state.tagName)) do
            clearColor(tagged)
        end
    end

    local function resolveTagName()
        if state.tagName then return state.tagName end
        local enumModule = tvlRecodeV2Fn_visualWaitForNode(ReplicatedStorage, { "ModuleScripts", "Enums", "AbilityName" }, 30)
        if not enumModule then return nil, "Could not find AbilityName enum" end
        local ok, AbilityName = pcall(require, enumModule)
        if not ok or type(AbilityName) ~= "table" then return nil, "Failed to require AbilityName" end
        local tagName = AbilityName[abilityEnumKey]
        if not tagName then return nil, "AbilityName." .. tostring(abilityEnumKey) .. " not found" end
        state.tagName = tagName
        return tagName
    end

    local function installHook()
        if state.tagConn then return true end
        local tagName, err = resolveTagName()
        if not tagName then return false, err end
        refreshAllTagged()
        state.tagConn = CollectionService:GetInstanceAddedSignal(tagName):Connect(function(tagged)
            if state.enabled then applyColor(tagged) end
        end)
        return true
    end

    local function uninstallHook()
        clearAllTagged()
        if state.tagConn then
            state.tagConn:Disconnect()
            state.tagConn = nil
        end
    end

    function controller:setPreset(value)
        local name = type(value) == "table" and value[1] or value
        if not tvlRecodeV2_VISUAL_COLORS[name] then return state.selected end
        state.selected = name
        state.useCustom = false
        if state.enabled then refreshAllTagged() end
        return state.selected
    end

    function controller:setCustomColor(color3)
        if typeof(color3) ~= "Color3" then return false end
        state.customColor = ColorSequence.new(color3)
        state.useCustom = true
        if state.enabled then refreshAllTagged() end
        return true
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end
        if enable then
            state.enabled = true
            local ok, installed, err = pcall(installHook)
            if not ok or not installed then
                state.enabled = false
                uninstallHook()
                return false, ok and err or installed
            end
            refreshAllTagged()
            return true
        end
        state.enabled = false
        uninstallHook()
        return true
    end

    return controller
end

local function tvlRecodeV2Fn_makeIncendiaColorController(fallbackPreset)
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer or Players.PlayerAdded:Wait()

    local state = {
        enabled = false,
        selected = fallbackPreset or "Valeria",
        customColor = nil,
        useCustom = false,
        originalAttr = nil,
        hadOriginal = false,
        hooked = false,
        module = nil,
        origBegin = nil,
        origFireballHit = nil,
        localGuids = {},
    }

    local controller = {}

    local function getColorSeq()
        if state.useCustom and state.customColor then
            return state.customColor
        end
        return tvlRecodeV2_VISUAL_COLORS[state.selected] or tvlRecodeV2_VISUAL_COLORS[fallbackPreset or "Valeria"]
    end

    local function applyAttr()
        if not state.enabled then return end
        pcall(function() LocalPlayer:SetAttribute("CustomColor", getColorSeq()) end)
    end

    local function restoreAttr()
        pcall(function()
            LocalPlayer:SetAttribute("CustomColor", state.hadOriginal and state.originalAttr or nil)
        end)
    end

    local function resolveModule()
        if state.module then return state.module end
        local ok, mod = pcall(function()
            return require(LocalPlayer.PlayerScripts.ModuleScripts.AbilityHandler.Incendia)
        end)
        if ok and type(mod) == "table" then
            state.module = mod
            return mod
        end
        return nil
    end

    local function installImpactHook()
        if state.hooked then return true end
        local mod = resolveModule()
        if not mod then return false, "Could not require Incendia handler" end

        state.origBegin = mod.begin
        state.origFireballHit = mod.fireballHit

        if type(state.origBegin) == "function" then
            mod.begin = function(player, guid, ...)
                if state.enabled and player == LocalPlayer and guid ~= nil then
                    state.localGuids[guid] = true
                end
                return state.origBegin(player, guid, ...)
            end
        end

        if type(state.origFireballHit) == "function" then
            mod.fireballHit = function(guid, position, color, ...)
                if state.enabled and guid ~= nil and state.localGuids[guid] and color == nil then
                    color = getColorSeq()
                end
                if guid ~= nil then state.localGuids[guid] = nil end
                return state.origFireballHit(guid, position, color, ...)
            end
        end

        state.hooked = true
        return true
    end

    local function uninstallImpactHook()
        if not state.hooked then return end
        local mod = state.module
        if mod then
            if state.origBegin ~= nil and mod.begin ~= state.origBegin then
                mod.begin = state.origBegin
            end
            if state.origFireballHit ~= nil and mod.fireballHit ~= state.origFireballHit then
                mod.fireballHit = state.origFireballHit
            end
        end
        state.origBegin = nil
        state.origFireballHit = nil
        table.clear(state.localGuids)
        state.hooked = false
    end

    function controller:setPreset(value)
        local name = type(value) == "table" and value[1] or value
        if not tvlRecodeV2_VISUAL_COLORS[name] then return state.selected end
        state.selected = name
        state.useCustom = false
        applyAttr()
        return state.selected
    end

    function controller:setCustomColor(color3)
        if typeof(color3) ~= "Color3" then return false end
        state.customColor = ColorSequence.new(color3)
        state.useCustom = true
        applyAttr()
        return true
    end

    function controller:setEnabled(value)
        local enable = value == true
        if state.enabled == enable then return true end
        if enable then
            local ok, current = pcall(function() return LocalPlayer:GetAttribute("CustomColor") end)
            state.hadOriginal = ok and current ~= nil
            state.originalAttr = ok and current or nil
            state.enabled = true
            applyAttr()
            installImpactHook()
            return true
        end
        state.enabled = false
        restoreAttr()
        uninstallImpactHook()
        return true
    end

    return controller
end

